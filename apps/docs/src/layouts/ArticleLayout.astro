---
import BaseLayout from "./BaseLayout.astro";
import { articleNavItems as navItems, type ArticleNavCurrent } from "../data/navigation";

export type { ArticleNavCurrent } from "../data/navigation";

interface Props {
  title: string;
  description?: string;
  current: ArticleNavCurrent;
  /** `teasers`: listing uses full main column; `article`: long-form post + optional right anchor nav; `default`: intro measure capped at 40rem. */
  pageVariant?: "default" | "teasers" | "article";
}

const { title, description = "Updates and articles from the Prism team.", current, pageVariant = "default" } =
  Astro.props;

---

<BaseLayout title={title} description={description}>
  <div class:list={["article-layout", pageVariant === "article" && "article-layout--article"]}>
    <nav class="section-nav section-nav--page" data-i18n-aria="article.sectionNav.aria" aria-label="Articles">
      <ul class="section-nav-list">
        {
          navItems.map((item) => (
            <li>
              <a
                class:list={["section-nav-link", { "is-current": current === item.id }]}
                href={item.href}
                aria-current={current === item.id ? "page" : undefined}
                data-i18n={item.i18n}
              >
                {item.fallback}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <article
      class:list={[
        "page",
        pageVariant === "teasers" && "page--article-teasers",
        pageVariant === "article" && "page--article-article",
      ]}
    >
      {pageVariant === "teasers" ? (
        <div id="article-teasers-root">
          <slot />
        </div>
      ) : (
        <slot />
      )}
    </article>
    {
      pageVariant === "article" ? (
        <aside class="article-anchor-aside" data-i18n-aria="article.articleAnchors.asideAria" aria-label="In this article">
          <slot name="anchors" />
        </aside>
      ) : null
    }
  </div>
  {pageVariant === "teasers" ? (
    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        var viewKey = "prism-article-teasers-view";
        var grid = document.getElementById("article-teasers-view-grid");
        var list = document.getElementById("article-teasers-view-list");
        var root = document.getElementById("article-teasers-root");
        if (!grid || !list || !root) return;

        var narrowMq = window.matchMedia("(max-width: 46.875rem)");

        function applyStoredView() {
          try {
            var v = localStorage.getItem(viewKey);
            if (v === "list") list.checked = true;
            else if (v === "grid") grid.checked = true;
          } catch (e) {}
        }

        function syncViewToViewport() {
          if (narrowMq.matches) {
            grid.checked = true;
          } else {
            applyStoredView();
          }
        }

        syncViewToViewport();

        if (narrowMq.addEventListener) {
          narrowMq.addEventListener("change", syncViewToViewport);
        } else {
          narrowMq.addListener(syncViewToViewport);
        }

        root.addEventListener("change", function (e) {
          var t = e.target;
          if (!t || t.name !== "article-teasers-view") return;
          if (narrowMq.matches) return;
          try {
            localStorage.setItem(viewKey, t.value);
          } catch (e2) {}
        });
      });
    </script>
  ) : null}
</BaseLayout>

<style>
  .article-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--prism-space-xl);
    width: 100%;
    max-width: none;
    align-items: start;
  }

  .section-nav {
    width: 100%;
    min-width: 0;
  }

  @media (max-width: 55.99rem) {
    .section-nav--page {
      display: none;
    }
  }

  .article-anchor-aside {
    display: none;
    width: 100%;
    min-width: 0;
  }

  @media (min-width: 56rem) {
    .article-layout {
      grid-template-columns: 12.5rem minmax(0, 1fr);
      column-gap: clamp(var(--prism-space-xl), 4vw, var(--prism-space-3xl));
    }

    .article-layout--article {
      grid-template-columns: 12.5rem minmax(0, 1fr);
    }

    .section-nav {
      position: sticky;
      top: calc(var(--site-header-sticky-anchor, 72px) + var(--prism-space-md));
      max-height: calc(100vh - var(--site-header-sticky-anchor, 72px) - var(--prism-space-xl));
      overflow-y: auto;
      padding-top: calc(var(--docs-page-content-padding-top) + var(--prism-space-sm) + 4px);
      padding-bottom: calc(var(--prism-space-md) + 4px);
      padding-inline: 6px;
    }
  }

  @media (min-width: 72rem) {
    .article-layout--article {
      grid-template-columns: 12.5rem minmax(0, 1fr) minmax(11.25rem, 14rem);
    }

    .article-anchor-aside {
      display: block;
      position: sticky;
      top: calc(var(--site-header-sticky-anchor, 72px) + var(--prism-space-md));
      max-height: calc(100vh - var(--site-header-sticky-anchor, 72px) - var(--prism-space-xl));
      overflow-y: auto;
      padding-top: calc(var(--docs-page-content-padding-top) + var(--prism-space-sm) + 4px);
      padding-bottom: calc(var(--prism-space-md) + 4px);
      padding-inline: 6px;
    }
  }

  .section-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    gap: var(--prism-space-xs);
  }

  .section-nav-list li {
    margin: 0;
    width: 100%;
    min-width: 0;
  }

  .section-nav-link {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: var(--prism-space-md) var(--prism-space-lg);
    text-decoration: none;
    color: var(--prism-color-text-primary);
    border-radius: 12px;
    background-color: transparent;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .section-nav-link.is-current {
    background-color: var(--nav-drawer-item-active-bg);
  }

  .section-nav-link:hover,
  .section-nav-link:focus-visible {
    background-color: var(--nav-drawer-item-active-bg);
    color: var(--prism-color-accent-strong);
  }

  .section-nav-link:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    outline-offset: 2px;
  }

  .page {
    width: 100%;
    max-width: 40rem;
    min-width: 0;
    padding-top: var(--docs-page-content-padding-top);
    padding-bottom: var(--prism-space-3xl);
  }

  .page--article-teasers,
  .page--article-article {
    max-width: none;
  }

  .page :global(.page-head) {
    margin-bottom: var(--prism-space-xl);
  }

  .page :global(.page-head:has(.article-teasers-head-row)) {
    margin-bottom: var(--prism-space-2xl);
  }

  .page :global(.intro) {
    margin: 0;
  }

  .page :global(.article-posts) {
    padding: 0 0 2rem;
  }

  .page :global(.article-article) {
    scroll-margin-top: calc(var(--docs-page-content-padding-top, 2rem) + 1rem);
    padding: clamp(2rem, 5vw, 2.75rem) 0;
    border-top: 1px solid color-mix(in srgb, var(--prism-color-border-subtle) 80%, transparent);
  }

  .page :global(.article-article--first) {
    border-top: none;
    padding-top: 0.5rem;
  }

  .page :global(.article-article__meta) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    margin: 0 0 0.65rem;
  }

  .page :global(.article-article__meta time) {
    font-size: var(--docs-fs-sm);
    font-weight: var(--docs-fw-regular);
    color: var(--docs-text-sm-color);
  }

  /* `pageVariant="article"` detail only (not listings or other update URLs). */
  .page.page--article-article :global(.article-article--full .article-article__meta time) {
    font-size: var(--docs-fs-lg);
  }

  /* Full article: 16px date→title; 32px title→author→hero (hero has no extra top). */
  .page.page--article-article :global(.article-article--full .article-article__head .article-article__meta) {
    margin-bottom: 16px;
  }

  .page.page--article-article :global(.article-article--full .article-article__head h1.article-article__title) {
    margin-bottom: 32px;
  }

  .page.page--article-article :global(.article-article--full .article-article__head-author) {
    margin: 0 0 32px 0;
  }

  .page.page--article-article :global(.article-article--full > .article-article__figure) {
    margin-top: 0;
  }

  /* Narrower measure for intro + byline after the hero figure (hero stays full column width). */
  .page.page--article-article :global(.article-article--full .article-article__body) {
    max-width: 1000px;
    margin-inline: auto;
    margin-top: 32px;
    width: 100%;
    box-sizing: border-box;
  }

  .page.page--article-article :global(.article-article--full .article-article__sections) {
    max-width: 800px;
    margin-inline: auto;
    width: 100%;
    box-sizing: border-box;
    overflow-x: visible;
  }

  .page :global(.article-article__title) {
    margin: 0;
    font-weight: var(--docs-fw-bold);
    letter-spacing: var(--docs-ls-tightest);
    line-height: var(--docs-lh-heading-tight);
  }

  /* Full post title: match ComponentsLayout `h1` (e.g. Accordion). */
  .page :global(.article-article--full .article-article__head h1.article-article__title) {
    margin: 0 0 var(--prism-space-sm);
    font-size: var(--docs-fs-display);
    font-weight: var(--docs-fw-bold);
    letter-spacing: var(--docs-ls-tighter);
    line-height: 1.08;
    scroll-margin-top: calc(var(--site-header-sticky-anchor, 72px) + var(--docs-page-content-padding-top, 2rem) + 0.5rem);
  }

  .page :global(.article-article--full .article-article__head-author) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 var(--prism-space-md);
  }

  .page :global(.article-article--full .article-article__head-author-avatar) {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid color-mix(in srgb, var(--prism-color-border-subtle) 75%, transparent);
  }

  .page :global(.article-article--full .article-article__head-author-avatars) {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .page
    :global(
      .article-article--full
        .article-article__head-author-avatars
        .article-article__head-author-avatar
        + .article-article__head-author-avatar
    ) {
    margin-left: -0.65rem;
    box-shadow: 0 0 0 2px var(--prism-color-surface);
  }

  .page :global(.article-article--full .article-article__head-author-name) {
    font-size: var(--docs-fs-base);
    font-weight: var(--docs-fw-medium);
    letter-spacing: var(--docs-ls-ui);
    line-height: var(--docs-lh-snug);
    color: var(--docs-text-sm-color);
  }

  :global([data-theme="dark"]) .page :global(.article-article--full .article-article__head-author-name) {
    color: var(--prism-color-text-secondary);
  }

  .page.page--article-article :global(.article-article--full .article-article__head-author-name) {
    font-size: var(--docs-fs-lg);
  }

  .page :global(.article-article--full .article-article__section-title),
  .page :global(.article-article--full .article-article__subsection-title) {
    scroll-margin-top: calc(var(--site-header-sticky-anchor, 72px) + var(--docs-page-content-padding-top, 2rem) + 0.5rem);
  }

  .page :global(.article-article__figure) {
    margin: clamp(1.25rem, 3vw, 1.75rem) 0 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--prism-color-border-subtle) 85%, transparent);
    background: color-mix(in srgb, var(--prism-color-border-subtle) 25%, var(--prism-color-surface));
  }

  .page :global(.article-article__img) {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: middle;
  }

  .page :global(.article-article__body) {
    margin-top: clamp(1.25rem, 3vw, 1.75rem);
  }

  .page :global(.article-article__body p) {
    margin: 0;
    font-size: var(--docs-fs-base);
    line-height: var(--docs-lh-relaxed);
    color: var(--prism-color-text-secondary);
  }

  .page :global(.article-article__sections > p + p) {
    margin-top: 1rem;
  }

  .page :global(.article-article__body .doc-h2-anchor-row + p) {
    margin-top: 1rem;
  }

  .page :global(.article-article__body p.article-article__try-cta-links) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0px;
    margin-bottom: 1.5rem;
  }

  /* Matches home “Explore all articles” (`.h-updates__view-all` on index). */
  .page :global(.article-article__try-cta-links a.article-article__home-view-all) {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    gap: 0.4em;
    margin: 0;
    padding: 0.25rem 0;
    font-size: var(--docs-fs-base);
    font-weight: var(--docs-fw-medium);
    letter-spacing: var(--docs-ls-label);
    line-height: var(--docs-lh-subheading);
    text-decoration: none;
    color: color-mix(in srgb, var(--prism-color-accent-strong) 91%, #000000);
    border-radius: 2px;
    transition: color 0.2s ease;
  }

  .page :global(.article-article__try-cta-links a.article-article__home-view-all:hover) {
    color: color-mix(in srgb, var(--prism-color-accent-strong) 82%, #000000);
  }

  .page :global(.article-article__home-view-all__label) {
    position: relative;
    display: inline-block;
    max-width: 100%;
    text-decoration: none;
  }

  .page :global(.article-article__home-view-all__label::after) {
    content: "";
    position: absolute;
    left: 0;
    top: calc(100% + 0.12em);
    width: 100%;
    height: 2px;
    border-radius: 999px;
    background-color: currentColor;
    pointer-events: none;
    transform: scaleX(0);
    transform-origin: right center;
    opacity: 0;
    transition:
      transform 0.38s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.32s ease;
  }

  .page :global(.article-article__try-cta-links a.article-article__home-view-all:hover .article-article__home-view-all__label::after),
  .page :global(.article-article__try-cta-links a.article-article__home-view-all:focus-visible .article-article__home-view-all__label::after) {
    transform: scaleX(1);
    transform-origin: left center;
    opacity: 1;
  }

  :global([data-theme="dark"]) .page :global(.article-article__try-cta-links a.article-article__home-view-all) {
    color: var(--prism-color-accent);
  }

  :global([data-theme="dark"]) .page :global(.article-article__try-cta-links a.article-article__home-view-all:hover) {
    color: var(--prism-color-accent);
  }

  .page :global(.article-article__try-cta-links a.article-article__home-view-all:focus-visible) {
    outline: 2px solid var(--prism-color-accent-strong);
    outline-offset: 3px;
  }

  :global([data-theme="dark"]) .page :global(.article-article__try-cta-links a.article-article__home-view-all:focus-visible) {
    outline-color: var(--prism-color-accent);
  }

  .page :global(.article-article__home-view-all__arrow) {
    display: inline-flex;
    align-items: center;
    line-height: 0;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .page :global(.article-article__try-cta-links a.article-article__home-view-all:hover .article-article__home-view-all__arrow) {
    transform: translate(0.12em, -0.12em);
  }

  .page :global(.article-article__home-view-all__arrow-icon) {
    display: block;
    width: 1.5em;
    height: 1.5em;
  }

  @media (prefers-reduced-motion: reduce) {
    .page :global(.article-article__try-cta-links a.article-article__home-view-all:hover .article-article__home-view-all__arrow) {
      transform: none;
    }

    .page :global(.article-article__home-view-all__label::after) {
      transition: none;
    }
  }

  .page :global(.article-article__body p + .article-article__affected-icons-label) {
    margin-top: 0.75rem;
  }

  .page :global(.article-article__body p[data-i18n="article.update.8.try.p1"] + p.article-article__try-cta-links) {
    margin-top: 0.75rem;
  }

  .page :global(.article-article__body .article-article__affected-icons-label + .article-article__affected-icons-list) {
    margin-top: 0.25rem;
  }

  .page :global(.article-article__body .article-article__affected-icons-list + p) {
    margin-top: 0.75rem;
  }

  .page :global(.article-article__body a.article-article__body-cta) {
    display: inline-block;
    font-size: var(--docs-fs-base);
    font-weight: var(--docs-fw-semibold);
    line-height: 1.5;
    color: var(--prism-color-accent-strong);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .page :global(.article-article__body a.article-article__body-cta:hover) {
    color: var(--prism-color-accent);
  }

  .page :global(.article-article__body .article-article__token-path) {
    font-family: var(--prism-font-mono);
    font-size: 0.875em;
    font-weight: var(--docs-fw-medium);
    letter-spacing: var(--docs-ls-heading-sm);
    overflow-wrap: anywhere;
    color: var(--prism-color-text-primary);
    border: 1px solid color-mix(in srgb, var(--prism-color-border-subtle) 85%, transparent);
    background: color-mix(in srgb, var(--prism-color-border-subtle) 22%, var(--prism-color-surface));
    padding-block: 0.14em;
    padding-inline: 0.4em;
    border-radius: 0.35rem;
  }

  /* Article section titles: DocH2WithAnchor + copy link; `doc-h2-anchor-heading` sets 36px globally (H2 default; Prism Skill post uses H3 for body sections under intro H2). */
  .page :global(.article-article__sections .doc-h2-anchor-row .doc-tabs__h2.article-article__section-title) {
    margin: 0;
    font-weight: var(--docs-fw-bold);
    letter-spacing: var(--docs-ls-tight);
    line-height: 1.2;
    color: var(--prism-color-text-primary);
  }

  /*
    H3 section titles (`DocH2WithAnchor` `level={3}`): between global `.doc-h2-anchor-heading` H2 (36px) and
    plain `.article-article__subsection-title` H4s (16px, same as April release subheads).
  */
  .page.page--article-article :global(
      .article-article__sections .doc-h2-anchor-row h3.doc-h2-anchor-heading.article-article__section-title
    ) {
    font-size: var(--docs-fs-2xl-fluid);
    letter-spacing: var(--docs-ls-fluid);
    line-height: var(--docs-lh-subheading);
  }

  /* Copy control sits in the margin via `doc-h2-anchor.css`; do not pad the row or the H2 won’t line up with body `<p>`. */
  .page.page--article-article :global(.article-article__sections .doc-h2-anchor-row) {
    padding-inline-start: 0;
    overflow: visible;
  }

  .page.page--article-article :global(.article-article__sections > .doc-h2-anchor-row:first-child),
  .page.page--article-article :global(.article-article__sections .article-article__subsection + .doc-h2-anchor-row),
  .page.page--article-article :global(.article-article__sections > p + .doc-h2-anchor-row),
  .page.page--article-article :global(.article-article__sections > p + .article-article__section),
  .page.page--article-article :global(.article-article__sections > .article-article__section + .article-article__section) {
    margin-top: 48px;
  }

  .page :global(.article-article__subsection) {
    margin-top: 2rem;
  }

  /* Subsection as first child of a `<section>` wrapper (e.g. Prism Skill closing block): avoid stacking `2rem` on top of section-vs-section spacing. */
  .page.page--article-article :global(.article-article__section > .article-article__subsection:first-child) {
    margin-top: 0;
  }

  .page :global(.article-article__subsection .article-article__subsection-title) {
    margin: 0 0 0.5rem;
    font-size: var(--docs-fs-base);
    font-weight: var(--docs-fw-semibold);
    letter-spacing: var(--docs-ls-heading-sm);
    line-height: var(--docs-lh-subheading);
    color: var(--prism-color-text-primary);
  }

  .page :global(.article-article__body .article-article__section-intro) {
    margin: 0 0 0.35rem;
  }

  .page :global(.article-article__body .article-article__inline-figure) {
    display: flex;
    flex-direction: column;
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--prism-color-border-subtle) 85%, transparent);
    background: color-mix(in srgb, var(--prism-color-border-subtle) 25%, var(--prism-color-surface));
  }

  .page :global(.article-article__body .article-article__subsection p + .article-article__inline-figure) {
    margin-top: 0.75rem;
  }

  .page :global(.article-article__body p + .article-article__compare-row) {
    margin-top: 0.75rem;
  }

  .page :global(.article-article__body .article-article__affected-icons-label) {
    margin: 0 0 0.35rem;
    font-weight: var(--docs-fw-semibold);
    color: var(--prism-color-text-primary);
  }

  .page :global(.article-article__body .article-article__compare-row + .article-article__affected-icons-label) {
    margin-top: 0.75rem;
  }

  .page :global(.article-article__body .article-article__affected-icons-list) {
    margin: 0;
    padding-left: 1.2rem;
    list-style-type: disc;
    font-size: var(--docs-fs-base);
    line-height: var(--docs-lh-reading);
    color: var(--prism-color-text-secondary);
  }

  .page :global(.article-article__body .article-article__affected-icons-list li) {
    padding-left: 0.15rem;
  }

  .page :global(.article-article__body .article-article__compare-row) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    align-items: stretch;
  }

  @media (max-width: 560px) {
    .page :global(.article-article__body .article-article__compare-row) {
      grid-template-columns: 1fr;
    }
  }

  .page :global(.article-article__body .article-article__compare-row .article-article__compare-cell) {
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    min-width: 0;
    height: 100%;
  }

  .page :global(.article-article__compare-cell > .article-article__inline-figure + .article-article__affected-icons-label) {
    margin: 0.65rem 0 0.25rem;
  }

  .page :global(.article-article__compare-cell > .article-article__affected-icons-list) {
    margin: 0;
  }

  .page :global(.article-article__body .article-article__subsection p + .article-article__inline-figure--media-player) {
    margin-top: 0.45rem;
  }

  .page :global(.article-article__body .article-article__inline-figure--media-player .article-article__inline-caption) {
    padding-block: 0.45rem;
    padding-inline: 0.85rem 1rem;
  }

  .page :global(.article-article__body .article-article__inline-figure .article-article__img) {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: middle;
  }

  /* Inset without stretching: padding on a wrapper; video stays width 100% of inner box + height auto. */
  .page :global(.article-article__body .article-article__inline-figure .article-article__inline-video-frame) {
    position: relative;
    box-sizing: border-box;
    padding-inline: clamp(0.75rem, 2.5vw, 1.25rem);
    padding-block: clamp(1.25rem, 3.5vw, 2rem);
    background: var(--prism-color-surface);
  }

  .page :global(.article-article__body .article-article__inline-figure .article-article__inline-video-stack) {
    width: min(40rem, 100%);
    margin-inline: auto;
  }

  .page :global(.article-article__body .article-article__inline-figure .article-article__inline-video-stack .article-article__inline-video) {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: middle;
    background: var(--prism-color-surface);
  }

  /* Bottom-right of `.article-article__inline-video-frame` (padding box), not only the video column. */
  .page :global(.article-article__body .article-article__inline-figure .article-article__inline-video-overlay-actions) {
    position: absolute;
    right: clamp(0.5rem, 1.75vw, 0.85rem);
    bottom: clamp(0.5rem, 1.75vw, 0.85rem);
    z-index: 2;
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
    pointer-events: none;
  }

  .page :global(.article-article__body .article-article__inline-figure .article-article__inline-video-overlay-actions .icon-btn) {
    pointer-events: auto;
  }

  .page :global(.article-article__body .article-article__inline-video-toggle .icon) {
    width: 1.25rem;
    height: 1.25rem;
  }

  /* SVGs do not always honor the HTML `[hidden]` UA rule inside flex buttons; force it. */
  .page :global(.article-article__body .article-article__inline-video-toggle svg.article-article__inline-video-icon[hidden]) {
    display: none !important;
  }

  .page :global(.article-article__body .article-article__inline-video-toggle.icon-btn) {
    background: color-mix(in srgb, var(--prism-color-accent) 16%, var(--prism-color-surface));
    border-color: color-mix(in srgb, var(--prism-color-accent) 32%, var(--prism-color-border-subtle));
    color: var(--prism-color-text-primary);
  }

  .page :global(.article-article__body .article-article__inline-video-toggle.icon-btn:hover:not(:disabled)) {
    background: color-mix(in srgb, var(--prism-color-accent) 24%, var(--prism-color-surface));
    border-color: color-mix(in srgb, var(--prism-color-accent) 48%, var(--prism-color-border-strong));
    color: var(--prism-color-text-primary);
  }

  .page :global(.article-article__subsection .article-article__subsection-title + .article-article__inline-figure),
  .page :global(.article-article__subsection .article-article__subsection-title + .article-article__compare-row) {
    margin-top: 0.75rem;
  }

  .page :global(.article-article--full .article-article-nav) {
    max-width: 800px;
    margin-inline: auto;
    width: 100%;
    box-sizing: border-box;
    margin-top: 2.5rem;
    padding-top: 1.75rem;
    border-top: 1px solid color-mix(in srgb, var(--prism-color-border-subtle) 85%, transparent);
  }

  .page :global(.article-article-nav__inner) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 1rem 1.5rem;
    align-items: start;
  }

  .page :global(.article-article-nav__link) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
    min-width: 0;
    text-decoration: none;
    color: inherit;
    border-radius: 6px;
  }

  .page :global(.article-article-nav__link--next) {
    align-items: flex-end;
    text-align: right;
  }

  .page :global(.article-article-nav__dir) {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-size: var(--docs-fs-md);
    font-weight: var(--docs-fw-medium);
    line-height: 1;
    color: var(--docs-text-sm-color);
  }

  :global([data-theme="dark"]) .page :global(.article-article-nav__dir) {
    color: var(--prism-color-text-secondary);
  }

  /* Unicode arrows sit low in Inter; size to label + slight lift so the shaft centers on cap height. */
  .page :global(.article-article-nav__arrow) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    line-height: 1;
    font-size: 1em;
    font-weight: var(--docs-fw-light);
    text-decoration: none;
    transform: translateY(-0.06em);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .page :global(.article-article-nav__link--prev:hover .article-article-nav__arrow),
  .page :global(.article-article-nav__link--prev:focus-visible .article-article-nav__arrow) {
    transform: translate(-0.25rem, -0.06em);
  }

  .page :global(.article-article-nav__link--next:hover .article-article-nav__arrow),
  .page :global(.article-article-nav__link--next:focus-visible .article-article-nav__arrow) {
    transform: translate(0.25rem, -0.06em);
  }

  .page :global(.article-article-nav__title) {
    font-size: var(--docs-fs-base);
    font-weight: var(--docs-fw-semibold);
    letter-spacing: var(--docs-ls-heading-sm);
    line-height: var(--docs-lh-snug);
    color: var(--prism-color-text-primary);
    text-decoration: none;
  }

  .page :global(.article-article-nav__link:hover .article-article-nav__title),
  .page :global(.article-article-nav__link:focus-visible .article-article-nav__title) {
    color: var(--prism-color-accent-strong);
  }

  .page :global(.article-article-nav__link:focus-visible) {
    outline: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    outline-offset: 3px;
  }

  .page :global(.article-article-nav__slot--empty) {
    min-height: 1px;
  }

  .page.page--article-article :global(.article-article--full .article-article-nav__title) {
    font-size: var(--docs-fs-lg);
  }

  .page :global(.article-update-back) {
    margin: 0 0 var(--prism-space-lg);
  }

  .page :global(.article-update-back__link) {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-size: var(--docs-fs-md);
    font-weight: var(--docs-fw-medium);
    color: var(--prism-color-accent-strong);
    text-decoration: none;
  }

  .page :global(.article-update-back__label) {
    text-decoration: none;
  }

  /* Same weight/size as overview list trail; accent color (link inherits). */
  .page :global(.article-update-back__arrow) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    line-height: 1;
    font-size: var(--docs-fs-xl-plus);
    font-weight: var(--docs-fw-light);
    color: var(--prism-color-accent-strong);
    text-decoration: none;
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .page :global(.article-update-back__link:hover .article-update-back__arrow),
  .page :global(.article-update-back__link:focus-visible .article-update-back__arrow) {
    transform: translateX(-0.35rem);
  }

  .page :global(.article-update-back__link:hover .article-update-back__label),
  .page :global(.article-update-back__link:focus-visible .article-update-back__label) {
    text-decoration: underline;
  }

  .page :global(.article-update-back__link:focus-visible) {
    outline: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .page :global(.article-article--teaser .article-article__teaser) {
    display: grid;
    gap: clamp(var(--prism-space-md), 3vw, var(--prism-space-xl));
    align-items: start;
    box-sizing: border-box;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    padding: clamp(0.35rem, 1vw, 0.5rem);
    margin: calc(-0.35rem) calc(-0.5rem);
    transition: background-color 0.15s ease;
  }

  @media (min-width: 32rem) {
    .page :global(.article-article--teaser .article-article__teaser) {
      grid-template-columns: minmax(0, 1fr) minmax(11rem, 38%);
    }
  }

  .page :global(.article-article--teaser .article-article__teaser:hover) {
    background-color: color-mix(in srgb, var(--prism-color-accent-strong) 6%, transparent);
  }

  .page :global(.article-article--teaser .article-article__teaser:focus-visible) {
    outline: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    outline-offset: 2px;
  }

  .page :global(.article-article--teaser .article-article__meta) {
    margin: 0 0 0.35rem;
  }

  .page :global(.article-article--teaser .article-article__excerpt) {
    margin: 0.65rem 0 0;
    font-size: var(--docs-fs-md);
    line-height: var(--docs-text-sm-line-height);
    color: var(--prism-color-text-secondary);
    min-height: 0;
  }

  .page :global(.article-article--teaser .article-article__excerpt-text) {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    overflow: hidden;
    overflow: clip;
    contain: paint;
    max-height: calc(3 * 1.55em);
    max-height: calc(3 * 1lh);
  }

  /* Matches home updates cards ( .h-updates-card__author ). */
  .page :global(.article-article--teaser .article-article__author) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0.75rem 0 0;
  }

  .page :global(.article-article--teaser .article-article__author-avatar) {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid color-mix(in srgb, var(--prism-color-border-subtle) 75%, transparent);
  }

  .page :global(.article-article--teaser .article-article__author-avatars) {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .page
    :global(
      .article-article--teaser .article-article__author-avatars .article-article__author-avatar + .article-article__author-avatar
    ) {
    margin-left: -0.5rem;
    box-shadow: 0 0 0 1px var(--prism-color-surface);
  }

  .page :global(.article-article--teaser .article-article__author-name) {
    font-size: var(--docs-fs-2xs);
    font-weight: var(--docs-fw-medium);
    letter-spacing: var(--docs-ls-label);
    line-height: var(--docs-lh-subheading);
    color: var(--docs-text-sm-color);
  }

  :global([data-theme="dark"]) .page :global(.article-article--teaser .article-article__author-name) {
    color: var(--prism-color-text-secondary);
  }

  .page :global(.article-article--teaser .article-article__figure) {
    margin: 0;
  }

  /* —— Article teaser listing: head row + grid/list (matches Foundations overview) —— */
  .page :global(.article-teasers-head-row) {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--prism-space-md) var(--prism-space-xl);
  }

  .page :global(.article-teasers-head-row .intro) {
    flex: 1 1 min(16rem, 100%);
    min-width: 0;
  }

  .page :global(.article-teasers-view-controls.view-segmented) {
    margin: 0;
    padding: 0;
    border: none;
    min-width: 0;
    flex-shrink: 0;
    align-self: flex-start;
    margin-inline-start: auto;
    margin-top: calc(var(--prism-space-xs) * 1.5);
  }

  @media (max-width: 46.875rem) {
    .page :global(.article-teasers-head-row) {
      flex-direction: column;
      align-items: stretch;
      gap: var(--prism-space-md);
    }

    .page :global(.article-teasers-head-row .intro) {
      flex: none;
    }

    /* Same breakpoint as stacked head row: hide grid/list switcher; grid-only (see inline script). */
    .page :global(.article-teasers-view-controls.view-segmented) {
      display: none;
    }
  }

  .page :global(.article-teasers-view-controls .view-segmented__legend) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .page :global(.article-teasers-view-controls .view-segmented__inner) {
    display: inline-flex;
    align-items: stretch;
    box-sizing: border-box;
    height: 2.375rem;
    min-height: 2.375rem;
    padding: 2px;
    gap: 2px;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--prism-color-text-primary) 5%, transparent);
    border: 1px solid var(--prism-color-border-subtle);
  }

  .page :global(.article-teasers-view-controls .view-segmented__input) {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .page :global(.article-teasers-view-controls .view-segmented__label) {
    display: inline-flex;
    align-items: center;
    align-self: stretch;
    gap: 0.35rem;
    padding: 0 1.125rem;
    font-size: var(--docs-fs-xs);
    font-weight: var(--docs-fw-medium);
    letter-spacing: var(--docs-ls-label);
    line-height: var(--docs-lh-tight);
    color: var(--docs-text-md-color);
    border-radius: 9999px;
    cursor: pointer;
    user-select: none;
    transition:
      background-color 0.15s ease,
      color 0.15s ease,
      box-shadow 0.15s ease;
  }

  :global([data-theme="dark"]) .page :global(.article-teasers-view-controls .view-segmented__label) {
    color: var(--prism-color-text-secondary);
  }

  .page :global(.article-teasers-view-controls .view-segmented__input:checked + .view-segmented__label) {
    background: var(--prism-color-text-primary);
    color: var(--prism-color-text-inverse);
    box-shadow: var(--prism-shadow-sm);
  }

  :global([data-theme="dark"])
    .page
    :global(.article-teasers-view-controls .view-segmented__input:checked + .view-segmented__label) {
    background: var(--prism-color-text-inverse);
    color: var(--prism-color-text-primary);
  }

  .page :global(.article-teasers-view-controls .view-segmented__label:hover) {
    color: var(--prism-color-text-primary);
  }

  .page :global(.article-teasers-view-controls .view-segmented__input:checked + .view-segmented__label:hover) {
    color: var(--prism-color-text-inverse);
  }

  :global([data-theme="dark"])
    .page
    :global(.article-teasers-view-controls .view-segmented__input:checked + .view-segmented__label:hover) {
    color: var(--prism-color-text-primary);
  }

  .page :global(.article-teasers-view-controls .view-segmented__input:focus-visible + .view-segmented__label) {
    outline: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    outline-offset: 2px;
  }

  .page :global(.article-teasers-view-controls .view-segmented__icon) {
    flex-shrink: 0;
    opacity: 0.88;
  }

  .page :global(.article-teasers-view-controls .view-segmented__icon--stroke) {
    display: block;
  }

  .page
    :global(.article-teasers-view-controls .view-segmented__input:checked + .view-segmented__label .view-segmented__icon) {
    opacity: 1;
  }

  /*
   * Teaser titles: `data-stagger-title-underline` + BaseLayout script wraps each soft-wrapped line in
   * `.prism-stagger-title-line` so underlines can run one line after the next. Without spans (no JS),
   * `box-decoration-break: clone` keeps a reasonable multi-line fallback.
   */
  #article-teasers-root :global(.article-article--teaser .article-article__title) {
    --prism-stagger-title-segment: 0.38s;
  }

  #article-teasers-root :global(.article-article--teaser .article-article__title:not(:has(.prism-stagger-title-line))) {
    display: inline;
    max-width: 100%;
    -webkit-box-decoration-break: clone;
    box-decoration-break: clone;
    padding-bottom: 0.1em;
    box-sizing: border-box;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 2px;
    transition:
      color 0.32s ease,
      background-size var(--prism-stagger-title-segment) cubic-bezier(0.22, 1, 0.36, 1);
  }

  #article-teasers-root
    :global(.article-article--teaser .article-article__teaser:hover .article-article__title:not(:has(.prism-stagger-title-line))),
  #article-teasers-root
    :global(
      .article-article--teaser .article-article__teaser:focus-visible .article-article__title:not(:has(.prism-stagger-title-line))
    ) {
    background-size: 100% 2px;
  }

  /* Column flex + flex-start: per-line spans use fit-content so gradient “underline” matches text width. */
  #article-teasers-root :global(.article-article--teaser .article-article__title:has(.prism-stagger-title-line)) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    background: none;
    padding-bottom: 0;
  }

  #article-teasers-root :global(.article-article--teaser .article-article__title .prism-stagger-title-line) {
    display: inline-block;
    flex-shrink: 0;
    align-self: flex-start;
    width: auto;
    max-width: 100%;
    padding-bottom: 0.1em;
    box-sizing: border-box;
    color: inherit;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 2px;
    transition:
      color 0.32s ease,
      background-size var(--prism-stagger-title-segment) cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay:
      0s,
      calc(
        (var(--prism-stagger-title-line-count, 1) - 1 - var(--prism-stagger-title-line-i, 0)) *
          var(--prism-stagger-title-segment)
      );
  }

  #article-teasers-root
    :global(.article-article--teaser .article-article__teaser:hover .article-article__title .prism-stagger-title-line),
  #article-teasers-root
    :global(
      .article-article--teaser .article-article__teaser:focus-visible .article-article__title .prism-stagger-title-line
    ) {
    color: var(--prism-color-accent-strong);
    background-size: 100% 2px;
    transition-delay: 0s, calc(var(--prism-stagger-title-line-i, 0) * var(--prism-stagger-title-segment));
  }

  :global([data-theme="dark"])
    #article-teasers-root:has(#article-teasers-view-grid:checked)
    :global(.article-article--teaser .article-article__teaser:hover .article-article__title .prism-stagger-title-line),
  :global([data-theme="dark"])
    #article-teasers-root:has(#article-teasers-view-grid:checked)
    :global(
      .article-article--teaser .article-article__teaser:focus-visible .article-article__title .prism-stagger-title-line
    ) {
    color: var(--prism-color-accent);
  }

  /* Grid: multi-column cards (image on top) */
  #article-teasers-root:has(#article-teasers-view-grid:checked) :global(.article-posts--teasers) {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--prism-space-xl);
    align-items: start;
  }

  @media (min-width: 48rem) {
    #article-teasers-root:has(#article-teasers-view-grid:checked) :global(.article-posts--teasers) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64rem) {
    #article-teasers-root:has(#article-teasers-view-grid:checked) :global(.article-posts--teasers) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  #article-teasers-root:has(#article-teasers-view-grid:checked) :global(.article-article--teaser) {
    border-top: none;
    padding: 0;
  }

  #article-teasers-root:has(#article-teasers-view-grid:checked) :global(.article-article--first) {
    padding-top: 0;
  }

  #article-teasers-root:has(#article-teasers-view-grid:checked) :global(.article-article--teaser .article-article__teaser) {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--prism-space-lg);
    margin: 0;
    padding: 0;
    height: 100%;
  }

  #article-teasers-root:has(#article-teasers-view-grid:checked) :global(.article-article--teaser .article-article__teaser:hover),
  #article-teasers-root:has(#article-teasers-view-grid:checked) :global(.article-article--teaser .article-article__teaser:focus-visible) {
    background-color: transparent;
  }

  /* Grid: image on top — 16:9 frame (same ratio as 384×216 / home updates) + dim overlay on hover. */
  #article-teasers-root:has(#article-teasers-view-grid:checked) :global(.article-article--teaser .article-article__figure) {
    order: -1;
    position: relative;
    width: 100%;
    margin: 0;
    aspect-ratio: 16 / 9;
  }

  #article-teasers-root:has(#article-teasers-view-grid:checked) :global(.article-article--teaser .article-article__figure)::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background: color-mix(in srgb, var(--prism-color-text-primary) 8%, transparent);
    opacity: 0;
    transition: opacity 0.18s ease;
    pointer-events: none;
  }

  #article-teasers-root:has(#article-teasers-view-grid:checked)
    :global(.article-article--teaser .article-article__teaser:hover .article-article__figure)::after,
  #article-teasers-root:has(#article-teasers-view-grid:checked)
    :global(.article-article--teaser .article-article__teaser:focus-visible .article-article__figure)::after {
    opacity: 1;
  }

  #article-teasers-root:has(#article-teasers-view-grid:checked)
    :global(.article-article--teaser .article-article__figure .article-article__img) {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Grid: teaser title matches home updates cards ( .h-updates-card__title ). */

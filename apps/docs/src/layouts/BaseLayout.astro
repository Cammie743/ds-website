<style>
  /* Shared: drawer nav + Get started sidebar — semi-transparent fill (tuned for legibility on canvas) */
  html {
    --nav-drawer-item-active-bg: color-mix(in srgb, var(--prism-color-border-subtle) 44%, transparent);
  }

  html[data-ui-lang="zh"] {
    font-family: "Noto Sans SC", var(--prism-font-sans), "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei",
      sans-serif;
  }

  body.site {
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    gap: 0;
  }

  :root {
    /* Gap between tooltip bubble and trigger (below-trigger: top 100% + gap; above-trigger: bottom 100% + gap) */
    --docs-tooltip-gap: 11px;
    --site-header-sticky-anchor: 72px;
    --site-header-pill-top-gap: 1rem;
    --site-header-pill-inset: max(1rem, min(5vw, 5rem));
    --site-page-pad-x: 24px;

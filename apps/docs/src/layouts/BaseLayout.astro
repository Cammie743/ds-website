---
import "../styles/global.css";
import "../styles/doc-h2-anchor.css";
import { uiStrings } from "../i18n/ui";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Prism is the design system for product experiences." } = Astro.props;
const fullTitle = title === "Prism" ? title : `${title} · Prism`;

const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";

function isNavActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  if (href === "/get-started") return pathname.startsWith("/get-started");
  if (href === "/foundations") return pathname.startsWith("/foundations");
  if (href === "/components") return pathname.startsWith("/components");
  if (href === "/resources") return pathname.startsWith("/resources");
  if (href === "/blog") return pathname.startsWith("/blog");
  return false;
}

function pathNorm(p: string): string {
  return p.replace(/\/+$/, "") || "/";
}

const normPath = pathNorm(pathname);

const componentsAvatarsDrawerOpen =
  normPath === "/components/avatars" || normPath.startsWith("/components/avatars/");

const pageShell = normPath === "/" ? "home" : "inner";
---

<!doctype html>
<html lang="en" data-page={pageShell}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
    <script is:inline>
      (function () {
        var allowed = { dark: 1, bloom: 1, agave: 1, rose: 1 };
        var t = localStorage.getItem("prism-theme");
        if (t && !allowed[t] && t !== "light") {
          try {
            localStorage.removeItem("prism-theme");
          } catch (e) {}
          t = null;
        }
        if (t && allowed[t]) document.documentElement.setAttribute("data-theme", t);
        else document.documentElement.removeAttribute("data-theme");
      })();
    </script>
  </head>
  <body class="site">
    <div class="prism-bg" aria-hidden="true"></div>
    <header class="top">
        <a class="brand" href="/"><span class="brand-name">Prism</span></a>
        <div class="nav-drawer-backdrop" id="nav-drawer-backdrop" aria-hidden="true"></div>
        <nav class="nav" id="site-nav" aria-label="Primary">
          <div class="nav-drawer-header" id="nav-drawer-header" aria-hidden="true">
            <button
              type="button"
              class="nav-drawer-parent"
              id="nav-drawer-back"
              hidden
              aria-label="Back"
              data-i18n-aria="nav.back"
            >
              <span class="nav-drawer-parent-chevron" aria-hidden="true">
                <svg
                  class="nav-drawer-parent-chevron-svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M19 12H5M12 5l-7 7 7 7"></path>
                </svg>
              </span>
              <span class="nav-drawer-section-title" id="nav-drawer-section-title"></span>
            </button>
          </div>
          <div class="nav-drawer-viewport" id="nav-drawer-viewport">
            <div class="nav-drawer-track" id="nav-drawer-track">
              <div class="nav-drawer-panel nav-drawer-panel--root" id="nav-drawer-panel-root">
                <a
                  class="nav-link--drawer"
                  href="/"
                  aria-current={isNavActive("/") ? "page" : undefined}
                  data-i18n="nav.home">Home</a>
                <a
                  class="nav-link--has-nested"
                  href="/get-started/overview"
                  data-nav-drill="get-started"
                  data-nav-drill-route-prefix="/get-started"
                  aria-current={isNavActive("/get-started") ? "page" : undefined}
                >
                  <span data-i18n="nav.getStarted">Get started</span>
                  <span class="nav-link-chevron" aria-hidden="true">
                    <svg
                      class="nav-link-chevron-svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="m9 18 6-6-6-6"></path>
                    </svg>
                  </span>
                </a>
                <a
                  class="nav-link--has-nested"
                  href="/foundations/overview"
                  data-nav-drill="foundations"
                  data-nav-drill-route-prefix="/foundations"
                  aria-current={isNavActive("/foundations") ? "page" : undefined}
                >
                  <span data-i18n="nav.foundations">Foundations</span>
                  <span class="nav-link-chevron" aria-hidden="true">
                    <svg
                      class="nav-link-chevron-svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="m9 18 6-6-6-6"></path>
                    </svg>
                  </span>
                </a>
                <a
                  class="nav-link--has-nested"
                  href="/components/overview"
                  data-nav-drill="components"
                  data-nav-drill-route-prefix="/components"
                  aria-current={isNavActive("/components") ? "page" : undefined}
                >
                  <span data-i18n="nav.components">Components</span>
                  <span class="nav-link-chevron" aria-hidden="true">
                    <svg
                      class="nav-link-chevron-svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="m9 18 6-6-6-6"></path>
                    </svg>
                  </span>
                </a>
                <a
                  class="nav-link--has-nested"
                  href="/resources/overview"
                  data-nav-drill="resources"
                  data-nav-drill-route-prefix="/resources"
                  aria-current={isNavActive("/resources") ? "page" : undefined}
                >
                  <span data-i18n="nav.resources">Resources</span>
                  <span class="nav-link-chevron" aria-hidden="true">
                    <svg
                      class="nav-link-chevron-svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="m9 18 6-6-6-6"></path>
                    </svg>
                  </span>
                </a>
                <a
                  class="nav-link--has-nested"
                  href="/blog/featured"
                  data-nav-drill="blog"
                  data-nav-drill-route-prefix="/blog"
                  aria-current={isNavActive("/blog") ? "page" : undefined}
                >
                  <span data-i18n="nav.blog">Blog</span>
                  <span class="nav-link-chevron" aria-hidden="true">
                    <svg
                      class="nav-link-chevron-svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="m9 18 6-6-6-6"></path>
                    </svg>
                  </span>
                </a>
              </div>
              <div class="nav-drawer-panel nav-drawer-panel--sub" id="nav-drawer-panel-sub" aria-hidden="true" role="group">
                <ul
                  id="nav-drawer-sub-get-started"
                  class="nav-drawer-subnav-list"
                  data-i18n-aria="getStarted.sectionNav.aria"
                  aria-label="Get started pages"
                >
                  <li>
                    <a
                      href="/get-started/overview"
                      aria-current={normPath === "/get-started/overview" ? "page" : undefined}
                      data-i18n="getStarted.toc.overview">Overview</a>
                  </li>
                  <li>
                    <a
                      href="/get-started/mission"
                      aria-current={normPath === "/get-started/mission" ? "page" : undefined}
                      data-i18n="getStarted.toc.mission">Mission</a>
                  </li>
                  <li>
                    <a
                      href="/get-started/principles"
                      aria-current={normPath === "/get-started/principles" ? "page" : undefined}
                      data-i18n="getStarted.toc.principles">Design principles</a>
                  </li>
                  <li>
                    <a
                      href="/get-started/language"
                      aria-current={normPath === "/get-started/language" ? "page" : undefined}
                      data-i18n="getStarted.toc.language">Design language</a>
                  </li>
                  <li>
                    <a
                      href="/get-started/faq"
                      aria-current={normPath === "/get-started/faq" ? "page" : undefined}
                      data-i18n="getStarted.toc.faq">FAQs</a>
                  </li>
                </ul>
                <ul
                  id="nav-drawer-sub-foundations"
                  class="nav-drawer-subnav-list"
                  hidden
                  data-i18n-aria="foundations.sectionNav.aria"
                  aria-label="Foundations pages"
                >
                  <li>
                    <a
                      href="/foundations/overview"
                      aria-current={normPath === "/foundations/overview" ? "page" : undefined}
                      data-i18n="foundations.toc.overview">Overview</a>
                  </li>
                  <li>
                    <a
                      href="/foundations/color"
                      aria-current={
                        normPath === "/foundations/color" || normPath === "/foundations/colors"
                          ? "page"
                          : undefined
                      }
                      data-i18n="foundations.toc.color">Color</a>
                  </li>
                  <li>
                    <a
                      href="/foundations/typography"
                      aria-current={normPath === "/foundations/typography" ? "page" : undefined}
                      data-i18n="foundations.toc.typography">Typography</a>
                  </li>
                  <li>
                    <a
                      href="/foundations/iconography"
                      aria-current={normPath === "/foundations/iconography" ? "page" : undefined}
                      data-i18n="foundations.toc.iconography">Iconography</a>
                  </li>
                  <li>
                    <a
                      href="/foundations/space"
                      aria-current={normPath === "/foundations/space" ? "page" : undefined}
                      data-i18n="foundations.toc.space">Space</a>
                  </li>
                  <li>
                    <a
                      href="/foundations/size"
                      aria-current={normPath === "/foundations/size" ? "page" : undefined}
                      data-i18n="foundations.toc.size">Size</a>
                  </li>
                  <li>
                    <a
                      href="/foundations/effects"
                      aria-current={normPath === "/foundations/effects" ? "page" : undefined}
                      data-i18n="foundations.toc.effects">Effects</a>
                  </li>
                  <li>
                    <a
                      href="/foundations/motion"
                      aria-current={normPath === "/foundations/motion" ? "page" : undefined}
                      data-i18n="foundations.toc.motion">Motion</a>
                  </li>
                  <li>
                    <a
                      href="/foundations/gestures"
                      aria-current={normPath === "/foundations/gestures" ? "page" : undefined}
                      data-i18n="foundations.toc.gestures">Gestures</a>
                  </li>
                  <li>
                    <a
                      href="/foundations/haptics-sounds"
                      aria-current={normPath === "/foundations/haptics-sounds" ? "page" : undefined}
                      data-i18n="foundations.toc.hapticsSounds">Haptics & sounds</a>
                  </li>
                </ul>
                <ul
                  id="nav-drawer-sub-components"
                  class="nav-drawer-subnav-list"
                  hidden
                  data-i18n-aria="components.sectionNav.aria"
                  aria-label="Components pages"
                >
                  <li>
                    <a
                      href="/components/overview"
                      aria-current={normPath === "/components/overview" ? "page" : undefined}
                      data-i18n="components.toc.overview">Overview</a>
                  </li>
                  <li>
                    <a
                      href="/components/accordion"
                      aria-current={normPath === "/components/accordion" ? "page" : undefined}
                      data-i18n="components.toc.accordion">Accordion</a>
                  </li>
                  <li>
                    <a
                      href="/components/anchor"
                      aria-current={normPath === "/components/anchor" ? "page" : undefined}
                      data-i18n="components.toc.anchor">Anchor</a>
                  </li>
                  <li class="nav-drawer-subnav-item--disclosure">
                    <details class="nav-drawer-subnav-details" open={componentsAvatarsDrawerOpen}>
                      <summary class="nav-drawer-subnav-details-summary">
                        <span class="nav-drawer-subnav-details-inner">
                          <a
                            href="/components/avatars"
                            aria-current={normPath === "/components/avatars" ? "page" : undefined}
                            data-i18n="components.toc.avatars">Avatars</a>
                          <span class="nav-drawer-subnav-details-chevron" aria-hidden="true">
                            <svg
                              class="nav-drawer-subnav-details-chevron-svg"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            >
                              <path d="m9 18 6-6-6-6"></path>
                            </svg>
                          </span>
                        </span>
                      </summary>
                      <ul class="nav-drawer-subnav-details-list">
                        <li class="nav-drawer-subnav-nested">
                          <a
                            href="/components/avatars/avatar"
                            aria-current={normPath === "/components/avatars/avatar" ? "page" : undefined}
                            data-i18n="components.toc.avatar">Avatar</a>
                        </li>
                        <li class="nav-drawer-subnav-nested">
                          <a
                            href="/components/avatars/avatar-group"
                            aria-current={normPath === "/components/avatars/avatar-group" ? "page" : undefined}
                            data-i18n="components.toc.avatarGroup">Avatar group</a>
                        </li>
                      </ul>
                    </details>
                  </li>
                  <li>
                    <a
                      href="/components/buttons"
                      aria-current={normPath === "/components/buttons" ? "page" : undefined}
                      data-i18n="components.toc.buttons">Buttons</a>
                  </li>
                  <li>
                    <a
                      href="/components/dialog"
                      aria-current={normPath === "/components/dialog" ? "page" : undefined}
                      data-i18n="components.toc.dialog">Dialog</a>
                  </li>
                  <li>
                    <a
                      href="/components/input-fields"
                      aria-current={normPath === "/components/input-fields" ? "page" : undefined}
                      data-i18n="components.toc.inputFields">Input fields</a>
                  </li>
                </ul>
                <ul
                  id="nav-drawer-sub-resources"
                  class="nav-drawer-subnav-list"
                  hidden
                  data-i18n-aria="resources.sectionNav.aria"
                  aria-label="Resources pages"
                >
                  <li>
                    <a
                      href="/resources/overview"
                      aria-current={normPath === "/resources/overview" ? "page" : undefined}
                      data-i18n="resources.toc.overview">Overview</a>
                  </li>
                  <li>
                    <a
                      href="/resources/ai-skills"
                      aria-current={normPath === "/resources/ai-skills" ? "page" : undefined}
                      data-i18n="resources.toc.aiSkills">AI skills</a>
                  </li>
                  <li>
                    <a
                      href="/resources/figma"
                      aria-current={normPath === "/resources/figma" ? "page" : undefined}
                      data-i18n="resources.toc.figma">Figma</a>
                  </li>
                  <li>
                    <a
                      href="/resources/development"
                      aria-current={normPath === "/resources/development" ? "page" : undefined}
                      data-i18n="resources.toc.development">Development</a>
                  </li>
                  <li>
                    <a
                      href="/resources/learning-videos"
                      aria-current={normPath === "/resources/learning-videos" ? "page" : undefined}
                      data-i18n="resources.toc.learningVideos">Learning videos</a>
                  </li>
                  <li>
                    <a
                      href="/resources/fonts"
                      aria-current={normPath === "/resources/fonts" ? "page" : undefined}
                      data-i18n="resources.toc.fonts">Fonts</a>
                  </li>
                  <li>
                    <a
                      href="/resources/templates"
                      aria-current={normPath === "/resources/templates" ? "page" : undefined}
                      data-i18n="resources.toc.templates">Templates</a>
                  </li>
                </ul>
                <ul
                  id="nav-drawer-sub-blog"
                  class="nav-drawer-subnav-list"
                  hidden
                  data-i18n-aria="blog.sectionNav.aria"
                  aria-label="Blog sections"
                >
                  <li>
                    <a
                      href="/blog/featured"
                      aria-current={normPath === "/blog/featured" ? "page" : undefined}
                      data-i18n="blog.nav.featured">Featured</a>
                  </li>
                  <li>
                    <a
                      href="/blog/latest"
                      aria-current={normPath === "/blog/latest" ? "page" : undefined}
                      data-i18n="blog.nav.latest">Latest updates</a>
                  </li>
                  <li>
                    <a
                      href="/blog/2026"
                      aria-current={normPath === "/blog/2026" ? "page" : undefined}
                      data-i18n="blog.nav.y2026">2026</a>
                  </li>
                  <li>
                    <a
                      href="/blog/2025"
                      aria-current={normPath === "/blog/2025" ? "page" : undefined}
                      data-i18n="blog.nav.y2025">2025</a>
                  </li>
                </ul>
              </div>
            </div>
          </div>
          <button
            type="button"
            class="icon-btn nav-drawer-close"
            id="nav-drawer-close"
            aria-label="Close menu"
            data-tooltip="Close menu"
          >
            <span class="icon nav-toggle-bars nav-toggle-bars--x" aria-hidden="true">
              <span class="nav-toggle-bar"></span>
              <span class="nav-toggle-bar"></span>
              <span class="nav-toggle-bar"></span>
            </span>
          </button>
        </nav>
        <div class="top-tools">
          <div class="search-wrap" id="search-wrap">
            <button
              type="button"
              class="icon-btn"
              id="search-toggle"
              aria-expanded="false"
              aria-controls="search-drawer"
              aria-haspopup="dialog"
              aria-label="Open search"
              data-tooltip="Open search (Ctrl+K)"
            >
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="7"></circle>
                <path d="M20 20l-4.35-4.35" stroke-linecap="round"></path>
              </svg>
            </button>
          </div>
          <div class="top-tools-drawer-util" id="top-tools-drawer-util" role="group" aria-label="Language and theme">
            <button type="button" class="icon-btn" id="lang-toggle" aria-label="Language: English" data-tooltip="Translate">
              <svg
                class="icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m5 8 6 6"></path>
                <path d="m4 14 6-6 2-3"></path>
                <path d="M2 5h12"></path>
                <path d="M7 2h1"></path>
                <path d="m22 22-5-10-5 10"></path>
                <path d="M14 18h6"></path>
              </svg>
            </button>
            <div class="theme-select-wrap">
              <label class="theme-select-label">
                <span class="theme-select-label-text" data-i18n="theme.aria">Color theme</span>
                <select id="theme-select" class="theme-select" autocomplete="off">
                  <option value="light" data-i18n="theme.light">Light</option>
                  <option value="dark" data-i18n="theme.dark">Dark</option>
                  <option value="bloom" data-i18n="theme.bloom">Bloom</option>
                  <option value="agave" data-i18n="theme.agave">Agave</option>
                  <option value="rose" data-i18n="theme.rose">Rose</option>
                </select>
              </label>
            </div>
          </div>
        </div>
        <button
          type="button"
          class="nav-toggle"
          id="nav-toggle"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label="Open menu"
          data-tooltip="Open menu"
        >
          <span class="nav-toggle-icons" aria-hidden="true">
            <span class="nav-toggle-bars">
              <span class="nav-toggle-bar"></span>
              <span class="nav-toggle-bar"></span>
              <span class="nav-toggle-bar"></span>
            </span>
          </span>
        </button>
    </header>
    <div class="search-drawer-backdrop" id="search-drawer-backdrop" aria-hidden="true"></div>
    <div
      class="search-drawer"
      id="search-drawer"
      role="dialog"
      aria-modal="true"
      aria-labelledby="search-drawer-title"
      aria-hidden="true"
    >
      <div class="search-drawer-inner">
        <span class="search-drawer-title" id="search-drawer-title" data-i18n="search.drawerTitle">Search</span>
        <div class="search-drawer-field-wrap">
          <div class="site-search-field">
            <span class="site-search-icon" aria-hidden="true">
              <svg class="site-search-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="7"></circle>
                <path d="M20 20l-4.35-4.35" stroke-linecap="round"></path>
              </svg>
            </span>
            <input
              class="site-search"
              type="text"
              role="searchbox"
              inputmode="search"
              id="site-search"
              name="q"
              placeholder="Search Prism"
              data-i18n-placeholder="search.placeholder"
              autocomplete="off"
              aria-label="Search documentation"
              data-i18n-aria="search.ariaStatic"
            />
            <button
              type="button"
              class="search-clear"
              id="search-clear"
              aria-hidden="true"
              aria-label="Clear search"
              data-i18n-aria="search.clear"
              data-tooltip="Clear search"
            >
              <svg class="search-clear-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M18 6 6 18M6 6l12 12" stroke-linecap="round"></path>
              </svg>
            </button>
          </div>
        </div>
        <button
          type="button"
          class="icon-btn search-drawer-close"
          id="search-drawer-close"
          aria-label="Close search"
          data-tooltip="Close search"
        >
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M18 6 6 18M6 6l12 12" stroke-linecap="round"></path>
          </svg>
        </button>
      </div>
    </div>
    <main class="main">
      <slot />
    </main>
    <footer class="foot">
      <p data-i18n="footer.tagline">Prism · Design system documentation.</p>
    </footer>
    <script define:vars={{ uiStrings }}>
      (function () {
        var root = document.documentElement;
        var locales = ["en", "zh"];
        function getLang() {
          return root.dataset.uiLang === "zh" ? "zh" : "en";
        }
        function t(key) {
          var lang = getLang();
          var row = uiStrings[lang];
          if (row && key in row) return row[key];
          return uiStrings.en[key] || key;
        }
        function isMacOSClient() {
          if (typeof navigator === "undefined") return false;
          var ua = navigator.userAgent || "";
          var p = navigator.platform || "";
          if (/Macintosh|Mac OS X|MacIntel|iPhone|iPad|iPod/i.test(ua)) return true;
          if (/^Mac/i.test(p)) return true;
          return false;
        }
        function searchOpenTooltipKey() {
          return isMacOSClient() ? "search.openTooltipMac" : "search.openTooltipWin";
        }
        function applyTranslations() {
          var lang = getLang();
          root.lang = lang === "zh" ? "zh-Hans" : "en";
          document.querySelectorAll("[data-i18n]").forEach(function (el) {
            var key = el.getAttribute("data-i18n");
            if (!key) return;
            el.textContent = t(key);
          });
          document.querySelectorAll("[data-i18n-placeholder]").forEach(function (el) {
            var key = el.getAttribute("data-i18n-placeholder");
            if (!key || !("placeholder" in el)) return;
            el.placeholder = t(key);
          });
          document.querySelectorAll("[data-i18n-aria]").forEach(function (el) {

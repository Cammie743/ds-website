---
import BaseLayout from "./BaseLayout.astro";

export type GetStartedSection = "mission" | "principles" | "language" | "faq";

/** Current page in the Get started section nav (includes top-level Overview). */
export type GetStartedNavCurrent = "overview" | GetStartedSection;

interface Props {
  title: string;
  description?: string;
  current: GetStartedNavCurrent;
}

const { title, description = "Mission, design principles, design language, and FAQs for Prism.", current } = Astro.props;

const navItems: { id: GetStartedNavCurrent; href: string; i18n: string; fallback: string }[] = [
  { id: "overview", href: "/get-started/overview", i18n: "getStarted.toc.overview", fallback: "Overview" },
  { id: "mission", href: "/get-started/mission", i18n: "getStarted.toc.mission", fallback: "Mission" },
  {
    id: "principles",
    href: "/get-started/principles",
    i18n: "getStarted.toc.principles",
    fallback: "Design principles",
  },
  {
    id: "language",
    href: "/get-started/language",
    i18n: "getStarted.toc.language",
    fallback: "Design language",
  },
  { id: "faq", href: "/get-started/faq", i18n: "getStarted.toc.faq", fallback: "FAQs" },
];
---

<BaseLayout title={title} description={description}>
  <div class="get-started-layout">
    <nav class="section-nav section-nav--page" data-i18n-aria="getStarted.sectionNav.aria" aria-label="Get started pages">
      <ul class="section-nav-list">
        {
          navItems.map((item) => (
            <li>
              <a
                class:list={["section-nav-link", { "is-current": current === item.id }]}
                href={item.href}
                aria-current={current === item.id ? "page" : undefined}
                data-i18n={item.i18n}
              >
                {item.fallback}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <article class="page">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .get-started-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--prism-space-xl);
    width: 100%;
    max-width: none;
    align-items: start;
  }

  .section-nav {
    width: 100%;
    min-width: 0;
  }

  @media (max-width: 55.99rem) {
    .section-nav--page {
      display: none;
    }
  }

  @media (min-width: 56rem) {
    .get-started-layout {
      grid-template-columns: 12.5rem minmax(0, 48rem);
      column-gap: clamp(var(--prism-space-xl), 4vw, var(--prism-space-3xl));
    }

    .section-nav {
      position: sticky;
      top: calc(var(--site-header-sticky-anchor, 72px) + var(--prism-space-md));
      max-height: calc(100vh - var(--site-header-sticky-anchor, 72px) - var(--prism-space-xl));
      overflow-y: auto;
      padding-top: calc(var(--docs-page-content-padding-top) + var(--prism-space-sm) + 4px);
      padding-bottom: calc(var(--prism-space-md) + 4px);
      padding-inline: 6px;
    }
  }

  .section-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    gap: var(--prism-space-xs);
  }

  .section-nav-list li {
    margin: 0;
    width: 100%;
    min-width: 0;
  }

  .section-nav-link {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: var(--prism-space-md) var(--prism-space-lg);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.4;
    text-decoration: none;
    color: var(--prism-color-text-primary);
    border-radius: 12px;
    background-color: transparent;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .section-nav-link.is-current {
    background-color: var(--nav-drawer-item-active-bg);
  }

  .section-nav-link:hover,
  .section-nav-link:focus-visible {
    background-color: var(--nav-drawer-item-active-bg);
    color: var(--prism-color-accent-strong);
  }

  .section-nav-link:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    outline-offset: 2px;
  }

  .page {
    width: 100%;
    max-width: 48rem;
    min-width: 0;
    padding-top: var(--docs-page-content-padding-top);
    padding-bottom: var(--prism-space-3xl);
  }

  .page :global(.page-head) {
    margin-bottom: var(--prism-space-xl);
  }

  /* Slotted page markup lives in child .astro files, so scoped selectors need :global() (matches Foundations). */
  .page :global(h1) {
    margin: 0 0 var(--prism-space-md);
    font-size: clamp(3rem, 8.5vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
  }

  .page :global(.intro) {
    margin: 0;
    color: var(--prism-color-text-secondary);
    line-height: 1.65;
    font-size: 1.0625rem;
  }

  .page :global(.block) {
    margin-bottom: var(--prism-space-3xl);
  }

  .page :global(.block h2) {
    margin: 0 0 var(--prism-space-md);
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .page :global(.prose) {
    margin: 0 0 var(--prism-space-md);
    color: var(--prism-color-text-secondary);
    line-height: 1.65;
  }

  .page :global(.prose:last-child) {
    margin-bottom: 0;
  }

  .page :global(.lead) {
    font-size: 1rem;
  }

  .page :global(.principles) {
    margin: var(--prism-space-lg) 0 0;
    padding: 0;
    list-style: none;
    counter-reset: principle;
    display: flex;
    flex-direction: column;
    gap: var(--prism-space-xl);
  }

  .page :global(.principles li) {
    counter-increment: principle;
    padding-left: var(--prism-space-2xl);
    position: relative;
  }

  .page :global(.principles li::before) {
    content: counter(principle);
    position: absolute;
    left: 0;
    top: 0.1rem;
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 700;
    border-radius: var(--prism-radius-sm);
    background: color-mix(in srgb, var(--prism-color-accent) 18%, transparent);
    color: var(--prism-color-text-primary);
  }

  .page :global(.principles h3) {
    margin: 0 0 var(--prism-space-sm);
    font-size: 1.0625rem;
    font-weight: 600;
  }

  .page :global(.principles p) {
    margin: 0;
    color: var(--prism-color-text-secondary);
    line-height: 1.65;
    font-size: 0.9375rem;
  }

  .page :global(.lang-grid) {
    margin-top: var(--prism-space-lg);
    display: grid;
    gap: var(--prism-space-md);
    grid-template-columns: 1fr;
  }

  @media (min-width: 40rem) {
    .page :global(.lang-grid) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .page :global(.lang-card) {
    padding: var(--prism-space-lg);
    border-radius: var(--prism-radius-md);
    border: 1px solid var(--prism-color-border-subtle);
    background: color-mix(in srgb, var(--prism-color-surface) 88%, transparent);
    box-shadow: var(--prism-shadow-sm);
  }

  .page :global(.lang-card h2),
  .page :global(.lang-card h3) {
    margin: 0 0 var(--prism-space-sm);
    font-size: 1rem;
    font-weight: 600;
  }

  .page :global(.lang-card p) {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--prism-color-text-secondary);
  }

  .page :global(.faq-list) {
    margin-top: var(--prism-space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--prism-space-sm);
  }

  .page :global(.faq-item) {
    border-radius: var(--prism-radius-md);
    border: 1px solid var(--prism-color-border-subtle);
    background: var(--prism-color-surface);
    box-shadow: var(--prism-shadow-sm);
    padding: 0 var(--prism-space-md);
  }

  .page :global(.faq-item summary) {
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9375rem;
    padding: var(--prism-space-md) 0;
    list-style: none;
  }

  .page :global(.faq-item summary::-webkit-details-marker) {
    display: none;
  }

  .page :global(.faq-item summary::after) {
    content: "";
    float: right;
    width: 0.5rem;
    height: 0.5rem;
    margin-top: 0.35rem;
    border-right: 2px solid var(--prism-color-text-secondary);
    border-bottom: 2px solid var(--prism-color-text-secondary);
    transform: rotate(45deg);
    transition: transform 0.15s ease;
  }

  .page :global(.faq-item[open] summary::after) {
    transform: rotate(-135deg);
    margin-top: 0.55rem;
  }

  .page :global(.faq-item p) {
    margin: 0 0 var(--prism-space-md);
    padding-top: 0;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--prism-color-text-secondary);
  }

  .page :global(.next) {
    margin: var(--prism-space-2xl) 0 0;
    padding-top: var(--prism-space-xl);
    border-top: 1px solid var(--prism-color-border-subtle);
  }

  .page :global(.next-link) {
    font-weight: 600;
    text-decoration: none;
    color: var(--prism-color-accent-strong);
  }

  .page :global(.next-link:hover) {
    text-decoration: underline;
  }
</style>

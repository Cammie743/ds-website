---
import BaseLayout from "./BaseLayout.astro";

export type BlogNavCurrent = "featured" | "latest" | "y2026" | "y2025";

interface Props {
  title: string;
  description?: string;
  current: BlogNavCurrent;
}

const { title, description = "Updates and articles from the Prism team.", current } = Astro.props;

const navItems: { id: BlogNavCurrent; href: string; i18n: string; fallback: string }[] = [
  { id: "featured", href: "/blog/featured", i18n: "blog.nav.featured", fallback: "Featured" },
  { id: "latest", href: "/blog/latest", i18n: "blog.nav.latest", fallback: "Latest updates" },
  { id: "y2026", href: "/blog/2026", i18n: "blog.nav.y2026", fallback: "2026" },
  { id: "y2025", href: "/blog/2025", i18n: "blog.nav.y2025", fallback: "2025" },
];
---

<BaseLayout title={title} description={description}>
  <div class="blog-layout">
    <nav class="section-nav section-nav--page" data-i18n-aria="blog.sectionNav.aria" aria-label="Blog sections">
      <ul class="section-nav-list">
        {
          navItems.map((item) => (
            <li>
              <a
                class:list={["section-nav-link", { "is-current": current === item.id }]}
                href={item.href}
                aria-current={current === item.id ? "page" : undefined}
                data-i18n={item.i18n}
              >
                {item.fallback}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <article class="page">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .blog-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--prism-space-xl);
    width: 100%;
    max-width: none;
    align-items: start;
  }

  .section-nav {
    width: 100%;
    min-width: 0;
  }

  @media (max-width: 55.99rem) {
    .section-nav--page {
      display: none;
    }
  }

  @media (min-width: 56rem) {
    .blog-layout {
      grid-template-columns: 12.5rem minmax(0, 48rem);
      column-gap: clamp(var(--prism-space-xl), 4vw, var(--prism-space-3xl));
    }

    .section-nav {
      position: sticky;
      top: calc(var(--site-header-sticky-anchor, 72px) + var(--prism-space-md));
      max-height: calc(100vh - var(--site-header-sticky-anchor, 72px) - var(--prism-space-xl));
      overflow-y: auto;
      padding-top: calc(var(--docs-page-content-padding-top) + var(--prism-space-sm) + 4px);
      padding-bottom: calc(var(--prism-space-md) + 4px);
      padding-inline: 6px;
    }
  }

  .section-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    gap: var(--prism-space-xs);
  }

  .section-nav-list li {
    margin: 0;
    width: 100%;
    min-width: 0;
  }

  .section-nav-link {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: var(--prism-space-md) var(--prism-space-lg);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.4;
    text-decoration: none;
    color: var(--prism-color-text-primary);
    border-radius: 12px;
    background-color: transparent;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .section-nav-link.is-current {
    background-color: var(--nav-drawer-item-active-bg);
  }

  .section-nav-link:hover,
  .section-nav-link:focus-visible {
    background-color: var(--nav-drawer-item-active-bg);
    color: var(--prism-color-accent-strong);
  }

  .section-nav-link:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    outline-offset: 2px;
  }

  .page {
    width: 100%;
    max-width: 40rem;
    min-width: 0;
    padding-top: var(--docs-page-content-padding-top);
    padding-bottom: var(--prism-space-3xl);
  }

  .page :global(.page-head) {
    margin-bottom: var(--prism-space-xl);
  }

  .page :global(h1) {
    margin: 0 0 var(--prism-space-md);
    font-size: clamp(3rem, 8.5vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
  }

  .page :global(.intro) {
    margin: 0;
    color: var(--prism-color-text-secondary);
    line-height: 1.65;
    font-size: 1.0625rem;
  }

  .page :global(.blog-posts) {
    padding: 0 0 2rem;
  }

  .page :global(.blog-article) {
    scroll-margin-top: calc(var(--docs-page-content-padding-top, 2rem) + 1rem);
    padding: clamp(2rem, 5vw, 2.75rem) 0;
    border-top: 1px solid color-mix(in srgb, var(--prism-color-border-subtle) 80%, transparent);
  }

  .page :global(.blog-article--first) {
    border-top: none;
    padding-top: 0.5rem;
  }

  .page :global(.blog-article__meta) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    margin: 0 0 0.65rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--prism-color-text-secondary);
  }

  /* Matches components overview matrix status badges (doc-overview-matrix__badge). */
  .page :global(.blog-article__tag) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.28em 0.7em;
    border-radius: var(--prism-radius-sm, 6px);
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  .page :global(.blog-article__tag--available) {
    background-color: color-mix(in srgb, var(--prism-color-success) 10%, var(--prism-color-surface));
    color: color-mix(in srgb, var(--prism-color-success) 22%, var(--prism-color-text-primary));
  }

  .page :global(.blog-article__tag--planned) {
    background-color: color-mix(in srgb, var(--prism-color-text-primary) 8%, var(--prism-color-surface));
    color: var(--prism-color-text-secondary);
  }

  .page :global(.blog-article__tag--beta) {
    background-color: color-mix(in srgb, var(--prism-color-accent) 10%, var(--prism-color-surface));
    color: color-mix(in srgb, var(--prism-color-accent-strong) 28%, var(--prism-color-text-primary));
  }

  .page :global(.blog-article__tag--unavailable) {
    background-color: color-mix(in srgb, var(--prism-color-text-primary) 8%, var(--prism-color-surface));
    color: var(--prism-color-text-secondary);
  }

  .page :global(.blog-article__title) {
    margin: 0;
    font-size: clamp(1.5rem, 4vw, 1.85rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.15;
  }

  .page :global(.blog-article__figure) {
    margin: clamp(1.25rem, 3vw, 1.75rem) 0 0;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--prism-color-border-subtle) 85%, transparent);
    background: color-mix(in srgb, var(--prism-color-border-subtle) 25%, var(--prism-color-surface));
  }

  .page :global(.blog-article__img) {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: middle;
  }

  .page :global(.blog-article__body) {
    margin-top: clamp(1.25rem, 3vw, 1.75rem);
  }

  .page :global(.blog-article__body p) {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--prism-color-text-secondary);
  }
</style>

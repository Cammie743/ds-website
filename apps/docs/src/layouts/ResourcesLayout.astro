---
import BaseLayout from "./BaseLayout.astro";

export type ResourcesSection =
  "overview" | "ai-skills" | "figma" | "development" | "learning-videos" | "fonts" | "templates";

export type ResourcesNavCurrent = ResourcesSection;

interface Props {
  title: string;
  description?: string;
  current: ResourcesNavCurrent;
}

const {
  title,
  description = "Guides, tools, and references for working with Prism.",
  current,
} = Astro.props;

const navItems: { id: ResourcesNavCurrent; href: string; i18n: string; fallback: string }[] = [
  { id: "overview", href: "/resources/overview", i18n: "resources.toc.overview", fallback: "Overview" },
  { id: "ai-skills", href: "/resources/ai-skills", i18n: "resources.toc.aiSkills", fallback: "AI skills" },
  { id: "figma", href: "/resources/figma", i18n: "resources.toc.figma", fallback: "Figma" },
  {
    id: "development",
    href: "/resources/development",
    i18n: "resources.toc.development",
    fallback: "Development",
  },
  {
    id: "learning-videos",
    href: "/resources/learning-videos",
    i18n: "resources.toc.learningVideos",
    fallback: "Learning videos",
  },
  { id: "fonts", href: "/resources/fonts", i18n: "resources.toc.fonts", fallback: "Fonts" },
  {
    id: "templates",
    href: "/resources/templates",
    i18n: "resources.toc.templates",
    fallback: "Templates",
  },
];
---

<BaseLayout title={title} description={description}>
  <div class="resources-layout">
    <nav
      class="section-nav section-nav--page"
      data-i18n-aria="resources.sectionNav.aria"
      aria-label="Resources pages"
    >
      <ul class="section-nav-list">
        {
          navItems.map((item) => (
            <li>
              <a
                class:list={["section-nav-link", { "is-current": current === item.id }]}
                href={item.href}
                aria-current={current === item.id ? "page" : undefined}
                data-i18n={item.i18n}
              >
                {item.fallback}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <article class="page">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .resources-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--prism-space-xl);
    width: 100%;
    max-width: none;
    align-items: start;
  }

  .section-nav {
    width: 100%;
    min-width: 0;
  }

  @media (max-width: 55.99rem) {
    .section-nav--page {
      display: none;
    }
  }

  @media (min-width: 56rem) {
    .resources-layout {
      grid-template-columns: 12.5rem minmax(0, 1fr);
      column-gap: clamp(var(--prism-space-xl), 4vw, var(--prism-space-3xl));
    }

    .section-nav {
      position: sticky;
      top: calc(var(--site-header-sticky-anchor, 72px) + var(--prism-space-md));
      max-height: calc(100vh - var(--site-header-sticky-anchor, 72px) - var(--prism-space-xl));
      overflow-y: auto;
      padding-top: calc(var(--docs-page-content-padding-top) + var(--prism-space-sm) + 4px);
      padding-bottom: calc(var(--prism-space-md) + 4px);
      padding-inline: 6px;
    }
  }

  .section-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    gap: var(--prism-space-xs);
  }

  .section-nav-list li {
    margin: 0;
    width: 100%;
    min-width: 0;
  }

  .section-nav-link {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: var(--prism-space-md) var(--prism-space-lg);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.4;
    text-decoration: none;
    color: var(--prism-color-text-primary);
    border-radius: 12px;
    background-color: transparent;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .section-nav-link.is-current {
    background-color: var(--nav-drawer-item-active-bg);
  }

  .section-nav-link:hover,
  .section-nav-link:focus-visible {
    background-color: var(--nav-drawer-item-active-bg);
    color: var(--prism-color-accent-strong);
  }

  .section-nav-link:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    outline-offset: 2px;
  }

  .page {
    width: 100%;
    max-width: none;
    min-width: 0;
    padding-top: var(--docs-page-content-padding-top);
    padding-bottom: var(--prism-space-3xl);
  }

  .page-head {
    margin-bottom: var(--prism-space-xl);
  }

  .page :global(h1) {
    margin: 0 0 var(--prism-space-md);
    font-size: clamp(3rem, 8.5vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
  }

  .page :global(.intro) {
    margin: 0;
    color: var(--prism-color-text-secondary);
    line-height: 1.65;
    font-size: 1.0625rem;
  }
</style>

---
import BaseLayout from "./BaseLayout.astro";

export type ComponentsSection =
  "overview" | "accordion" | "anchor" | "avatars" | "buttons" | "dialog" | "input-fields";

/** Avatars subsection routes (under `/components/avatars/*`). */
export type AvatarsNavLeaf = "avatars-avatar" | "avatars-avatar-group";

/** Current page in the components section nav. */
export type ComponentsNavCurrent = ComponentsSection | AvatarsNavLeaf;

type NavChild = {
  id: AvatarsNavLeaf;
  href: string;
  i18n: string;
  fallback: string;
};

type NavItem =
  | {
      id: Exclude<ComponentsSection, "avatars">;
      href: string;
      i18n: string;
      fallback: string;
      children?: undefined;
    }
  | {
      id: "avatars";
      href: string;
      i18n: string;
      fallback: string;
      children: NavChild[];
    };

interface Props {
  title: string;
  description?: string;
  current?: ComponentsNavCurrent;
}

const { title, description = "Prism UI components for web experiences.", current } = Astro.props;

/** Open Avatars disclosure when viewing any Avatars page so nested links stay visible. */
const avatarsNavDisclosureOpen =
  current === "avatars" || current === "avatars-avatar" || current === "avatars-avatar-group";

const navItems: NavItem[] = [
  {
    id: "overview",
    href: "/components/overview",
    i18n: "components.toc.overview",
    fallback: "Overview",
  },
  { id: "accordion", href: "/components/accordion", i18n: "components.toc.accordion", fallback: "Accordion" },
  { id: "anchor", href: "/components/anchor", i18n: "components.toc.anchor", fallback: "Anchor" },
  {
    id: "avatars",
    href: "/components/avatars",
    i18n: "components.toc.avatars",
    fallback: "Avatars",
    children: [
      {
        id: "avatars-avatar",
        href: "/components/avatars/avatar",
        i18n: "components.toc.avatar",
        fallback: "Avatar",
      },
      {
        id: "avatars-avatar-group",
        href: "/components/avatars/avatar-group",
        i18n: "components.toc.avatarGroup",
        fallback: "Avatar group",
      },
    ],
  },
  { id: "buttons", href: "/components/buttons", i18n: "components.toc.buttons", fallback: "Buttons" },
  { id: "dialog", href: "/components/dialog", i18n: "components.toc.dialog", fallback: "Dialog" },
  {
    id: "input-fields",
    href: "/components/input-fields",
    i18n: "components.toc.inputFields",
    fallback: "Input fields",
  },
];
---

<BaseLayout title={title} description={description}>
  <div class="components-layout">
    <nav
      class="section-nav section-nav--page"
      data-i18n-aria="components.sectionNav.aria"
      aria-label="Components pages"
    >
      <ul class="section-nav-list">
        {
          navItems.map((item) =>
            item.children ? (
              <li class="section-nav-item--has-children">
                <details class="section-nav-disclosure" open={avatarsNavDisclosureOpen}>
                  <summary class="section-nav-disclosure-summary">
                    <span class="section-nav-disclosure-summary-inner">
                      <a
                        class:list={[
                          "section-nav-link",
                          "section-nav-link--disclosure-label",
                          { "is-current": current != null && current === item.id },
                          {
                            "is-active-branch":
                              current === "avatars-avatar" || current === "avatars-avatar-group",
                          },
                        ]}
                        href={item.href}
                        aria-current={current != null && current === item.id ? "page" : undefined}
                        data-i18n={item.i18n}
                      >
                        {item.fallback}
                      </a>
                      <span class="section-nav-disclosure-chevron" aria-hidden="true">
                        <svg
                          class="section-nav-disclosure-chevron-svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="m9 18 6-6-6-6"></path>
                        </svg>
                      </span>
                    </span>
                  </summary>
                  <ul class="section-nav-sublist">
                    {item.children.map((child) => (
                      <li>
                        <a
                          class:list={[
                            "section-nav-link",
                            "section-nav-link--nested",
                            { "is-current": current != null && current === child.id },
                          ]}
                          href={child.href}
                          aria-current={current != null && current === child.id ? "page" : undefined}
                          data-i18n={child.i18n}
                        >
                          {child.fallback}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              </li>
            ) : (
              <li>
                <a
                  class:list={["section-nav-link", { "is-current": current != null && current === item.id }]}
                  href={item.href}
                  aria-current={current != null && current === item.id ? "page" : undefined}
                  data-i18n={item.i18n}
                >
                  {item.fallback}
                </a>
              </li>
            )
          )
        }
      </ul>
    </nav>
    <article class="page">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .components-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--prism-space-xl);
    width: 100%;
    max-width: none;
    align-items: start;
  }

  .section-nav {
    width: 100%;
    min-width: 0;
  }

  @media (max-width: 55.99rem) {
    .section-nav--page {
      display: none;
    }
  }

  @media (min-width: 56rem) {
    .components-layout {
      grid-template-columns: 12.5rem minmax(0, 1fr);
      column-gap: clamp(var(--prism-space-xl), 4vw, var(--prism-space-3xl));
    }

    .section-nav {
      position: sticky;
      top: calc(var(--site-header-sticky-anchor, 72px) + var(--prism-space-md));
      max-height: calc(100vh - var(--site-header-sticky-anchor, 72px) - var(--prism-space-xl));
      overflow-y: auto;
      /* Inset so focus rings (outline + offset) are not clipped by the scrollport */
      padding-top: calc(var(--docs-page-content-padding-top) + var(--prism-space-sm) + 4px);
      padding-bottom: calc(var(--prism-space-md) + 4px);
      padding-inline: 6px;
    }
  }

  .section-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    width: 100%;
    gap: var(--prism-space-xs);
  }

  .section-nav-list li {
    margin: 0;
    width: 100%;
    min-width: 0;
  }

  .section-nav-link {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: var(--prism-space-md) var(--prism-space-lg);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.4;
    text-decoration: none;
    color: var(--prism-color-text-primary);
    border-radius: 12px;
    background-color: transparent;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .section-nav-link.is-current {
    background-color: var(--nav-drawer-item-active-bg);
  }

  .section-nav-link:hover,
  .section-nav-link:focus-visible {
    background-color: var(--nav-drawer-item-active-bg);
    color: var(--prism-color-accent-strong);
  }

  .section-nav-link:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    outline-offset: 2px;
  }

  .section-nav-item--has-children {
    display: flex;
    flex-direction: column;
    gap: var(--prism-space-xs);
  }

  .section-nav-disclosure {
    display: flex;
    flex-direction: column;
    gap: var(--prism-space-xs);
    width: 100%;
    min-width: 0;
    border-radius: 12px;
  }

  .section-nav-disclosure-summary {
    list-style: none;
    cursor: pointer;
    border-radius: 12px;
  }

  .section-nav-disclosure-summary:focus-within {
    outline: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    outline-offset: 2px;
    border-radius: 12px;
  }

  .section-nav-disclosure-summary::-webkit-details-marker {
    display: none;
  }

  .section-nav-disclosure-summary::marker {
    content: none;
  }

  .section-nav-disclosure-summary-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--prism-space-xs);
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    padding-block: var(--prism-space-md);
    padding-inline-start: var(--prism-space-lg);
    padding-inline-end: var(--prism-space-xs);
    border-radius: 12px;
    background-color: transparent;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .section-nav-disclosure-summary-inner:hover,
  .section-nav-disclosure-summary-inner:focus-within,
  .section-nav-disclosure-summary-inner:has(.section-nav-link--disclosure-label.is-current) {
    background-color: var(--nav-drawer-item-active-bg);
  }

  .section-nav-disclosure-summary-inner:hover .section-nav-link--disclosure-label,
  .section-nav-disclosure-summary-inner:focus-within .section-nav-link--disclosure-label {
    color: var(--prism-color-accent-strong);
  }

  .section-nav-disclosure-summary-inner:hover .section-nav-disclosure-chevron,
  .section-nav-disclosure-summary-inner:focus-within .section-nav-disclosure-chevron {
    color: var(--prism-color-accent-strong);
  }

  .section-nav-disclosure-chevron {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 2.25rem;
    flex-shrink: 0;
    width: 2.25rem;
    color: var(--prism-color-text-secondary);
    transition: color 0.2s ease;
  }

  /* Path points right at 0deg; rotate so glyph reads as “down” in the sidebar */
  .section-nav-disclosure-chevron-svg {
    width: 1.125rem;
    height: 1.125rem;
    transform: rotate(90deg);
    transition: transform 0.2s ease;
  }

  .section-nav-link--disclosure-label {
    flex: 1 1 auto;
    min-width: 0;
    padding: 0;
    margin: 0;
    background-color: transparent !important;
  }

  .section-nav-link--disclosure-label.is-current {
    background-color: transparent !important;
  }

  .section-nav-link--disclosure-label:hover,
  .section-nav-link--disclosure-label:focus-visible {
    background-color: transparent !important;
    outline: none;
  }

  .section-nav-sublist {
    list-style: none;
    margin: 0;
    padding: 0 0 0 var(--prism-space-md);
    display: flex;
    flex-direction: column;
    gap: var(--prism-space-xs);
    width: 100%;
  }

  .section-nav-sublist li {
    margin: 0;
  }

  .section-nav-link--nested {
    padding: var(--prism-space-md) var(--prism-space-lg);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.4;
  }

  .section-nav-link.is-active-branch:not(.is-current) {
    color: var(--prism-color-text-secondary);
  }

  .page {
    width: 100%;
    max-width: none;
    min-width: 0;
    padding-top: var(--docs-page-content-padding-top);
    padding-bottom: var(--prism-space-3xl);
  }

  .page-head {
    margin-bottom: var(--prism-space-xl);
  }

  .page :global(h1) {
    margin: 0 0 var(--prism-space-md);
    font-size: clamp(3rem, 8.5vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.08;
  }

  .page :global(.intro) {
    margin: 0;
    color: var(--prism-color-text-secondary);
    line-height: 1.65;
    font-size: 1.0625rem;
  }
</style>

---
import ComponentsLayout from "../../layouts/ComponentsLayout.astro";
import DocH2WithAnchor from "../../components/DocH2WithAnchor.astro";
---

<ComponentsLayout title="Accordion" description="Expand and collapse patterns in Prism." current="accordion">
  <header class="page-head">
    <div class="page-head__title-row">
      <h1 data-i18n="components.accordion.h1">Accordion</h1>
      <span class="page-head__version" data-i18n="components.accordion.version">v1.0</span>
    </div>
    <p class="intro" data-i18n="components.accordion.intro">
      Accordion helps users reveal and hide related content without leaving the current context. It is best for grouped
      information that users may want to scan first and open selectively.
    </p>
  </header>

  <figure class="doc-preview">
    <div class="doc-preview__media">
      <img
        class="doc-preview__img"
        src="/images/components/accordion/preview.png"
        alt="Component preview: Accordion"
        data-i18n-alt="components.accordion.previewAlt"
        loading="eager"
        decoding="async"
      />
    </div>
  </figure>

  <div class="doc-tabs" data-doc-tabs>
    <div
      class="doc-tabs__list prism-chrome-bg"
      role="tablist"
      aria-label="Accordion usage sections"
      data-i18n-aria="components.accordion.tabs.aria"
    >
      <button
        type="button"
        class="doc-tabs__tab"
        id="accordion-tab-overview"
        role="tab"
        aria-selected="true"
        aria-controls="accordion-panel-overview"
        tabindex="0"
        data-i18n="components.accordion.tabs.overview"
      >
        Overview
      </button>
      <button
        type="button"
        class="doc-tabs__tab"
        id="accordion-tab-design"
        role="tab"
        aria-selected="false"
        aria-controls="accordion-panel-guidelines"
        tabindex="-1"
        data-i18n="components.accordion.tabs.design"
      >
        Guidelines
      </button>
      <button
        type="button"
        class="doc-tabs__tab"
        id="accordion-tab-content"
        role="tab"
        aria-selected="false"
        aria-controls="accordion-panel-content"
        tabindex="-1"
        data-i18n="components.accordion.tabs.content"
      >
        Content
      </button>
      <button
        type="button"
        class="doc-tabs__tab"
        id="accordion-tab-accessibility"
        role="tab"
        aria-selected="false"
        aria-controls="accordion-panel-accessibility"
        tabindex="-1"
        data-i18n="components.accordion.tabs.accessibility"
      >
        Accessibility
      </button>
    </div>

    <div class="doc-tabs__panels">
      <section
        class="doc-tabs__panel"
        id="accordion-panel-overview"
        role="tabpanel"
        aria-labelledby="accordion-tab-overview"
        tabindex="0"
      >
        <section class="doc-section-block doc-overview-resources doc-section-group" aria-labelledby="accordion-overview-resources-h2">
          <DocH2WithAnchor
            id="accordion-overview-resources-h2"
            rowClass="doc-h2-anchor-row--tabs"
            class="doc-tabs__h2"
            data-i18n="components.accordion.overview.resourcesH2"
          >
            Resources and availability
          </DocH2WithAnchor>
          <div class="doc-section-stack">
          <div class="doc-section-group">
            <h4 data-i18n="components.accordion.overview.desktopWebH3">Desktop client &amp; Web browser</h4>
            <div class="doc-overview-matrix-shell">
              <table class="doc-tabs__table doc-overview-matrix doc-overview-matrix--resources" aria-labelledby="accordion-overview-resources-h2">
                <thead>
                  <tr>
                    <th scope="col" data-i18n="components.accordion.overview.colType">Type</th>
                    <th scope="col" data-i18n="components.accordion.overview.colResource">Resource</th>
                    <th scope="col" data-i18n="components.accordion.overview.colStatus">Status</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th scope="row" class="doc-overview-matrix__type" data-i18n="components.accordion.overview.bucketDesign">Design</th>
                    <td class="doc-overview-matrix__resource-cell">
                      <a class="doc-overview-matrix__resource" href="https://figma.com/design/OWKBE2BJBBanezKhapWx2Y/Prism-Desktop---Web-2.5?node-id=682-0" target="_blank" rel="noopener noreferrer">
                        <span data-i18n="components.accordion.overview.resourceRowFigma">Desktop &amp; Web Figma library</span>
                      </a>
                    </td>
                    <td class="doc-overview-matrix__status-cell"><span class="doc-overview-matrix__badge doc-overview-matrix__badge--available" data-i18n="components.accordion.overview.statusAvailable">Available</span></td>
                  </tr>
                  <tr>
                    <th scope="row" class="doc-overview-matrix__type" data-i18n="components.accordion.overview.bucketImplementation">Engineering</th>
                    <td class="doc-overview-matrix__resource-cell">
                      <a class="doc-overview-matrix__resource" href="https://reactui.zoomdev.us/v2.x/docs/component/accordion/" target="_blank" rel="noopener noreferrer">
                        <span data-i18n="components.accordion.overview.resourceRowReact">React</span>
                      </a>
                    </td>
                    <td class="doc-overview-matrix__status-cell"><span class="doc-overview-matrix__badge doc-overview-matrix__badge--available" data-i18n="components.accordion.overview.statusAvailable">Available</span></td>
                  </tr>
                  <tr>
                    <th scope="row" class="doc-overview-matrix__type" data-i18n="components.accordion.overview.bucketImplementation">Engineering</th>
                    <td class="doc-overview-matrix__resource-cell">
                      <a class="doc-overview-matrix__resource" href="https://vueui.zoomdev.us/vue3/en-US/components/accordion.html" target="_blank" rel="noopener noreferrer">
                        <span data-i18n="components.accordion.overview.resourceRowVue">Vue</span>
                      </a>
                    </td>
                    <td class="doc-overview-matrix__status-cell"><span class="doc-overview-matrix__badge doc-overview-matrix__badge--available" data-i18n="components.accordion.overview.statusAvailable">Available</span></td>
                  </tr>
                  <tr>
                    <th scope="row" class="doc-overview-matrix__type" data-i18n="components.accordion.overview.bucketImplementation">Engineering</th>
                    <td class="doc-overview-matrix__resource-cell" data-i18n="components.accordion.overview.resourceRowMacos">macOS</td>
                    <td class="doc-overview-matrix__status-cell"><span class="doc-overview-matrix__badge doc-overview-matrix__badge--planned" data-i18n="components.accordion.overview.statusVerify">Verify</span></td>
                  </tr>
                  <tr>
                    <th scope="row" class="doc-overview-matrix__type" data-i18n="components.accordion.overview.bucketImplementation">Engineering</th>
                    <td class="doc-overview-matrix__resource-cell" data-i18n="components.accordion.overview.resourceRowWindows">Windows</td>
                    <td class="doc-overview-matrix__status-cell"><span class="doc-overview-matrix__badge doc-overview-matrix__badge--planned" data-i18n="components.accordion.overview.statusVerify">Verify</span></td>
                  </tr>
                  <tr>
                    <th scope="row" class="doc-overview-matrix__type" data-i18n="components.accordion.overview.bucketImplementation">Engineering</th>
                    <td class="doc-overview-matrix__resource-cell" data-i18n="components.accordion.overview.resourceRowLinux">Linux</td>
                    <td class="doc-overview-matrix__status-cell"><span class="doc-overview-matrix__badge doc-overview-matrix__badge--planned" data-i18n="components.accordion.overview.statusVerify">Verify</span></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
          <div class="doc-section-group">
            <h4 data-i18n="components.accordion.overview.mobileAppH3">Mobile app</h4>
          <p class="doc-tabs__panel-copy">
            <span class="doc-overview-matrix__badge doc-overview-matrix__badge--unavailable" data-i18n="components.accordion.overview.mobileAppUnavailable">
              Unavailable
            </span>
          </p>
          </div>
          <div class="doc-section-group">
            <h4 data-i18n="components.accordion.overview.aiSkillsH3">AI skills</h4>
            <div class="doc-overview-matrix-shell">
              <table class="doc-tabs__table doc-overview-matrix doc-overview-matrix--resources" data-i18n-aria="components.accordion.overview.aiSkills.tableAria">
                <thead>
                  <tr>
                    <th scope="col" data-i18n="components.accordion.overview.colType">Type</th>
                    <th scope="col" data-i18n="components.accordion.overview.colResource">Resource</th>
                    <th scope="col" data-i18n="components.accordion.overview.colStatus">Status</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th scope="row" class="doc-overview-matrix__type" data-i18n="components.accordion.overview.aiSkills.guidanceType">Guidance</th>
                    <td class="doc-overview-matrix__resource-cell">
                      <span data-i18n="components.accordion.overview.aiSkills.guidanceResource">Accordion guidelines Markdown file</span>
                    </td>
                    <td class="doc-overview-matrix__status-cell"><span class="doc-overview-matrix__badge doc-overview-matrix__badge--available" data-i18n="components.accordion.overview.statusAvailable">Available</span></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
          </div>
        </section>
      </section>
      <section
        class="doc-tabs__panel"
        id="accordion-panel-guidelines"
        role="tabpanel"
        aria-labelledby="accordion-tab-design"
        tabindex="0"
        hidden
      >
        <section class="doc-section-block">
          <DocH2WithAnchor
            id="accordion-design-usage"
            rowClass="doc-h2-anchor-row--tabs"
            class="doc-tabs__h2"
            data-i18n="components.accordion.design.usageH2"
          >
            Usage
          </DocH2WithAnchor>
          <section class="doc-section-group">
            <h4 id="accordion-design-when-to-use" data-i18n="components.accordion.design.whenToUseH2">✅ When to use</h4>
            <p class="doc-tabs__panel-copy" data-i18n="components.accordion.design.whenToUseBody">
              Use accordion when content fits clear, labeled sections and all details do not need to be visible at once. It is useful for settings groups, FAQs, filters, permissions, and grouped informational blocks.
            </p>
            <h4 id="accordion-design-when-not-to-use" data-i18n="components.accordion.design.whenNotToUseH2">🚫 When not to use</h4>
            <p class="doc-tabs__panel-copy" data-i18n="components.accordion.design.whenNotToUseBody">
              Avoid accordion for critical content that should always stay visible, for one or two short items, or when users need to compare all sections side by side.
            </p>
          </section>
        </section>
        <section class="doc-section-block">
          <DocH2WithAnchor
            id="accordion-design-variants"
            rowClass="doc-h2-anchor-row--tabs"
            class="doc-tabs__h2"
            data-i18n="components.accordion.design.variantsH2"
          >
            Variants
          </DocH2WithAnchor>
          <p class="doc-tabs__panel-copy" data-i18n="components.accordion.design.variantsBody">
            There are 2 variants: leading chevron and trailing chevron.
          </p>
          <div class="doc-tabs__figure">
          <div
            class="accordion-variant-row"
            role="group"
            aria-label="Interactive examples: leading and trailing chevron accordions"
            data-i18n-aria="components.accordion.design.demoAria"
          >
            <div class="accordion-variant-column">
              <p class="accordion-variant-demo__example-caption" data-i18n="components.accordion.design.demoLeadingTitle">
                Leading chevron
              </p>
              <div
                class="doc-tabs__figure-media accordion-variant-box"
                role="region"
                aria-label="Leading chevron accordion example"
                data-i18n-aria="components.accordion.design.demoLeadingAria"
              >
                <div class="accordion-variant-demo__example accordion-variant-demo__example--leading">
                  <div class="accordion-prism-stack">
                  <details class="accordion-prism-item">
                    <summary class="accordion-prism-summary accordion-prism-summary--leading">
                      <span class="accordion-prism-chevron" aria-hidden="true">
                        <svg
                          class="accordion-prism-chevron-svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="m9 18 6-6-6-6"></path>
                        </svg>
                      </span>
                      <span class="accordion-prism-label" data-i18n="components.accordion.design.demoSummary1">
                        Billing overview
                      </span>
                    </summary>
                    <div class="accordion-prism-panel">
                      <p class="accordion-prism-panel-copy" data-i18n="components.accordion.design.demoBody1">
                        Review line items, tax, and payment method before submitting. You can return here while the
                        order is still open.
                      </p>
                    </div>
                  </details>
                  <details class="accordion-prism-item">
                    <summary class="accordion-prism-summary accordion-prism-summary--leading">
                      <span class="accordion-prism-chevron" aria-hidden="true">
                        <svg
                          class="accordion-prism-chevron-svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="m9 18 6-6-6-6"></path>
                        </svg>
                      </span>
                      <span class="accordion-prism-label" data-i18n="components.accordion.design.demoSummary2">
                        Shipping and delivery
                      </span>
                    </summary>
                    <div class="accordion-prism-panel">
                      <p class="accordion-prism-panel-copy" data-i18n="components.accordion.design.demoBody2">
                        Delivery estimates update when your address or items change. Expand this panel for carrier
                        options and tracking details.
                      </p>
                    </div>
                  </details>
                  <details class="accordion-prism-item">
                    <summary class="accordion-prism-summary accordion-prism-summary--leading">
                      <span class="accordion-prism-chevron" aria-hidden="true">
                        <svg
                          class="accordion-prism-chevron-svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="m9 18 6-6-6-6"></path>
                        </svg>
                      </span>
                      <span class="accordion-prism-label" data-i18n="components.accordion.design.demoSummary3">
                        Returns and exchanges
                      </span>
                    </summary>
                    <div class="accordion-prism-panel">
                      <p class="accordion-prism-panel-copy" data-i18n="components.accordion.design.demoBody3">
                        See eligible items, return windows, and how refunds post to your original payment method.
                      </p>
                    </div>
                  </details>
                  <details class="accordion-prism-item">
                    <summary class="accordion-prism-summary accordion-prism-summary--leading">
                      <span class="accordion-prism-chevron" aria-hidden="true">
                        <svg
                          class="accordion-prism-chevron-svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="m9 18 6-6-6-6"></path>
                        </svg>
                      </span>
                      <span class="accordion-prism-label" data-i18n="components.accordion.design.demoSummary4">
                        Need help?
                      </span>
                    </summary>
                    <div class="accordion-prism-panel">
                      <p class="accordion-prism-panel-copy" data-i18n="components.accordion.design.demoBody4">
                        Contact support for order changes, damaged shipments, or account questions.
                      </p>
                    </div>
                  </details>
                </div>
              </div>
            </div>
            </div>
            <div class="accordion-variant-column">
              <p class="accordion-variant-demo__example-caption" data-i18n="components.accordion.design.demoTrailingTitle">
                Trailing chevron
              </p>
              <div
                class="doc-tabs__figure-media accordion-variant-box"
                role="region"
                aria-label="Trailing chevron accordion example"
                data-i18n-aria="components.accordion.design.demoTrailingAria"
              >
                <div class="accordion-variant-demo__example accordion-variant-demo__example--trailing">
                  <div class="accordion-prism-stack">
                  <details class="accordion-prism-item">
                    <summary class="accordion-prism-summary accordion-prism-summary--trailing">
                      <span class="accordion-prism-label" data-i18n="components.accordion.design.demoSummary1">
                        Billing overview
                      </span>
                      <span class="accordion-prism-chevron" aria-hidden="true">
                        <svg
                          class="accordion-prism-chevron-svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="m9 18 6-6-6-6"></path>
                        </svg>
                      </span>
                    </summary>
                    <div class="accordion-prism-panel">
                      <p class="accordion-prism-panel-copy" data-i18n="components.accordion.design.demoBody1">
                        Review line items, tax, and payment method before submitting. You can return here while the
                        order is still open.
                      </p>
                    </div>
                  </details>
                  <details class="accordion-prism-item">
                    <summary class="accordion-prism-summary accordion-prism-summary--trailing">
                      <span class="accordion-prism-label" data-i18n="components.accordion.design.demoSummary2">
                        Shipping and delivery
                      </span>
                      <span class="accordion-prism-chevron" aria-hidden="true">
                        <svg
                          class="accordion-prism-chevron-svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="m9 18 6-6-6-6"></path>
                        </svg>
                      </span>
                    </summary>
                    <div class="accordion-prism-panel">
                      <p class="accordion-prism-panel-copy" data-i18n="components.accordion.design.demoBody2">
                        Delivery estimates update when your address or items change. Expand this panel for carrier
                        options and tracking details.
                      </p>
                    </div>
                  </details>
                  <details class="accordion-prism-item">
                    <summary class="accordion-prism-summary accordion-prism-summary--trailing">
                      <span class="accordion-prism-label" data-i18n="components.accordion.design.demoSummary3">
                        Returns and exchanges
                      </span>
                      <span class="accordion-prism-chevron" aria-hidden="true">
                        <svg
                          class="accordion-prism-chevron-svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="m9 18 6-6-6-6"></path>
                        </svg>
                      </span>
                    </summary>
                    <div class="accordion-prism-panel">
                      <p class="accordion-prism-panel-copy" data-i18n="components.accordion.design.demoBody3">
                        See eligible items, return windows, and how refunds post to your original payment method.
                      </p>
                    </div>
                  </details>
                  <details class="accordion-prism-item">
                    <summary class="accordion-prism-summary accordion-prism-summary--trailing">
                      <span class="accordion-prism-label" data-i18n="components.accordion.design.demoSummary4">
                        Need help?
                      </span>
                      <span class="accordion-prism-chevron" aria-hidden="true">
                        <svg
                          class="accordion-prism-chevron-svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="m9 18 6-6-6-6"></path>
                        </svg>
                      </span>
                    </summary>
                    <div class="accordion-prism-panel">
                      <p class="accordion-prism-panel-copy" data-i18n="components.accordion.design.demoBody4">
                        Contact support for order changes, damaged shipments, or account questions.
                      </p>
                    </div>
                  </details>
                </div>
              </div>
            </div>
            </div>
          </div>
        </div>
        <div class="doc-overview-matrix-shell">
          <table
            class="doc-tabs__table doc-overview-matrix doc-overview-matrix--guidelines"
            aria-label="Leading and trailing chevron usage"
            data-i18n-aria="components.accordion.design.variantGuidance.tableAria"
          >
            <thead>
              <tr>
                <th scope="col" data-i18n="components.accordion.design.variantGuidance.colVariant">Variant</th>
                <th scope="col" data-i18n="components.accordion.design.variantGuidance.colUseCase">Use case</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row" class="doc-overview-matrix__type" data-i18n="components.accordion.design.demoLeadingTitle">
                  Leading chevron
                </th>
                <td class="doc-overview-matrix__resource-cell" data-i18n="components.accordion.design.variantGuidance.leadingUseCase">
                  Use when left-aligned scanning is important, such as in dense settings lists or structured navigation
                  patterns.
                </td>
              </tr>
              <tr>
                <th scope="row" class="doc-overview-matrix__type" data-i18n="components.accordion.design.demoTrailingTitle">
                  Trailing chevron
                </th>
                <td class="doc-overview-matrix__resource-cell" data-i18n="components.accordion.design.variantGuidance.trailingUseCase">
                  Use when content readability should be prioritized first, such as in cards, detail panels, or
                  content-heavy lists.
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        </section>
        <section class="doc-section-block">
          <DocH2WithAnchor
            id="accordion-design-core-anatomy"
            rowClass="doc-h2-anchor-row--tabs"
            class="doc-tabs__h2"
            data-i18n="components.accordion.design.coreAnatomyH2"
          >
            Core anatomy
          </DocH2WithAnchor>
          <figure class="doc-tabs__figure docs-inline-figure-shell">
            <div class="doc-tabs__figure-media">
              <img
                class="doc-preview__img"
                src="/images/components/accordion/core-anatomy.png"
                alt="Accordion core anatomy visual with numbered callouts"
                loading="lazy"
                decoding="async"
              />
            </div>
            <figcaption class="docs-inline-caption docs-inline-caption--stack">
              <div class="docs-inline-caption-row">
                <span class="docs-inline-caption__badge" aria-hidden="true"><span class="docs-inline-caption__badge-num">1</span></span>
                <span class="docs-inline-caption__text">Chevron (required)</span>
              </div>
              <div class="docs-inline-caption-row">
                <span class="docs-inline-caption__badge" aria-hidden="true"><span class="docs-inline-caption__badge-num">2</span></span>
                <span class="docs-inline-caption__text">Label (required)</span>
              </div>
              <div class="docs-inline-caption-row">
                <span class="docs-inline-caption__badge" aria-hidden="true"><span class="docs-inline-caption__badge-num">3</span></span>
                <span class="docs-inline-caption__text">Expandable content area (required)</span>
              </div>
              <div class="docs-inline-caption-row">
                <span class="docs-inline-caption__badge" aria-hidden="true"><span class="docs-inline-caption__badge-num">4</span></span>
                <span class="docs-inline-caption__text">Divider (optional)</span>
              </div>
            </figcaption>
          </figure>
        </section>
        <section class="doc-section-block">
          <DocH2WithAnchor
            id="accordion-design-configurations"
            rowClass="doc-h2-anchor-row--tabs"
            class="doc-tabs__h2"
            data-i18n="components.accordion.design.propertiesH2"
          >
            Properties
          </DocH2WithAnchor>
          <section class="doc-subsection-detail" aria-labelledby="accordion-design-property-label">
            <div class="doc-subsection-detail__copy">
              <h3 id="accordion-design-property-label" data-i18n="components.accordion.design.properties.label.property">
                Label
              </h3>
              <p class="doc-tabs__panel-copy" data-i18n="components.accordion.design.properties.label.description">
                Defines the primary text for the accordion row.

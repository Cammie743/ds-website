---
import ComponentsLayout from "../../layouts/ComponentsLayout.astro";
import DocH2WithAnchor from "../../components/DocH2WithAnchor.astro";
---

<ComponentsLayout title="Accordion" description="Expand and collapse patterns in Prism." current="accordion">
  <header class="page-head">
    <div class="page-head__title-row">
      <h1 data-i18n="components.accordion.h1">Accordion</h1>
      <span class="page-head__version" data-i18n="components.accordion.version">v2.5</span>
    </div>
    <p class="intro" data-i18n="components.accordion.intro">
      Disclosure groups, keyboard interaction, and motion for stacked panels will be documented here.
    </p>
  </header>

  <figure class="doc-preview">
    <div class="doc-preview__media">
      <img
        class="doc-preview__img"
        src="/images/components/accordion.png"
        alt="Component preview: Accordion"
        data-i18n-alt="components.accordion.previewAlt"
        loading="eager"
        decoding="async"
      />
    </div>
  </figure>

  <div class="doc-tabs" data-doc-tabs>
    <div
      class="doc-tabs__list prism-chrome-bg"
      role="tablist"
      aria-label="Accordion usage sections"
      data-i18n-aria="components.accordion.tabs.aria"
    >
      <button
        type="button"
        class="doc-tabs__tab"
        id="accordion-tab-overview"
        role="tab"
        aria-selected="true"
        aria-controls="accordion-panel-overview"
        tabindex="0"
        data-i18n="components.accordion.tabs.overview"
      >
        Overview
      </button>
      <button
        type="button"
        class="doc-tabs__tab"
        id="accordion-tab-design"
        role="tab"
        aria-selected="false"
        aria-controls="accordion-panel-design"
        tabindex="-1"
        data-i18n="components.accordion.tabs.design"
      >
        Guidelines
      </button>
      <button
        type="button"
        class="doc-tabs__tab"
        id="accordion-tab-accessibility"
        role="tab"
        aria-selected="false"
        aria-controls="accordion-panel-accessibility"
        tabindex="-1"
        data-i18n="components.accordion.tabs.accessibility"
      >
        Accessibility
      </button>
    </div>

    <div class="doc-tabs__panels">
      <section
        class="doc-tabs__panel"
        id="accordion-panel-overview"
        role="tabpanel"
        aria-labelledby="accordion-tab-overview"
        tabindex="0"
      >
        <div class="doc-overview-resources">
          <DocH2WithAnchor
            id="accordion-overview-resources-h2"
            rowClass="doc-h2-anchor-row--tabs"
            class="doc-tabs__h2 doc-overview-resources__h2"
            data-i18n="components.accordion.overview.resourcesH2"
          >
            Resources and availability
          </DocH2WithAnchor>
          <div class="doc-overview-matrix-shell">
            <table class="doc-tabs__table doc-overview-matrix" aria-labelledby="accordion-overview-resources-h2">
              <thead>
                <tr>
                  <th scope="col" data-i18n="components.accordion.overview.colType">Type</th>
                  <th scope="col" data-i18n="components.accordion.overview.colResource">Resource</th>
                  <th scope="col" data-i18n="components.accordion.overview.colStatus">Status</th>
                </tr>
              </thead>
              <tbody>
                <tr class="doc-overview-matrix__row--design">
                  <th scope="row" class="doc-overview-matrix__type" id="accordion-overview-type-design" data-i18n="components.accordion.overview.bucketDesign">
                    Design
                  </th>
                  <td class="doc-overview-matrix__resource-cell">
                    <div class="doc-overview-matrix__cell-align">
                      <a
                        class="doc-overview-matrix__resource"
                        href="https://www.figma.com/design/OWKBE2BJBBanezKhapWx2Y/Prism-Desktop---Web-2.5?node-id=682-0"
                        target="_blank" rel="noopener noreferrer"
                      >
                        <span class="doc-overview-matrix__icon" aria-hidden="true">
                          <svg width="20" height="20" viewBox="0 0 15 15" fill="none" aria-hidden="true">
                            <path
                              fill-rule="evenodd"
                              clip-rule="evenodd"
                              d="M7.00005 2.04999H5.52505C4.71043 2.04999 4.05005 2.71037 4.05005 3.52499C4.05005 4.33961 4.71043 4.99999 5.52505 4.99999H7.00005V2.04999ZM7.00005 1.04999H8.00005H9.47505C10.842 1.04999 11.95 2.15808 11.95 3.52499C11.95 4.33163 11.5642 5.04815 10.9669 5.49999C11.5642 5.95184 11.95 6.66836 11.95 7.475C11.95 8.8419 10.842 9.95 9.47505 9.95C8.92236 9.95 8.41198 9.76884 8.00005 9.46266V9.95L8.00005 11.425C8.00005 12.7919 6.89195 13.9 5.52505 13.9C4.15814 13.9 3.05005 12.7919 3.05005 11.425C3.05005 10.6183 3.43593 9.90184 4.03317 9.44999C3.43593 8.99814 3.05005 8.28163 3.05005 7.475C3.05005 6.66836 3.43594 5.95184 4.03319 5.5C3.43594 5.04815 3.05005 4.33163 3.05005 3.52499C3.05005 2.15808 4.15814 1.04999 5.52505 1.04999H7.00005ZM8.00005 2.04999V4.99999H9.47505C10.2897 4.99999 10.95 4.33961 10.95 3.52499C10.95 2.71037 10.2897 2.04999 9.47505 2.04999H8.00005ZM5.52505 8.94998H7.00005L7.00005 7.4788L7.00005 7.475L7.00005 7.4712V6H5.52505C4.71043 6 4.05005 6.66038 4.05005 7.475C4.05005 8.28767 4.70727 8.94684 5.5192 8.94999L5.52505 8.94998ZM4.05005 11.425C4.05005 10.6123 4.70727 9.95315 5.5192 9.94999L5.52505 9.95H7.00005L7.00005 11.425C7.00005 12.2396 6.33967 12.9 5.52505 12.9C4.71043 12.9 4.05005 12.2396 4.05005 11.425ZM8.00005 7.47206C8.00164 6.65879 8.66141 6 9.47505 6C10.2897 6 10.95 6.66038 10.95 7.475C10.95 8.28962 10.2897 8.95 9.47505 8.95C8.66141 8.95 8.00164 8.29121 8.00005 7.47794V7.47206Z"
                              fill="currentColor"
                            ></path>
                          </svg>
                        </span>
                        <span data-i18n="components.accordion.overview.resourceRowFigma">Desktop & Web (Figma)</span>
                      </a>
                    </div>
                  </td>
                  <td class="doc-overview-matrix__status-cell">
                    <div class="doc-overview-matrix__cell-align">
                      <span class="doc-overview-matrix__badge doc-overview-matrix__badge--available">
                        <span data-i18n="components.accordion.overview.statusAvailable">Available</span>
                      </span>
                    </div>
                  </td>
                </tr>
                <tr class="doc-overview-matrix__row--design doc-overview-matrix__row--design-last">
                  <td class="doc-overview-matrix__type-spacer" aria-hidden="true"></td>
                  <td class="doc-overview-matrix__resource-cell" headers="accordion-overview-type-design">
                    <div class="doc-overview-matrix__cell-align">
                      <span class="doc-overview-matrix__resource doc-overview-matrix__resource--text">
                        <span class="doc-overview-matrix__icon" aria-hidden="true">
                          <svg width="20" height="20" viewBox="0 0 15 15" fill="none" aria-hidden="true">
                            <path
                              fill-rule="evenodd"
                              clip-rule="evenodd"
                              d="M7.00005 2.04999H5.52505C4.71043 2.04999 4.05005 2.71037 4.05005 3.52499C4.05005 4.33961 4.71043 4.99999 5.52505 4.99999H7.00005V2.04999ZM7.00005 1.04999H8.00005H9.47505C10.842 1.04999 11.95 2.15808 11.95 3.52499C11.95 4.33163 11.5642 5.04815 10.9669 5.49999C11.5642 5.95184 11.95 6.66836 11.95 7.475C11.95 8.8419 10.842 9.95 9.47505 9.95C8.92236 9.95 8.41198 9.76884 8.00005 9.46266V9.95L8.00005 11.425C8.00005 12.7919 6.89195 13.9 5.52505 13.9C4.15814 13.9 3.05005 12.7919 3.05005 11.425C3.05005 10.6183 3.43593 9.90184 4.03317 9.44999C3.43593 8.99814 3.05005 8.28163 3.05005 7.475C3.05005 6.66836 3.43594 5.95184 4.03319 5.5C3.43594 5.04815 3.05005 4.33163 3.05005 3.52499C3.05005 2.15808 4.15814 1.04999 5.52505 1.04999H7.00005ZM8.00005 2.04999V4.99999H9.47505C10.2897 4.99999 10.95 4.33961 10.95 3.52499C10.95 2.71037 10.2897 2.04999 9.47505 2.04999H8.00005ZM5.52505 8.94998H7.00005L7.00005 7.4788L7.00005 7.475L7.00005 7.4712V6H5.52505C4.71043 6 4.05005 6.66038 4.05005 7.475C4.05005 8.28767 4.70727 8.94684 5.5192 8.94999L5.52505 8.94998ZM4.05005 11.425C4.05005 10.6123 4.70727 9.95315 5.5192 9.94999L5.52505 9.95H7.00005L7.00005 11.425C7.00005 12.2396 6.33967 12.9 5.52505 12.9C4.71043 12.9 4.05005 12.2396 4.05005 11.425ZM8.00005 7.47206C8.00164 6.65879 8.66141 6 9.47505 6C10.2897 6 10.95 6.66038 10.95 7.475C10.95 8.28962 10.2897 8.95 9.47505 8.95C8.66141 8.95 8.00164 8.29121 8.00005 7.47794V7.47206Z"
                              fill="currentColor"
                            ></path>
                          </svg>
                        </span>
                        <span data-i18n="components.accordion.overview.resourceRowMobileFigma">Mobile</span>
                      </span>
                    </div>
                  </td>
                  <td class="doc-overview-matrix__status-cell" headers="accordion-overview-type-design">
                    <div class="doc-overview-matrix__cell-align">
                      <span class="doc-overview-matrix__badge doc-overview-matrix__badge--unavailable">
                        <span data-i18n="components.accordion.overview.statusNotAvailable">Not available</span>
                      </span>
                    </div>
                  </td>
                </tr>
                <tr class="doc-overview-matrix__row--impl">
                  <th scope="row" class="doc-overview-matrix__type" id="accordion-overview-type-implementation" data-i18n="components.accordion.overview.bucketImplementation">
                    Engineering
                  </th>
                  <td class="doc-overview-matrix__resource-cell">
                    <div class="doc-overview-matrix__cell-align">
                      <a class="doc-overview-matrix__resource" href="https://vueui.zoomdev.us/vue3/en-US/components/accordion.html" target="_blank" rel="noopener noreferrer">
                        <span class="doc-overview-matrix__icon" aria-hidden="true">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path
                              d="M12 3 3 20h4.5l4.5-8 4.5 8H21L12 3Z"
                              stroke="currentColor"
                              stroke-width="1.75"
                              stroke-linejoin="round"
                            ></path>
                            <path d="M12 9 9 20h6l-3-11Z" fill="currentColor" stroke="none"></path>
                          </svg>
                        </span>
                        <span data-i18n="components.accordion.overview.resourceRowVue">Vue (Desktop & Web)</span>
                      </a>
                    </div>
                  </td>
                  <td class="doc-overview-matrix__status-cell">
                    <div class="doc-overview-matrix__cell-align">
                      <span class="doc-overview-matrix__badge doc-overview-matrix__badge--available">
                        <span data-i18n="components.accordion.overview.statusAvailable">Available</span>
                      </span>
                    </div>
                  </td>
                </tr>
                <tr class="doc-overview-matrix__row--impl doc-overview-matrix__row--impl-last">
                  <td class="doc-overview-matrix__type-spacer" aria-hidden="true"></td>
                  <td class="doc-overview-matrix__resource-cell" headers="accordion-overview-type-implementation">
                    <div class="doc-overview-matrix__cell-align">
                      <a class="doc-overview-matrix__resource" href="https://reactui.zoomdev.us/v2.x/docs/component/accordion/" target="_blank" rel="noopener noreferrer">
                        <span class="doc-overview-matrix__icon" aria-hidden="true">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <circle cx="12" cy="12" r="2" fill="currentColor"></circle>
                            <ellipse
                              cx="12"
                              cy="12"
                              rx="11"
                              ry="4.2"
                              stroke="currentColor"
                              stroke-width="1.5"
                              transform="rotate(0 12 12)"
                            ></ellipse>
                            <ellipse
                              cx="12"
                              cy="12"
                              rx="11"
                              ry="4.2"
                              stroke="currentColor"
                              stroke-width="1.5"
                              transform="rotate(60 12 12)"
                            ></ellipse>
                            <ellipse
                              cx="12"
                              cy="12"
                              rx="11"
                              ry="4.2"
                              stroke="currentColor"
                              stroke-width="1.5"
                              transform="rotate(120 12 12)"
                            ></ellipse>
                          </svg>
                        </span>
                        <span data-i18n="components.accordion.overview.resourceRowReact">React (Desktop & Web)</span>
                      </a>
                    </div>
                  </td>
                  <td class="doc-overview-matrix__status-cell" headers="accordion-overview-type-implementation">
                    <div class="doc-overview-matrix__cell-align">
                      <span class="doc-overview-matrix__badge doc-overview-matrix__badge--available">
                        <span data-i18n="components.accordion.overview.statusAvailable">Available</span>
                      </span>
                    </div>
                  </td>
                </tr>
                <tr class="doc-overview-matrix__row--ai">
                  <th scope="row" class="doc-overview-matrix__type" id="accordion-overview-type-ai" data-i18n="components.accordion.overview.bucketAiSkill">
                    AI Skill
                  </th>
                  <td class="doc-overview-matrix__resource-cell">
                    <div class="doc-overview-matrix__cell-align">
                      <a class="doc-overview-matrix__resource" href="https://cursor.com/docs" target="_blank" rel="noopener noreferrer">
                        <span class="doc-overview-matrix__icon" aria-hidden="true">
                          <svg width="20" height="20" viewBox="0 0 466.73 532.09" fill="none" aria-hidden="true">
                            <path
                              fill-rule="nonzero"
                              d="M457.43,125.94L244.42,2.96c-6.84-3.95-15.28-3.95-22.12,0L9.3,125.94c-5.75,3.32-9.3,9.46-9.3,16.11v247.99c0,6.65,3.55,12.79,9.3,16.11l213.01,122.98c6.84,3.95,15.28,3.95,22.12,0l213.01-122.98c5.75-3.32,9.3-9.46,9.3-16.11v-247.99c0-6.65-3.55-12.79-9.3-16.11h-.01ZM444.05,151.99l-205.63,356.16c-1.39,2.4-5.06,1.42-5.06-1.36v-233.21c0-4.66-2.49-8.97-6.53-11.31L24.87,145.67c-2.4-1.39-1.42-5.06,1.36-5.06h411.26c5.84,0,9.49,6.33,6.57,11.39h-.01Z"
                              fill="currentColor"
                            ></path>
                          </svg>
                        </span>
                        <span data-i18n="components.accordion.overview.resourceRowCursor">Cursor</span>
                      </a>
                    </div>
                  </td>
                  <td class="doc-overview-matrix__status-cell">
                    <div class="doc-overview-matrix__cell-align">
                      <span class="doc-overview-matrix__badge doc-overview-matrix__badge--beta">
                        <span data-i18n="components.accordion.overview.statusBeta">Beta</span>
                      </span>
                    </div>
                  </td>
                </tr>
                <tr class="doc-overview-matrix__row--ai doc-overview-matrix__row--ai-last">
                  <td class="doc-overview-matrix__type-spacer" aria-hidden="true"></td>
                  <td class="doc-overview-matrix__resource-cell" headers="accordion-overview-type-ai">
                    <div class="doc-overview-matrix__cell-align">
                      <a class="doc-overview-matrix__resource" href="https://docs.anthropic.com/" target="_blank" rel="noopener noreferrer">
                        <span class="doc-overview-matrix__icon" aria-hidden="true">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path
                              fill-rule="nonzero"
                              fill="currentColor"
                              d="M4.709 15.955l4.72-2.647.08-.23-.08-.128H9.2l-.79-.048-2.698-.073-2.339-.097-2.266-.122-.571-.121L0 11.784l.055-.352.48-.321.686.06 1.52.103 2.278.158 1.652.097 2.449.255h.389l.055-.157-.134-.098-.103-.097-2.358-1.596-2.552-1.688-1.336-.972-.724-.491-.364-.462-.158-1.008.656-.722.881.06.225.061.893.686 1.908 1.476 2.491 1.833.365.304.145-.103.019-.073-.164-.274-1.355-2.446-1.446-2.49-.644-1.032-.17-.619a2.97 2.97 0 01-.104-.729L6.283.134 6.696 0l.996.134.42.364.62 1.414 1.002 2.229 1.555 3.03.456.898.243.832.091.255h.158V9.01l.128-1.706.237-2.095.23-2.695.08-.76.376-.91.747-.492.584.28.48.685-.067.444-.286 1.851-.559 2.903-.364 1.942h.212l.243-.242.985-1.306 1.652-2.064.73-.82.85-.904.547-.431h1.033l.76 1.129-.34 1.166-1.064 1.347-.881 1.142-1.264 1.7-.79 1.36.073.11.188-.02 2.856-.606 1.543-.28 1.841-.315.833.388.091.395-.328.807-1.969.486-2.309.462-3.439.813-.042.03.049.061 1.549.146.662.036h1.622l3.02.225.79.522.474.638-.079.485-1.215.62-1.64-.389-3.829-.91-1.312-.329h-.182v.11l1.093 1.068 2.006 1.81 2.509 2.33.127.578-.322.455-.34-.049-2.205-1.657-.851-.747-1.926-1.62h-.128v.17l.444.649 2.345 3.521.122 1.08-.17.353-.608.213-.668-.122-1.374-1.925-1.415-2.167-1.143-1.943-.14.08-.674 7.254-.316.37-.729.28-.607-.461-.322-.747.322-1.476.389-1.924.315-1.53.286-1.9.17-.632-.012-.042-.14.018-1.434 1.967-2.18 2.945-1.726 1.845-.414.164-.717-.37.067-.662.401-.589 2.388-3.036 1.44-1.882.93-1.086-.006-.158h-.055L4.132 18.56l-1.13.146-.487-.456.061-.746.231-.243 1.908-1.312-.006.006z"

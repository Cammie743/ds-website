  <script>
    (function () {
      function wireDocTabs(root) {
        var tablist = root.querySelector('[role="tablist"]');
        var panelsRoot = root.querySelector(".doc-tabs__panels");
        if (!tablist || !panelsRoot) return;

        var tabs = Array.prototype.slice.call(tablist.querySelectorAll("button.doc-tabs__tab"));
        var panels = Array.prototype.slice.call(panelsRoot.querySelectorAll("section.doc-tabs__panel"));
        if (!tabs.length || tabs.length !== panels.length) return;

        function select(index, updateHash) {
          var n = tabs.length;
          var i = ((index % n) + n) % n;
          for (var j = 0; j < n; j++) {
            var on = j === i;
            tabs[j].setAttribute("aria-selected", String(on));
            tabs[j].tabIndex = on ? 0 : -1;
            panels[j].hidden = !on;
          }

          if (updateHash) {
            var panelId = tabs[i].getAttribute("aria-controls");
            if (panelId) {
              history.replaceState(null, "", "#" + panelId);
            }
          }
        }

        /** Map fragment ids on this page → tab index so copied deep links open the right panel. */
        var hashToTabIndex = {
          "accordion-panel-overview": 0,
          "accordion-overview-resources-h2": 0,
          "accordion-design-when-to-use": 1,
          "accordion-design-when-not-to-use": 1,
          "accordion-panel-guidelines": 1,
          "accordion-design-variants": 1,
          "accordion-design-configurations": 1,
          "accordion-design-best-practices": 1,
          "accordion-panel-content": 2,
          "accordion-design-content-guidelines": 2,
          "accordion-panel-accessibility": 3,
        };

        function getTabIndexFromHash() {
          var id = (window.location.hash || "").replace(/^#/, "");
          if (!id || !Object.prototype.hasOwnProperty.call(hashToTabIndex, id)) return 0;
          return hashToTabIndex[id];
        }

        /* Apply initial tab state as early as possible to reduce refresh flicker. */
        select(getTabIndexFromHash(), false);

        tabs.forEach(function (tab, i) {
          tab.addEventListener("click", function () {
            select(i, true);
          });
          tab.addEventListener("keydown", function (e) {
            if (e.key === "ArrowRight") {
              e.preventDefault();
              select(i + 1, true);
              tabs[(i + 1) % tabs.length].focus();
            } else if (e.key === "ArrowLeft") {
              e.preventDefault();
              select(i - 1, true);
              tabs[(i - 1 + tabs.length) % tabs.length].focus();
            } else if (e.key === "Home") {
              e.preventDefault();
              select(0, true);
              tabs[0].focus();
            } else if (e.key === "End") {
              e.preventDefault();
              select(tabs.length - 1, true);
              tabs[tabs.length - 1].focus();
            }
          });
        });

        function syncTabPanelFromHash(shouldScroll) {
          var id = (window.location.hash || "").replace(/^#/, "");
          if (!id || !Object.prototype.hasOwnProperty.call(hashToTabIndex, id)) return;
          var idx = hashToTabIndex[id];
          select(idx, false);
          if (!shouldScroll) return;
          window.requestAnimationFrame(function () {
            var el = document.getElementById(id);
            if (el && typeof el.scrollIntoView === "function") {
              el.scrollIntoView({ block: "start", behavior: "smooth" });
            }
          });
        }

        window.addEventListener("hashchange", function () {
          syncTabPanelFromHash(true);
        });
        syncTabPanelFromHash(false);
      }

      document.querySelectorAll("[data-doc-tabs]").forEach(wireDocTabs);

    })();

    margin: var(--prism-space-2xl) 0 var(--prism-space-2xl);
    padding: 0;
    min-width: 0;
    width: 100%;
  }

  .doc-preview__media {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    width: 100%;
  }

  .doc-preview__img {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: middle;
    border-radius: 12px;
  }

  .doc-tabs {
    margin-top: 0;
  }

  .doc-tabs__list {
    display: flex;
    flex-wrap: nowrap;
    align-items: flex-end;
    gap: clamp(24px, 5vw, 40px);
    position: sticky;
    top: calc(var(--site-header-sticky-anchor, 72px) + var(--prism-space-sm));
    z-index: 40;
    margin: 0 0 var(--prism-space-lg);
    padding-block: var(--prism-space-sm) 0;
    padding-inline: 0;
    border: 0;
    border-bottom: 1px solid
      var(--prism-color-border-subtle, color-mix(in srgb, var(--prism-color-text-primary) 12%, transparent));
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-x: contain;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .doc-tabs__list::-webkit-scrollbar {
    display: none;
  }

  .doc-tabs__tab {
    flex: 0 0 auto;
    margin: 0 0 -1px;
    cursor: pointer;
    border: none;
    border-radius: 0;
    padding: var(--prism-space-sm) 0 calc(var(--prism-space-sm) + 2px);
    font: inherit;
    font-size: var(--docs-fs-md);
    font-weight: var(--docs-fw-medium);
    letter-spacing: var(--docs-ls-ui);
    line-height: var(--docs-lh-ui);
    color: var(--prism-color-text-secondary);
    background-color: transparent;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .doc-tabs__tab:hover {
    color: var(--prism-color-text-primary);
  }

  .doc-tabs__tab:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .doc-tabs__tab[aria-selected="true"] {
    color: var(--prism-color-text-primary);
    font-weight: var(--docs-fw-semibold);
    border-bottom-color: var(--prism-color-accent-strong);
  }

  @media (max-width: 640px) {
    .doc-tabs__list {
      gap: 20px;
    }
  }

  .doc-tabs__panels {
    box-sizing: border-box;
    width: 100%;
    max-width: 1000px;
    margin-inline: auto;
    padding-top: var(--prism-space-lg);
  }

  .doc-tabs__panel {
    margin: 0;
  }

  .doc-tabs__panel:focus-visible {
    outline: none;
  }

  /* Outer border on shell; inner grid uses separate borders so corners stay cleaner than collapse. */
  .doc-overview-matrix-shell {
    min-width: 0;
    border-radius: var(--prism-radius-md);
    border: 1px solid var(--prism-color-border-subtle);
    overflow: hidden;
    background-color: var(--prism-color-surface);
  }

  .doc-overview-matrix {
    margin: 0;
    border: none;
    border-collapse: separate;
    border-spacing: 0;
  }

  .doc-overview-matrix thead th {
    /* Theme-aware muted band via --prism-color-surface-muted (tokens) */
    background-color: var(--prism-color-surface-muted);
    color: var(--prism-color-text-primary);
    font-weight: var(--docs-fw-semibold);
    font-size: var(--docs-fs-md);
  }

  .doc-overview-matrix thead th:last-child {
    text-align: start;
  }

  .doc-overview-matrix__status-cell {
    text-align: start;
    white-space: nowrap;
  }

  .doc-overview-matrix__resource {
    display: inline-flex;
    align-items: center;
    gap: var(--prism-space-sm);
    max-width: 100%;
    font-weight: var(--docs-fw-medium);
    font-size: var(--docs-fs-md);
    line-height: 1.2;
    color: var(--prism-color-accent);
    text-decoration: none;
  }

  /* Fill the matrix cell so clicks anywhere in the resource column hit the link */
  a.doc-overview-matrix__resource {
    width: 100%;
    box-sizing: border-box;
  }

  a.doc-overview-matrix__resource:hover {
    color: var(--prism-color-accent-strong);
    text-decoration: underline;
    text-underline-offset: 0.12em;
    text-decoration-thickness: 1px;
  }

  a.doc-overview-matrix__resource:focus-visible {
    outline: 2px solid var(--prism-color-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .doc-overview-matrix__resource--text {
    color: var(--prism-color-text-secondary);
    text-decoration: none;
    cursor: default;
  }

  .doc-overview-matrix__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    color: currentColor;
  }

  .doc-overview-matrix__icon svg {
    display: block;
  }

  .doc-overview-matrix__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.28em 0.7em;
    border-radius: var(--prism-radius-sm, 6px);
    font-size: var(--docs-fs-xs);
    font-weight: var(--docs-fw-semibold);
    line-height: 1.2;
    letter-spacing: var(--docs-ls-wide);
  }

  /* Opaque surface mixes — AA 4.5:1+ vs transparent tints on unknown backdrops. */
  .doc-overview-matrix__badge--available {
    background-color: color-mix(in srgb, var(--prism-color-success) 10%, var(--prism-color-surface));
    color: color-mix(in srgb, var(--prism-color-success) 22%, var(--prism-color-text-primary));
  }

  .doc-overview-matrix__badge--planned {
    background-color: color-mix(in srgb, var(--prism-color-warning) 14%, var(--prism-color-surface));
    color: color-mix(in srgb, var(--prism-color-warning) 40%, var(--prism-color-text-primary));
  }

  .doc-overview-matrix__badge--beta {
    background-color: color-mix(in srgb, var(--prism-color-accent) 10%, var(--prism-color-surface));
    color: color-mix(in srgb, var(--prism-color-accent-strong) 28%, var(--prism-color-text-primary));
  }

  .doc-overview-matrix__badge--unavailable {
    background-color: color-mix(in srgb, var(--prism-color-text-primary) 8%, var(--prism-color-surface));
    color: var(--prism-color-text-secondary);
  }

  .doc-tabs__figure {
    margin: var(--prism-space-2xl) 0 0;
    padding: 0;
    min-width: 0;
    width: 100%;
  }

  .doc-tabs .doc-tabs__h2 + .doc-tabs__figure {
    margin-top: var(--prism-space-md);
  }

  .doc-tabs__figure-media {
    overflow: visible;
    box-sizing: border-box;
    width: 100%;
    border: 1px solid var(--prism-color-border-subtle);
    border-radius: var(--prism-radius-md);
  }

  .docs-inline-figure-shell .doc-tabs__figure-media {
    overflow: hidden;
    border: 0;
    border-radius: 0;
  }

  .docs-inline-figure-shell .doc-preview__img {
    border-radius: 0;
  }

  .accordion-variant-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--prism-space-lg);
    align-items: stretch;
    width: 100%;
    min-width: 0;
  }

  @media (min-width: 40rem) {
    .accordion-variant-row {
      grid-template-columns: 1fr 1fr;
      gap: var(--prism-space-lg);
    }
  }

  .accordion-variant-row--config {
    grid-template-columns: 1fr;
  }

  .accordion-variant-column {
    display: flex;
    flex-direction: column;
    gap: var(--prism-space-sm);
    min-width: 0;
  }

  .accordion-variant-box {
    padding: 40px;
    background: var(--prism-color-surface);
    min-width: 0;
  }

  .accordion-variant-demo__example {
    display: flex;
    flex-direction: column;
    min-width: 0;
    box-sizing: border-box;
  }

  .accordion-variant-demo__example-intro {
    display: flex;
    flex-direction: column;
    gap: var(--prism-space-xs);
  }

  .accordion-variant-demo__example-caption {
    margin: 0;
    font-size: var(--docs-text-md-size);
    font-weight: var(--docs-text-md-weight);
    line-height: var(--docs-text-md-line-height);
    color: var(--docs-text-md-color);
  }

  /* Subsection title under “Configurations” — matches doc H3 presence (primary, semibold). */
  .accordion-variant-row--config .accordion-variant-demo__example-caption {
    font-size: var(--docs-fs-xl);
    font-weight: var(--docs-fw-semibold);
    letter-spacing: var(--docs-ls-heading-sm);
    line-height: var(--docs-lh-snug);
    color: var(--prism-color-text-primary);
  }

  .accordion-variant-demo__example-desc {
    margin: 0;
    font-size: var(--docs-fs-base);
    font-weight: var(--docs-fw-regular);
    line-height: var(--docs-text-sm-line-height);
    color: var(--prism-color-text-secondary);
  }

  .accordion-prism-stack {
    width: 100%;
    max-width: 400px;
    margin-inline: auto;
    background: var(--prism-color-surface);
    overflow: visible;
  }

  .accordion-prism-item {
    border-bottom: 1px solid var(--prism-color-border-subtle);
  }

  .accordion-prism-item:first-child {
    border-top: 1px solid var(--prism-color-border-subtle);
  }

  .accordion-prism-item:has(.accordion-prism-info-wrap:hover),
  .accordion-prism-item:has(.accordion-prism-info-wrap:focus-within) {
    position: relative;
    z-index: 100;
  }

  .accordion-prism-summary {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--prism-space-sm);
    width: 100%;
    box-sizing: border-box;
    margin: 0;
    min-height: calc(4px + 32px + 4px);
    padding: 4px var(--prism-space-sm);
    cursor: pointer;
    list-style: none;
    font-family: var(--prism-font-sans);
    font-weight: var(--docs-fw-semibold);
    font-size: var(--docs-fs-sm);
    line-height: 1.28571429;
    letter-spacing: var(--docs-ls-subtle);
    color: var(--prism-color-text-primary);
    background: transparent;
  }

  .accordion-prism-summary > * {
    position: relative;
    z-index: 1;
  }

  .accordion-prism-summary::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 4px;
    height: 32px;
    z-index: 0;
    border-radius: 8px;
    background-color: transparent;
    pointer-events: none;
    transition: background-color 0.15s ease;
  }

  .accordion-prism-summary:hover::before,
  .accordion-prism-summary:focus-visible::before {
    background-color: color-mix(in srgb, var(--prism-color-text-primary) 4%, transparent);
  }

  .accordion-prism-summary::-webkit-details-marker {
    display: none;
  }

  .accordion-prism-summary::marker {
    content: "";
  }

  .accordion-prism-summary:focus-visible {
    outline: none;
    border-radius: 12px;
  }

  .accordion-prism-summary:focus-visible::after {
    content: "";
    position: absolute;
    box-sizing: border-box;
    top: 0;
    right: -4px;
    bottom: 0;
    left: -4px;
    border: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    border-radius: 12px;
    pointer-events: none;
    z-index: 0;
  }

  .accordion-prism-summary--trailing {
    justify-content: space-between;
  }

  .accordion-prism-summary--trailing .accordion-prism-label {
    flex: 1;
    min-width: 0;
    text-align: start;
  }

  .accordion-prism-summary--with-info {
    justify-content: space-between;
    gap: var(--prism-space-sm);
  }

  .accordion-prism-summary-start {
    display: flex;
    align-items: center;
    gap: 6px;
    flex: 1 1 auto;
    min-width: 0;
  }

  .accordion-prism-summary--with-info .accordion-prism-label {
    flex: 0 1 auto;
    min-width: 0;
  }

  .accordion-prism-info-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    margin: 0;
    padding: 0;
    border: none;
    border-radius: 999px;
    color: var(--prism-color-text-secondary);
    background-color: transparent;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .accordion-prism-info-btn:hover {
    background-color: color-mix(in srgb, var(--prism-color-text-primary) 6%, transparent);
  }

  .accordion-prism-info-btn:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--prism-color-accent-strong) 45%, transparent);
    outline-offset: 2px;
  }

  .accordion-prism-info-wrap {
    position: relative;
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    vertical-align: middle;
  }

  .accordion-prism-info-popover {
    position: absolute;
    z-index: 1000;
    top: auto;
    bottom: calc(100% + var(--prism-space-sm));
    left: 50%;
    transform: translateX(-50%);
    box-sizing: border-box;
    /* Icon wrap is narrow; explicit width avoids shrink-to-fit using that CB and over-wrapping. */
    width: 17rem;
    max-width: calc(100vw - 2rem);
    padding: var(--prism-space-lg);
    border-radius: 16px;
    border: 1px solid var(--prism-color-border-subtle);
    background-color: var(--prism-color-surface);
    color: var(--prism-color-text-primary);
    font-family: var(--prism-font-sans);
    font-size: var(--docs-fs-sm);
    font-weight: var(--docs-fw-regular);
    line-height: calc(18 / 14);
    letter-spacing: var(--docs-ls-label);
    text-align: start;
    pointer-events: none;
    box-shadow:
      0 6px 12px color-mix(in srgb, var(--prism-color-text-primary) 8%, transparent),
      0 12px 24px color-mix(in srgb, var(--prism-color-text-primary) 8%, transparent);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.15s ease,
      visibility 0.15s ease;
  }

  .accordion-prism-info-popover::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: -6px;
    transform: translateX(-50%);
    border-left: 12px solid transparent;
    border-right: 12px solid transparent;
    border-top: 11px solid var(--prism-color-surface);
    pointer-events: none;
  }

  .accordion-prism-info-wrap:hover .accordion-prism-info-popover,
  .accordion-prism-info-wrap:focus-within .accordion-prism-info-popover {
    opacity: 1;
    visibility: visible;
  }

  .accordion-prism-info-icon {
    display: block;
    width: 18px;
    height: 18px;
  }

  .accordion-prism-chevron--muted {
    color: var(--prism-color-text-secondary);
  }

  .accordion-prism-label {
    flex: 1;
    min-width: 0;
  }

  .accordion-prism-chevron {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    color: currentColor;
    transform: rotate(0deg);
    transform-origin: 50% 50%;
    transition: transform 0.2s ease;
  }

  .accordion-prism-item[open] .accordion-prism-chevron {
    transform: rotate(90deg);
  }

  .accordion-prism-chevron-svg {
    display: block;
    width: 16px;
    height: 16px;
  }

  .accordion-prism-panel {
    padding: 0 0 var(--prism-space-md) var(--prism-space-sm);
  }

  /* Align body copy with the label column (past chevron + gap), matching summary row metrics */
  .accordion-variant-demo__example--leading .accordion-prism-panel {
    padding-left: calc(var(--prism-space-sm) + 20px + var(--prism-space-sm));
  }

  .accordion-prism-panel-copy {
    margin: 0;
    padding-top: 0;
    padding-bottom: 0;
    font-size: var(--docs-fs-sm);
    font-weight: var(--docs-fw-regular);
    line-height: 1.28571429;
    color: var(--prism-color-text-secondary);
  }

  .accordion-usage-label {
    color: var(--prism-color-text-primary);
    font-weight: var(--docs-fw-semibold);
  }

  .accordion-usage-list,
  .accordion-usage-list li {
    color: var(--prism-color-text-secondary);
  }

  .accordion-usage-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--prism-space-xl);
    align-items: start;
  }

  @media (max-width: 52rem) {
    .accordion-usage-grid {
      grid-template-columns: 1fr;
    }
  }

  .doc-tabs__figure + .doc-overview-matrix-shell {
    margin-top: var(--prism-space-xl);
  }

  .doc-tabs__table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--docs-fs-base);
    line-height: 1.5;
  }

  .doc-tabs__table-caption {
    caption-side: top;
    text-align: start;
    margin-bottom: var(--prism-space-md);
    padding: 0;
    font-size: var(--docs-fs-md);
    font-weight: var(--docs-fw-semibold);
    color: var(--prism-color-text-primary);
  }

  .doc-tabs__table th,
  .doc-tabs__table td {
    padding: var(--prism-space-md) var(--prism-space-lg);
    text-align: start;
    vertical-align: top;
    border: 1px solid var(--prism-color-border-subtle);
  }

  /* Separate borders + single 1px seams: cleaner corners than collapse inside a rounded clip. */
  .doc-tabs__table.doc-overview-matrix th,
  .doc-tabs__table.doc-overview-matrix td {
    border: 0 solid var(--prism-color-border-subtle);
    border-right-width: 1px;
    border-bottom-width: 1px;
  }

  .doc-tabs__table.doc-overview-matrix thead th {
    border-top-width: 0;
  }

  .doc-tabs__table.doc-overview-matrix tr > :first-child {
    border-left-width: 0;
  }

  .doc-tabs__table.doc-overview-matrix tr > :last-child {
    border-right-width: 0;
  }

  .doc-tabs__table.doc-overview-matrix tbody tr:last-child th,
  .doc-tabs__table.doc-overview-matrix tbody tr:last-child td {
    border-bottom-width: 0;
  }

  .doc-tabs__table thead th {
    background-color: var(--prism-color-surface-muted);
    color: var(--prism-color-text-primary);
    font-weight: var(--docs-fw-semibold);
  }

  .doc-tabs__table tbody th {
    background-color: color-mix(in srgb, var(--prism-color-text-primary) 3%, var(--prism-color-surface));
    color: var(--prism-color-text-primary);
    font-weight: var(--docs-fw-semibold);
  }

  .doc-tabs__table tbody td {
    color: var(--prism-color-text-secondary);
  }

  .doc-tabs__table.doc-overview-matrix tbody th.doc-overview-matrix__type {
    width: var(--docs-table-first-column-width);
    max-width: var(--docs-table-first-column-max);
    background-color: var(--prism-color-surface);
    color: var(--prism-color-text-secondary);
    font-weight: var(--docs-fw-regular);
    font-size: var(--docs-fs-md);
    line-height: var(--docs-lh-snug);
    vertical-align: middle;
  }

  @media (max-width: 640px) {
    .doc-tabs__table.doc-overview-matrix--guidelines {
      table-layout: fixed;
    }

    .doc-tabs__table.doc-overview-matrix--guidelines th,
    .doc-tabs__table.doc-overview-matrix--guidelines td {
      padding-inline: var(--prism-space-sm);
    }

    .doc-tabs__table.doc-overview-matrix--guidelines thead th:first-child,
    .doc-tabs__table.doc-overview-matrix--guidelines tbody th.doc-overview-matrix__type {
      width: 40%;
      max-width: none;
    }

    .doc-tabs__table.doc-overview-matrix--guidelines thead th:last-child,
    .doc-tabs__table.doc-overview-matrix--guidelines td.doc-overview-matrix__resource-cell {
      width: 60%;
    }

    .doc-tabs__table.doc-overview-matrix--resources {
      table-layout: fixed;
    }

    .doc-tabs__table.doc-overview-matrix--resources th,
    .doc-tabs__table.doc-overview-matrix--resources td {
      padding-inline: var(--prism-space-md);
    }

    .doc-tabs__table.doc-overview-matrix--resources thead th:first-child,
    .doc-tabs__table.doc-overview-matrix--resources tbody th.doc-overview-matrix__type {
      width: 32%;
      max-width: none;
    }

    .doc-tabs__table.doc-overview-matrix--resources thead th:nth-child(2),
    .doc-tabs__table.doc-overview-matrix--resources td.doc-overview-matrix__resource-cell {
      width: 38%;
    }

    .doc-tabs__table.doc-overview-matrix--resources thead th:last-child,
    .doc-tabs__table.doc-overview-matrix--resources td.doc-overview-matrix__status-cell {
      width: 30%;
    }
  }

  .doc-tabs__table.doc-overview-matrix td.doc-overview-matrix__type-spacer {
    vertical-align: middle;
    background-color: var(--prism-color-surface);
  }

  /* Grouped Type column only: hide internal horizontal rules. Resource + Status keep row dividers. */
  .doc-overview-matrix tr.doc-overview-matrix__row--impl:not(.doc-overview-matrix__row--impl-last) th.doc-overview-matrix__type,
  .doc-overview-matrix tr.doc-overview-matrix__row--impl:not(.doc-overview-matrix__row--impl-last) td.doc-overview-matrix__type-spacer {
    border-bottom: none;
  }

  .doc-overview-matrix tr.doc-overview-matrix__row--impl + tr.doc-overview-matrix__row--impl th.doc-overview-matrix__type,
  .doc-overview-matrix tr.doc-overview-matrix__row--impl + tr.doc-overview-matrix__row--impl td.doc-overview-matrix__type-spacer {
    border-top: none;
  }

  .doc-overview-matrix tr.doc-overview-matrix__row--design:not(.doc-overview-matrix__row--design-last) th.doc-overview-matrix__type,
  .doc-overview-matrix tr.doc-overview-matrix__row--design:not(.doc-overview-matrix__row--design-last) td.doc-overview-matrix__type-spacer {
    border-bottom: none;
  }

  .doc-overview-matrix tr.doc-overview-matrix__row--design + tr.doc-overview-matrix__row--design th.doc-overview-matrix__type,
  .doc-overview-matrix tr.doc-overview-matrix__row--design + tr.doc-overview-matrix__row--design td.doc-overview-matrix__type-spacer {

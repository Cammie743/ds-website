                  </td>
                  <td class="doc-overview-matrix__status-cell" headers="accordion-overview-type-ai">
                    <div class="doc-overview-matrix__cell-align">
                      <span class="doc-overview-matrix__badge doc-overview-matrix__badge--beta">
                        <span data-i18n="components.accordion.overview.statusBeta">Beta</span>
                      </span>
                    </div>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>
      <section
        class="doc-tabs__panel"
        id="accordion-panel-design"
        role="tabpanel"
        aria-labelledby="accordion-tab-design"
        tabindex="0"
        hidden
      >
        <DocH2WithAnchor
          id="accordion-design-variants"
          rowClass="doc-h2-anchor-row--tabs"
          class="doc-tabs__h2"
          data-i18n="components.accordion.design.variantsH2"
        >
          Variants
        </DocH2WithAnchor>
        <p class="doc-tabs__panel-copy" data-i18n="components.accordion.design.variantsBody">
          There are 2 variants available for accordion - Leading and trailing chevron.
        </p>
        <div class="doc-tabs__figure">
          <div
            class="accordion-variant-row"
            role="group"
            aria-label="Interactive examples: leading and trailing chevron accordions"
            data-i18n-aria="components.accordion.design.demoAria"
          >
            <div class="accordion-variant-column">
              <h3 class="accordion-variant-demo__example-title" data-i18n="components.accordion.design.demoLeadingTitle">
                Leading chevron
              </h3>
              <div
                class="doc-tabs__figure-media accordion-variant-box"
                role="region"
                aria-label="Leading chevron accordion example"
                data-i18n-aria="components.accordion.design.demoLeadingAria"
              >
                <div class="accordion-variant-demo__example accordion-variant-demo__example--leading">
                  <div class="accordion-prism-stack">
                  <details class="accordion-prism-item">
                    <summary class="accordion-prism-summary accordion-prism-summary--leading">
                      <span class="accordion-prism-chevron" aria-hidden="true">
                        <svg
                          class="accordion-prism-chevron-svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="m9 18 6-6-6-6"></path>
                        </svg>
                      </span>
                      <span class="accordion-prism-label" data-i18n="components.accordion.design.demoSummary1">
                        Billing overview
                      </span>
                    </summary>
                    <div class="accordion-prism-panel">
                      <p class="accordion-prism-panel-copy" data-i18n="components.accordion.design.demoBody1">
                        Review line items, tax, and payment method before submitting. You can return here while the
                        order is still open.
                      </p>
                    </div>
                  </details>
                  <details class="accordion-prism-item">
                    <summary class="accordion-prism-summary accordion-prism-summary--leading">
                      <span class="accordion-prism-chevron" aria-hidden="true">
                        <svg
                          class="accordion-prism-chevron-svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="m9 18 6-6-6-6"></path>
                        </svg>
                      </span>
                      <span class="accordion-prism-label" data-i18n="components.accordion.design.demoSummary2">
                        Shipping and delivery
                      </span>
                    </summary>
                    <div class="accordion-prism-panel">
                      <p class="accordion-prism-panel-copy" data-i18n="components.accordion.design.demoBody2">
                        Delivery estimates update when your address or items change. Expand this panel for carrier
                        options and tracking details.
                      </p>
                    </div>
                  </details>
                  <details class="accordion-prism-item">
                    <summary class="accordion-prism-summary accordion-prism-summary--leading">
                      <span class="accordion-prism-chevron" aria-hidden="true">
                        <svg
                          class="accordion-prism-chevron-svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="m9 18 6-6-6-6"></path>
                        </svg>
                      </span>
                      <span class="accordion-prism-label" data-i18n="components.accordion.design.demoSummary3">
                        Returns and exchanges
                      </span>
                    </summary>
                    <div class="accordion-prism-panel">
                      <p class="accordion-prism-panel-copy" data-i18n="components.accordion.design.demoBody3">
                        See eligible items, return windows, and how refunds post to your original payment method.
                      </p>
                    </div>

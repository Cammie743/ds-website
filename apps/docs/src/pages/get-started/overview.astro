---
import GetStartedLayout from "../../layouts/GetStartedLayout.astro";
---

<GetStartedLayout
  title="Get started"
  current="overview"
  description="How the Get started section is organized and where to go next."
>
  <header class="page-head">
    <h1 data-i18n="getStarted.overview.h1">Get started</h1>
    <p class="intro" data-i18n="getStarted.overview.intro">
      This section explains why Prism exists, how we make design decisions, the vocabulary we use in files
      and reviews, and answers to common onboarding questions.
    </p>
  </header>

  <nav class="block" aria-labelledby="get-started-overview-toc">
    <h2 class="sr-only" id="get-started-overview-toc" data-i18n="getStarted.overview.tocHeading">Pages in this section</h2>
    <ul class="toc-list">
      <li>
        <a href="/get-started/mission" data-i18n="getStarted.toc.mission">Mission</a>
      </li>
      <li>
        <a href="/get-started/principles" data-i18n="getStarted.toc.principles">Design principles</a>
      </li>
      <li>
        <a href="/get-started/language" data-i18n="getStarted.toc.language">Design language</a>
      </li>
      <li>
        <a href="/get-started/faq" data-i18n="getStarted.toc.faq">FAQs</a>
      </li>
    </ul>
  </nav>

  <p class="next">
    <a class="next-link" href="/get-started/mission" data-i18n="getStarted.overview.nextMission">Begin with Mission</a>
  </p>
</GetStartedLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .block {
    margin-bottom: var(--prism-space-xl);
  }

  .toc-list {
    list-style: none;
    margin: var(--prism-space-lg) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--prism-space-sm);
  }

  .toc-list a {
    font-weight: 600;
    text-decoration: none;
    color: var(--prism-color-accent-strong);
  }

  .toc-list a:hover {
    text-decoration: underline;
  }
</style>

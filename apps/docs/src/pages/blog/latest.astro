---
import BlogLayout from "../../layouts/BlogLayout.astro";
import BlogUpdateArticle from "../../components/blog/BlogUpdateArticle.astro";
---

<BlogLayout title="Latest updates" current="latest" description="Recent release notes and product updates from the Prism team.">
  <header class="page-head">
    <h1 data-i18n="blog.nav.latest">Latest updates</h1>
    <p class="intro" data-i18n="blog.lede">
      Release notes, deep dives, and product updates from the Prism team.
    </p>
  </header>
  <div class="blog-posts">
    <BlogUpdateArticle id="update-theme-previews" updateN={2} isFirstInPage />
    <BlogUpdateArticle id="update-foundations-ia" updateN={3} />
    <BlogUpdateArticle id="update-search-docs" updateN={4} />
    <BlogUpdateArticle id="update-usage-metrics" updateN={5} />
    <BlogUpdateArticle id="update-a11y-checklist" updateN={6} />
  </div>
</BlogLayout>

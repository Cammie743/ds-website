---
import { BLOG_UPDATE_SLUG_BY_N, getBlogUpdatePostPathByPostId } from "../../../data/blogUpdates";

export function getStaticPaths() {
  return (Object.values(BLOG_UPDATE_SLUG_BY_N) as string[]).map((slug) => ({
    params: { slug },
  }));
}

const legacy = Astro.params.slug;
const target = legacy ? getBlogUpdatePostPathByPostId(legacy) : undefined;
if (!target) return new Response(null, { status: 404 });
return Astro.redirect(target, 301);
---

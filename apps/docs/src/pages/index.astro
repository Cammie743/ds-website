---
import BaseLayout from "../layouts/BaseLayout.astro";
import DocH2WithAnchor from "../components/DocH2WithAnchor.astro";
import { getBlogUpdatePostPath } from "../data/blogUpdates";
---

<BaseLayout title="Prism">
  <div class="home-root">
    <section class="h-hero" aria-labelledby="home-title">
      <h1 id="home-title" class="h-hero__title home-rise" data-i18n="home.title">Prism Design</h1>
      <p class="h-hero__lede home-rise home-rise--2" data-i18n="home.lede">
        Prism Design 3 is Zoom's design system that helps teams build better product experiences, faster.
      </p>
      <div class="h-hero__actions home-rise home-rise--3">
        <a class="h-btn h-btn--filled" href="/get-started/overview">
          <span class="h-btn__surface" aria-hidden="true"></span>
          <span class="h-btn__content">
            <span data-i18n="home.btn.getStarted">Get started</span>
            <span class="h-btn__arrow" aria-hidden="true">→</span>
          </span>
        </a>
      </div>
    </section>

    <section class="h-updates" aria-labelledby="updates-heading">
      <div class="h-updates__head">
        <div class="h-updates__head-main">
          <DocH2WithAnchor id="updates-heading" class="h-updates__h" data-i18n="home.updates.sectionTitle">
            Latest and greatest from Prism
          </DocH2WithAnchor>
          <a class="h-updates__view-all" href="/articles/latest">
            <span class="h-updates__view-all__label" data-i18n="home.updates.viewAll">Explore all blogs</span>
            <span class="h-updates__view-all__arrow" aria-hidden="true">
              <svg
                class="h-updates__view-all__arrow-icon"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  d="M7 7h10v10"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <path
                  d="M7 17 17 7"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </span>
          </a>
        </div>
      </div>
      <div
        class="h-updates-carousel home-rise home-rise--6"
        data-updates-carousel
        role="region"
        aria-roledescription="carousel"
        aria-labelledby="updates-heading"
      >
        <div class="h-updates-carousel__toolbar">
          <fieldset class="view-segmented h-updates-carousel__filter" data-updates-filter>
            <legend class="view-segmented__legend">
              <span data-i18n="home.updates.filterLegend">Filter updates</span>
            </legend>
            <div class="view-segmented__inner">
              <input
                class="view-segmented__input"
                type="radio"
                name="home-updates-filter"
                id="home-updates-filter-all"
                value="all"
                checked
              />
              <label class="view-segmented__label" for="home-updates-filter-all">
                <span data-i18n="home.updates.filterAll">All latest</span>
              </label>
              <input
                class="view-segmented__input"
                type="radio"
                name="home-updates-filter"
                id="home-updates-filter-feature"
                value="feature"
              />
              <label class="view-segmented__label" for="home-updates-filter-feature">
                <span data-i18n="home.updates.filterFeature">Feature</span>
              </label>
              <input
                class="view-segmented__input"
                type="radio"
                name="home-updates-filter"
                id="home-updates-filter-update"
                value="update"
              />
              <label class="view-segmented__label" for="home-updates-filter-update">
                <span data-i18n="home.updates.filterUpdate">Update</span>
              </label>
            </div>
          </fieldset>
          <div class="h-updates-carousel__btn-row">
            <button
              type="button"
              class="icon-btn h-updates-carousel__btn"
              data-carousel-prev
              aria-controls="updates-carousel-viewport"
              data-i18n-aria="home.updates.carouselPrev"
              data-i18n-tooltip="home.updates.carouselPrevTip"
              data-tooltip="Previous"
              aria-label="Previous updates"
            >
              <svg
                class="icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M19 12H5"></path>
                <path d="m12 19-7-7 7-7"></path>
              </svg>
            </button>
            <button
              type="button"
              class="icon-btn h-updates-carousel__btn"
              data-carousel-next
              aria-controls="updates-carousel-viewport"
              data-i18n-aria="home.updates.carouselNext"
              data-i18n-tooltip="home.updates.carouselNextTip"
              data-tooltip="Next"
              aria-label="Next updates"
            >
              <svg
                class="icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            </button>
          </div>
        </div>
        <div id="updates-carousel-viewport" class="h-updates-carousel__viewport" data-carousel-viewport>
          <ol class="h-updates-carousel__list">
            <li class="h-updates-carousel__slide" data-updates-kind="update">
              <a class="h-updates-card" href={getBlogUpdatePostPath(1)}>
                <div class="h-updates-card__media">
                  <img
                    class="h-updates-card__img"
                    src="/images/articles/article-1/article-1-hero.jpg"
                    width="1024"
                    height="601"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.1.alt"
                  />
                </div>
                <div class="h-updates-card__meta">
                  <time class="h-updates-card__date" datetime="2026-04-17" data-i18n="home.updates.1.date">April 17, 2026</time>
                </div>
                <span class="h-updates-card__title">
                  <span class="h-updates-card__title-text" data-stagger-title-underline data-i18n="home.updates.1.title"
                    >April release: Figma library updates for v2.5</span>
                </span>
                <p class="h-updates-card__desc"><span class="h-updates-card__desc-text" data-i18n="home.updates.1.body">
                  New button variants, icons, bug fixes, updated colors, and more.
                </span></p>
                <div class="h-updates-card__author">
                  <img
                    class="h-updates-card__author-avatar"
                    src="/images/prism-library/avatars/april-2026-update.png"
                    width="64"
                    height="64"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.1.authorAvatarAlt"
                  />
                  <span class="h-updates-card__author-name" data-i18n="home.updates.1.authorName">Cam Foster</span>
                </div>
              </a>
            </li>
            <li class="h-updates-carousel__slide" data-updates-kind="feature">
              <a class="h-updates-card" href={getBlogUpdatePostPath(2)}>
                <div class="h-updates-card__media">
                  <img
                    class="h-updates-card__img"
                    src="/images/articles/article-2/article-2.svg"
                    width="640"
                    height="360"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.2.alt"
                  />
                </div>
                <div class="h-updates-card__meta">
                  <time class="h-updates-card__date" datetime="2026-04-01" data-i18n="home.updates.2.date">April 1, 2026</time>
                </div>
                <span class="h-updates-card__title">
                  <span class="h-updates-card__title-text" data-stagger-title-underline data-i18n="home.updates.2.title">Home and navigation refresh</span>
                </span>
                <p class="h-updates-card__desc"><span class="h-updates-card__desc-text" data-i18n="home.updates.2.body">
                  Clearer paths into foundations, components, and bilingual documentation.
                </span></p>
                <div class="h-updates-card__author">
                  <img
                    class="h-updates-card__author-avatar"
                    src="/images/prism-library/avatars/rowan-vega.png"
                    width="64"
                    height="64"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.2.authorAvatarAlt"
                  />
                  <span class="h-updates-card__author-name" data-i18n="home.updates.2.authorName">Rowan Vega</span>
                </div>
              </a>
            </li>
            <li class="h-updates-carousel__slide" data-updates-kind="update">
              <a class="h-updates-card" href={getBlogUpdatePostPath(3)}>
                <div class="h-updates-card__media">
                  <img
                    class="h-updates-card__img"
                    src="/images/articles/article-3/article-3.svg"
                    width="640"
                    height="360"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.3.alt"
                  />
                </div>
                <div class="h-updates-card__meta">
                  <time class="h-updates-card__date" datetime="2026-03-01" data-i18n="home.updates.3.date">March 1, 2026</time>
                </div>
                <span class="h-updates-card__title">
                  <span class="h-updates-card__title-text" data-stagger-title-underline data-i18n="home.updates.3.title">Theme previews across the site</span>
                </span>
                <p class="h-updates-card__desc"><span class="h-updates-card__desc-text" data-i18n="home.updates.3.body">
                  Bloom, Agave, and Rose palettes help stress-test semantic color tokens in context.
                </span></p>
                <div class="h-updates-card__author">
                  <img
                    class="h-updates-card__author-avatar"
                    src="/images/prism-library/avatars/kenji-park.png"
                    width="64"
                    height="64"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.3.authorAvatarAlt"
                  />
                  <span class="h-updates-card__author-name" data-i18n="home.updates.3.authorName">Kenji Park</span>
                </div>
              </a>
            </li>
            <li class="h-updates-carousel__slide" data-updates-kind="update">
              <a class="h-updates-card" href={getBlogUpdatePostPath(4)}>
                <div class="h-updates-card__media">
                  <img
                    class="h-updates-card__img"
                    src="/images/articles/article-4/article-4.svg"
                    width="640"
                    height="360"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.4.alt"
                  />
                </div>
                <div class="h-updates-card__meta">
                  <time class="h-updates-card__date" datetime="2026-02-01" data-i18n="home.updates.4.date">February 1, 2026</time>
                </div>
                <span class="h-updates-card__title">
                  <span class="h-updates-card__title-text" data-stagger-title-underline data-i18n="home.updates.4.title">Foundations and components IA</span>
                </span>
                <p class="h-updates-card__desc"><span class="h-updates-card__desc-text" data-i18n="home.updates.4.body">
                  Structured foundations pages and a public checklist as the library grows.
                </span></p>
                <div class="h-updates-card__author">
                  <img
                    class="h-updates-card__author-avatar"
                    src="/images/prism-library/avatars/ellis-mercer.png"
                    width="64"
                    height="64"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.4.authorAvatarAlt"
                  />
                  <span class="h-updates-card__author-name" data-i18n="home.updates.4.authorName">Ellis Mercer</span>
                </div>
              </a>
            </li>
            <li class="h-updates-carousel__slide" data-updates-kind="update">
              <a class="h-updates-card" href={getBlogUpdatePostPath(5)}>
                <div class="h-updates-card__media">
                  <img
                    class="h-updates-card__img"
                    src="/images/articles/article-5/article-5.svg"
                    width="640"
                    height="360"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.5.alt"
                  />
                </div>
                <div class="h-updates-card__meta">
                  <time class="h-updates-card__date" datetime="2026-01-15" data-i18n="home.updates.5.date">January 15, 2026</time>
                </div>
                <span class="h-updates-card__title">
                  <span class="h-updates-card__title-text" data-stagger-title-underline data-i18n="home.updates.5.title">Search across documentation</span>
                </span>
                <p class="h-updates-card__desc"><span class="h-updates-card__desc-text" data-i18n="home.updates.5.body">
                  The global search drawer now indexes foundations, components, and get-started pages with bilingual
                  snippets and clearer result grouping.
                </span></p>
                <div class="h-updates-card__author">
                  <img
                    class="h-updates-card__author-avatar"
                    src="/images/prism-library/avatars/calvin-rhodes.png"
                    width="64"
                    height="64"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.5.authorAvatarAlt"
                  />
                  <span class="h-updates-card__author-name" data-i18n="home.updates.5.authorName">Calvin Rhodes</span>
                </div>
              </a>
            </li>
            <li class="h-updates-carousel__slide" data-updates-kind="update">
              <a class="h-updates-card" href={getBlogUpdatePostPath(6)}>
                <div class="h-updates-card__media">
                  <img
                    class="h-updates-card__img"
                    src="/images/articles/article-6/article-6.svg"
                    width="640"
                    height="360"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.6.alt"
                  />
                </div>
                <div class="h-updates-card__meta">
                  <time class="h-updates-card__date" datetime="2025-12-08" data-i18n="home.updates.6.date">December 8, 2025</time>
                </div>
                <span class="h-updates-card__title">
                  <span class="h-updates-card__title-text" data-stagger-title-underline data-i18n="home.updates.6.title">Component usage metrics</span>
                </span>
                <p class="h-updates-card__desc"><span class="h-updates-card__desc-text" data-i18n="home.updates.6.body">
                  We published an opt-in specification for measuring Prism adoption in host apps without collecting
                  end-user PII.
                </span></p>
                <div class="h-updates-card__author">
                  <img
                    class="h-updates-card__author-avatar"
                    src="/images/prism-library/avatars/amari-okoro.png"
                    width="64"
                    height="64"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.6.authorAvatarAlt"
                  />
                  <span class="h-updates-card__author-name" data-i18n="home.updates.6.authorName">Amari Okoro</span>
                </div>
              </a>
            </li>
            <li class="h-updates-carousel__slide" data-updates-kind="update">
              <a class="h-updates-card" href={getBlogUpdatePostPath(7)}>
                <div class="h-updates-card__media">
                  <img
                    class="h-updates-card__img"
                    src="/images/articles/article-7/article-7.svg"
                    width="640"
                    height="360"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.7.alt"
                  />
                </div>
                <div class="h-updates-card__meta">
                  <time class="h-updates-card__date" datetime="2025-11-20" data-i18n="home.updates.7.date">November 20, 2025</time>
                </div>
                <span class="h-updates-card__title">
                  <span class="h-updates-card__title-text" data-stagger-title-underline data-i18n="home.updates.7.title">Accessibility audit checklist</span>
                </span>
                <p class="h-updates-card__desc"><span class="h-updates-card__desc-text" data-i18n="home.updates.7.body">
                  A WCAG 2.2 AA-oriented checklist maps Prism components to keyboard, contrast, and assistive-tech
                  expectations for audits.
                </span></p>
                <div class="h-updates-card__author">
                  <img
                    class="h-updates-card__author-avatar"
                    src="/images/prism-library/avatars/sofia-delgado.png"
                    width="64"
                    height="64"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.7.authorAvatarAlt"
                  />
                  <span class="h-updates-card__author-name" data-i18n="home.updates.7.authorName">Sofia Delgado</span>
                </div>
              </a>
            </li>
          </ol>
        </div>
      </div>
    </section>

    <section class="h-inside" aria-labelledby="inside-heading">
      <header class="h-inside__head home-rise home-rise--6">
        <DocH2WithAnchor id="inside-heading" class="h-inside__h" data-i18n="home.inside.heading">What's inside</DocH2WithAnchor>
        <p class="h-inside__intro" data-i18n="home.inside.intro">
          Foundations, components, content, and resources—everything documented here is built to move in sync from
          design to production.
        </p>
      </header>
      <ul class="h-inside__list">
        <li class="home-rise home-rise--7">
          <a class="h-inside__card" href="/foundations/overview">
            <span class="h-inside__icon-wrap h-inside__icon-wrap--foundations" aria-hidden="true">
              <svg class="h-inside__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z"></path>
              </svg>
            </span>
            <span class="h-inside__name" data-i18n="home.card.foundations.title">Foundations</span>
            <span class="h-inside__desc" data-i18n="home.card.foundations.body">
              Color, typography, spacing, and elevation — the core elements that create a unified visual language.
            </span>
            <span class="h-inside__cta">
              <span class="h-inside__cta__label" data-i18n="home.card.foundations.cta">Explore</span>
              <span class="h-inside__cta__arrow" aria-hidden="true">
                <svg
                  class="h-inside__cta__arrow-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <path
                    d="M7 7h10v10"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <path
                    d="M7 17 17 7"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
            </span>
          </a>
        </li>
        <li class="home-rise home-rise--8">
          <a class="h-inside__card" href="/components/overview">
            <span class="h-inside__icon-wrap h-inside__icon-wrap--components" aria-hidden="true">
              <svg class="h-inside__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"></path>
              </svg>
            </span>
            <span class="h-inside__name" data-i18n="home.card.components.title">Components</span>
            <span class="h-inside__desc" data-i18n="home.card.components.body">
              Reusable building blocks designed and coded to be flexible, accessible, and scalable.
            </span>
            <span class="h-inside__cta">
              <span class="h-inside__cta__label" data-i18n="home.card.components.cta">Browse</span>
              <span class="h-inside__cta__arrow" aria-hidden="true">
                <svg
                  class="h-inside__cta__arrow-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <path
                    d="M7 7h10v10"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <path
                    d="M7 17 17 7"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
            </span>
          </a>
        </li>
        <li class="home-rise home-rise--9">
          <a class="h-inside__card" href="/articles/latest">
            <span class="h-inside__icon-wrap h-inside__icon-wrap--content" aria-hidden="true">
              <svg class="h-inside__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path>
              </svg>
            </span>
            <span class="h-inside__name" data-i18n="home.card.content.title">Content</span>
            <span class="h-inside__desc" data-i18n="home.card.content.body">
              Writing guidelines and best practices so your product speaks with one clear, consistent voice.
            </span>
            <span class="h-inside__cta">
              <span class="h-inside__cta__label" data-i18n="home.card.content.cta">Read</span>
              <span class="h-inside__cta__arrow" aria-hidden="true">
                <svg
                  class="h-inside__cta__arrow-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <path
                    d="M7 7h10v10"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <path
                    d="M7 17 17 7"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
            </span>
          </a>
        </li>
        <li class="home-rise home-rise--10">
          <a class="h-inside__card" href="/resources/overview">
            <span class="h-inside__icon-wrap h-inside__icon-wrap--resources" aria-hidden="true">
              <svg class="h-inside__icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path

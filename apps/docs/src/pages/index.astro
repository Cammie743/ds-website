    z-index: 1;
    box-sizing: border-box;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform, opacity;
    /* Inherits label color from .h-btn → soft tinted ink (MD3-style) */
    background: color-mix(in srgb, currentColor 34%, transparent);
    box-shadow: 0 0 28px color-mix(in srgb, currentColor 14%, transparent);
    opacity: 0.5;
    transform: scale(0);
  }

  .home-root a.h-btn .h-btn__ripple.h-btn__ripple--press {
    animation: h-btnRipplePress 0.48s cubic-bezier(0.2, 0, 0.2, 1) forwards;
  }

  @keyframes h-btnRipplePress {
    0% {
      transform: scale(0);
      opacity: 0.48;
    }
    100% {
      transform: scale(1);
      opacity: 0.36;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-root a.h-btn .h-btn__ripple {
      display: none !important;
    }
  }
</style>

<script>
  function initUpdatesCarousel() {
    var root = document.querySelector("[data-updates-carousel]");
    if (!root) return;
    var viewport = root.querySelector("[data-carousel-viewport]");
    var list = viewport && viewport.querySelector(".h-updates-carousel__list");
    var prev = root.querySelector("[data-carousel-prev]");
    var next = root.querySelector("[data-carousel-next]");
    if (!viewport || !list || !prev || !next) return;

    var allSlides = Array.prototype.slice.call(
      list.querySelectorAll(":scope > .h-updates-carousel__slide:not(.h-updates-carousel__slide--clone)")
    );
    if (allSlides.length === 0) return;

    var toolbar = root.querySelector(".h-updates-carousel__toolbar");
    /** Max scrollLeft where the last card’s right edge lines up with the Next button (≤ physical max). */
    var carouselEndScroll = 0;

    /** Align list start with the toolbar (home column) while the viewport spans the full window width. */
    function syncCarouselPad() {
      if (!toolbar || !viewport) return;
      var tl = toolbar.getBoundingClientRect().left;
      var vl = viewport.getBoundingClientRect().left;
      var pad = Math.max(0, Math.round(tl - vl));
      viewport.style.paddingLeft = pad + "px";
      viewport.style.paddingRight = "0px";
    }

    var wideMq = typeof window.matchMedia === "function" ? window.matchMedia("(min-width: 720px)") : null;

    function gapPx() {
      var g = getComputedStyle(list).columnGap || getComputedStyle(list).gap || "0";
      var n = parseFloat(g, 10);
      return Number.isFinite(n) ? n : 16;
    }

    function activeSlides() {
      return allSlides.filter(function (s) {
        return getComputedStyle(s).display !== "none";
      });
    }

    function lastVisibleSlide() {
      for (var i = allSlides.length - 1; i >= 0; i--) {
        var s = allSlides[i];
        if (s && getComputedStyle(s).display !== "none") return s;
      }
      return null;
    }

    function applyUpdatesFilter() {
      var checked = root.querySelector('input[name="home-updates-filter"]:checked');
      var v = checked ? checked.value : "all";
      allSlides.forEach(function (slide) {
        var kind = slide.getAttribute("data-updates-kind") || "update";
        var show = v === "all" || v === kind;
        if (show) slide.removeAttribute("hidden");
        else slide.setAttribute("hidden", "");
      });
      viewport.scrollLeft = 0;
      sync();
    }

    /** Columns used only for `--updates-slide-basis` math (not scroll snapping). */
    function slideColumnCountForWidth() {
      var n = activeSlides().length;
      var maxCols = wideMq && wideMq.matches ? 4 : 1;
      if (n <= 0) return 1;
      /*
        With one matching slide (e.g. Feature filter), min(maxCols, n) would be 1 and the card
        would span the full viewport — inconsistent with the multi-card row. Keep ~1/maxCols width.
      */
      if (wideMq && wideMq.matches && n === 1) return maxCols;
      return Math.min(maxCols, n);
    }

    function viewportInnerWidthPx() {
      var cs = getComputedStyle(viewport);
      var pl = parseFloat(cs.paddingLeft);
      var pr = parseFloat(cs.paddingRight);
      if (!Number.isFinite(pl)) pl = 0;
      if (!Number.isFinite(pr)) pr = 0;
      var cw = viewport.clientWidth;
      if (Number.isFinite(cw) && cw > 0) return Math.max(0, cw - pl - pr);
      var bl = parseFloat(cs.borderLeftWidth);
      var br = parseFloat(cs.borderRightWidth);
      if (!Number.isFinite(bl)) bl = 0;
      if (!Number.isFinite(br)) br = 0;
      var outer = viewport.getBoundingClientRect().width;
      return Math.max(0, outer - pl - pr - bl - br);
    }

    function slideWidthPx() {
      var inner = viewportInnerWidthPx();
      if (inner <= 0) return 0;
      var cols = slideColumnCountForWidth();
      var g = gapPx();
      var n = activeSlides().length;
      /*
        Single-column (narrow) layout: make each card slightly narrower than the viewport so a slice
        of the following card stays visible — signals more content via swipe or Next.
        Omit when only one slide matches (e.g. Feature filter with one item).
      */
      if ((!wideMq || !wideMq.matches) && cols === 1 && n > 1) {
        var peekDesired = Math.round(Math.min(96, Math.max(44, inner * 0.175)));
        var peek = Math.min(peekDesired, Math.max(0, inner - g - 176));
        var w = inner - g - peek;
        if (w > 0) return w;
      }
      var gutters = (cols - 1) * g;
      var share = inner - gutters;
      if (share <= 0) return 0;
      var base = share / cols;
      /* Slightly wider than “fill the row” so cards read a touch larger (multi-column only). */
      if (cols > 1) base *= 1.06;
      return base;
    }

    /** Viewport X where card left edges should line up (same column as section title + segmented control). */
    function contentAlignEdgeX() {
      var v = viewport.getBoundingClientRect();
      var cs = getComputedStyle(viewport);
      var pl = parseFloat(cs.paddingLeft);
      if (!Number.isFinite(pl)) pl = 0;
      return v.left + pl;
    }

    /** First slide whose right edge crosses the alignment column (leftmost “column” card). */
    function leftColumnSlideIndex(slides) {
      var edge = contentAlignEdgeX();
      for (var i = 0; i < slides.length; i++) {
        var r = slides[i].getBoundingClientRect();
        if (r.right > edge + 0.5) return i;
      }
      return 0;
    }

    /** Scroll so `slide`’s left edge meets the padded content edge (toolbar / title column). */
    function scrollToAlignSlideLeft(slide, smooth) {
      if (!slide) return;
      syncCarouselPad();
      var edge = contentAlignEdgeX();
      var delta = slide.getBoundingClientRect().left - edge;
      var target = viewport.scrollLeft + delta;
      var maxS = maxScrollLeft();
      var clamped = Math.max(0, Math.min(maxS, Math.round(target)));
      viewport.scrollTo({ left: clamped, behavior: smooth === false ? "auto" : "smooth" });
    }

    function nativeMaxScrollLeft() {
      return Math.max(0, viewport.scrollWidth - viewport.clientWidth);
    }

    /**
     * List padding-right only as needed so at max scroll the last card’s right can meet the Next
     * control (tight — no wide empty runway).
     */
    function syncListEndSpace() {
      var saved = viewport.scrollLeft;
      var endPad = 0;
      for (var pass = 0; pass < 5; pass++) {
        list.style.paddingRight = endPad + "px";
        void list.offsetHeight;
        var maxS = Math.max(0, viewport.scrollWidth - viewport.clientWidth);
        var lastAtEnd = maxS > 0 ? lastVisibleSlide() : null;
        if (!lastAtEnd || !next) break;
        viewport.scrollLeft = maxS;
        void viewport.offsetHeight;
        var lr = lastAtEnd.getBoundingClientRect().right;
        var nr = next.getBoundingClientRect().right;
        viewport.scrollLeft = saved;
        void list.offsetHeight;
        if (lr <= nr + 1) break;
        endPad += Math.ceil(lr - nr);
      }
      list.style.paddingRight = endPad + "px";
    }

    /** Scroll position that right-aligns the last card to the Next button (linear scroll model). */
    function syncEndScrollTarget() {
      var maxS = nativeMaxScrollLeft();
      if (maxS <= 0) {
        carouselEndScroll = 0;
        return;
      }
      var last = lastVisibleSlide();
      if (!last || !next) {
        carouselEndScroll = maxS;
        return;
      }
      var saved = viewport.scrollLeft;
      viewport.scrollLeft = maxS;
      void viewport.offsetHeight;
      var lr = last.getBoundingClientRect().right;
      var nr = next.getBoundingClientRect().right;
      viewport.scrollLeft = saved;
      void viewport.offsetHeight;
      var ideal = Math.round(lr + maxS - nr);
      carouselEndScroll = Math.max(0, Math.min(maxS, ideal));
    }

    function maxScrollLeft() {
      return carouselEndScroll;
    }

    function clampCarouselScroll() {
      var mx = carouselEndScroll;
      if (viewport.scrollLeft > mx + 0.5) {
        viewport.scrollLeft = mx;
      }
    }

    function setSlideWidths() {
      if (viewportInnerWidthPx() <= 0) return;
      var sw = slideWidthPx();
      viewport.style.setProperty("--updates-slide-basis", (Number.isFinite(sw) ? sw : 0) + "px");
    }

    function updateNavDisabled() {
      var maxS = maxScrollLeft();
      var x = viewport.scrollLeft;
      var slides = activeSlides();
      var edge = contentAlignEdgeX();
      var atStart =
        slides.length === 0 || slides[0].getBoundingClientRect().left >= edge - 2;
      prev.disabled = maxS <= 0 || atStart;
      next.disabled = maxS <= 0 || x >= maxS - 2;
    }

    function sync() {
      syncCarouselPad();
      setSlideWidths();
      syncListEndSpace();
      syncEndScrollTarget();
      clampCarouselScroll();
      updateNavDisabled();
      document.dispatchEvent(new CustomEvent("prism-resplit-stagger-titles"));
    }

    var scrollIdleTimer;
    function onScrollIdle() {
      clampCarouselScroll();
      updateNavDisabled();
    }

    prev.addEventListener("click", function () {
      if (prev.disabled) return;
      syncCarouselPad();
      setSlideWidths();
      syncListEndSpace();
      syncEndScrollTarget();
      if (maxScrollLeft() <= 0) return;
      var slides = activeSlides();
      if (slides.length === 0) return;
      var i = leftColumnSlideIndex(slides);
      if (i <= 0) scrollToAlignSlideLeft(slides[0], true);
      else scrollToAlignSlideLeft(slides[i - 1], true);
    });
    next.addEventListener("click", function () {
      if (next.disabled) return;
      syncCarouselPad();
      setSlideWidths();
      syncListEndSpace();
      syncEndScrollTarget();
      if (maxScrollLeft() <= 0) return;
      var slides = activeSlides();
      if (slides.length === 0) return;
      var i = leftColumnSlideIndex(slides);
      if (i >= slides.length - 1) return;
      var nextIdx = i + 1;
      /* Last step: land on end-aligned scroll (last card right = Next), not raw native max. */
      if (nextIdx === slides.length - 1) {
        viewport.scrollTo({ left: carouselEndScroll, behavior: "smooth" });
      } else {
        scrollToAlignSlideLeft(slides[nextIdx], true);
      }
    });
    viewport.addEventListener(
      "scroll",
      function () {
        clampCarouselScroll();
        updateNavDisabled();
        clearTimeout(scrollIdleTimer);
        scrollIdleTimer = setTimeout(onScrollIdle, 130);
      },
      { passive: true }
    );
    viewport.addEventListener("scrollend", function () {
      clearTimeout(scrollIdleTimer);
      onScrollIdle();
    });

    var filterRoot = root.querySelector("[data-updates-filter]");
    if (filterRoot) {
      filterRoot.querySelectorAll('input[type="radio"][name="home-updates-filter"]').forEach(function (inp) {
        inp.addEventListener("change", applyUpdatesFilter);
      });
    }

    function preserveScrollAfterLayout() {
      syncCarouselPad();
      setSlideWidths();
      syncListEndSpace();
      syncEndScrollTarget();
      var d = carouselEndScroll;
      var ratio = d > 0 ? Math.min(1, Math.max(0, viewport.scrollLeft / d)) : 0;
      requestAnimationFrame(function () {
        syncCarouselPad();
        setSlideWidths();
        syncListEndSpace();
        syncEndScrollTarget();
        var d2 = carouselEndScroll;
        viewport.scrollTo({ left: d2 * ratio, behavior: "auto" });
        sync();
      });
    }

    window.addEventListener("resize", preserveScrollAfterLayout);
    if (wideMq && typeof wideMq.addEventListener === "function") {
      wideMq.addEventListener("change", preserveScrollAfterLayout);
    } else if (wideMq && typeof wideMq.addListener === "function") {
      wideMq.addListener(preserveScrollAfterLayout);
    }
    sync();
  }

  /**
   * MD3-style ink: grows from pointer on press (CSS keyframes), holds, then fades on release.
   * Ripples use is:global styles — Astro scoped CSS does not apply to JS-created nodes.
   */
  function initHomeButtonPressFeedback() {
    var root = document.querySelector(".home-root");
    if (!root) return;

    var reduceMotion =
      typeof window.matchMedia === "function" &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    root.addEventListener(
      "pointerdown",
      function (e) {
        if (reduceMotion) return;
        var btn = e.target.closest(".home-root a.h-btn");
        if (!btn || !root.contains(btn)) return;
        if (e.pointerType === "mouse" && e.button !== 0) return;

        var surface = btn.querySelector(".h-btn__surface");
        if (!surface) return;

        var prev = surface.querySelector(".h-btn__ripple");
        if (prev) prev.remove();

        var rect = btn.getBoundingClientRect();
        var x = e.clientX - rect.left;
        var y = e.clientY - rect.top;
        var maxDim = Math.max(rect.width, rect.height);
        var d = maxDim * 2.55;

        var ripple = document.createElement("span");
        ripple.className = "h-btn__ripple";
        ripple.style.left = x - d / 2 + "px";
        ripple.style.top = y - d / 2 + "px";
        ripple.style.width = d + "px";
        ripple.style.height = d + "px";
        surface.appendChild(ripple);

        requestAnimationFrame(function () {
          ripple.classList.add("h-btn__ripple--press");
        });

        var pid = e.pointerId;

        function removeListeners() {
          document.removeEventListener("pointerup", onUp, true);
          document.removeEventListener("pointercancel", onUp, true);
        }

        function onUp(e2) {
          if (e2.pointerId !== pid) return;
          removeListeners();

          var cs = window.getComputedStyle(ripple);
          var op = cs.opacity;
          var tr = cs.transform;
          ripple.classList.remove("h-btn__ripple--press");
          ripple.style.animation = "none";
          ripple.style.opacity = op;
          ripple.style.transform = tr;
          void ripple.offsetWidth;
          ripple.style.transition =
            "opacity 0.32s ease-out, transform 0.42s cubic-bezier(0.2, 0.75, 0.25, 1)";
          requestAnimationFrame(function () {
            ripple.style.opacity = "0";
            ripple.style.transform = "scale(1.12)";
          });

          function cleanup() {
            if (ripple.parentNode) ripple.parentNode.removeChild(ripple);
          }

          ripple.addEventListener(
            "transitionend",
            function (tev) {
              if (tev.propertyName === "opacity") cleanup();
            },
            { once: true }
          );
          window.setTimeout(cleanup, 480);
        }

        document.addEventListener("pointerup", onUp, true);
        document.addEventListener("pointercancel", onUp, true);
      },
      { passive: true }
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHomeButtonPressFeedback);
  } else {
    initHomeButtonPressFeedback();
  }

  initUpdatesCarousel();
</script>

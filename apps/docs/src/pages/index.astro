      radial-gradient(ellipse 100% 85% at 96% 4%, color-mix(in srgb, #b8d9fb 40%, transparent), transparent 52%),
      radial-gradient(ellipse 70% 60% at 88% 42%, color-mix(in srgb, var(--prism-color-accent) 24%, transparent), transparent 50%),
      radial-gradient(ellipse 55% 45% at 18% 22%, color-mix(in srgb, #dbeafe 22%, transparent), transparent 55%),

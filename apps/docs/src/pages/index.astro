      radial-gradient(ellipse 70% 60% at 88% 42%, color-mix(in srgb, var(--prism-color-accent-strong) 18%, transparent), transparent 50%),
      radial-gradient(ellipse 55% 45% at 18% 22%, color-mix(in srgb, #c4b5fd 14%, transparent), transparent 55%),
      var(--prism-color-canvas);
  }

  :global([data-theme="bloom"]) .h-hero::before {

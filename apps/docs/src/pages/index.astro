    box-shadow: var(--prism-shadow-lg);
  }

  :global([data-theme="bloom"]) .h-btn--elevated {
    background: linear-gradient(to top right, #0a3d9c 0%, #2271df 60%, #63a6ff 100%);
    box-shadow: var(--prism-shadow-lg);

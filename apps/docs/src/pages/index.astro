  .h-inside__desc {
    grid-column: 1;
    grid-row: 2;
    max-width: 38rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--prism-color-text-secondary);
  }

  .h-inside__arrow {
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: center;
    font-size: 1.35rem;
    font-weight: 300;
    color: var(--prism-color-text-secondary);
    opacity: 0.35;
    transition:
      opacity 0.35s var(--home-ease),
      transform 0.45s var(--home-ease);

      radial-gradient(ellipse 70% 60% at 88% 42%, color-mix(in srgb, #fce7f3 22%, transparent), transparent 50%),
      radial-gradient(ellipse 55% 45% at 18% 22%, color-mix(in srgb, var(--prism-color-accent-strong) 16%, transparent), transparent 55%),

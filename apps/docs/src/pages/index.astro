  .h-inside__link:hover .h-inside__arrow {
    opacity: 1;
    transform: translateX(0.35rem);
  }

  @media (max-width: 32rem) {
    .h-inside__arrow {
      align-self: start;
      padding-top: 0.2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .h-btn--primary:hover,
    .h-btn--quiet:hover,
    .h-btn--tertiary:hover {
      transform: none;
    }

    .h-btn:hover .h-btn__arrow {
      transform: none;
    }

    .h-updates-carousel__viewport {
      scroll-behavior: auto;
    }

    .h-updates-card:hover {
      transform: none;
    }

    .h-inside__link:hover {
      padding-left: 0;
    }

    .h-inside__link:hover .h-inside__arrow {
      transform: none;
    }
  }
</style>

<script>
  function initUpdatesCarousel() {
    var root = document.querySelector("[data-updates-carousel]");
    if (!root) return;
    var viewport = root.querySelector("[data-carousel-viewport]");
    var list = viewport && viewport.querySelector(".h-updates-carousel__list");
    var prev = root.querySelector("[data-carousel-prev]");
    var next = root.querySelector("[data-carousel-next]");
    var countEl = root.querySelector("[data-carousel-count]");
    if (!viewport || !list || !prev || !next) return;

    var realTotal = parseInt(String(root.getAttribute("data-carousel-real-total") || "6"), 10) || 6;

    function appendLoopClones() {
      if (list.querySelector(".h-updates-carousel__slide--clone")) return;
      var originals = Array.prototype.slice.call(
        list.querySelectorAll(":scope > .h-updates-carousel__slide:not(.h-updates-carousel__slide--clone)")
      );
      originals.forEach(function (slide) {
        var c = slide.cloneNode(true);
        c.classList.add("h-updates-carousel__slide--clone");
        c.setAttribute("aria-hidden", "true");
        var link = c.querySelector("a");
        if (link) link.setAttribute("tabindex", "-1");
        list.appendChild(c);
      });
    }

    appendLoopClones();

    var allSlides = Array.prototype.slice.call(list.querySelectorAll(".h-updates-carousel__slide"));
    if (allSlides.length === 0) return;

    var wideMq = typeof window.matchMedia === "function" ? window.matchMedia("(min-width: 720px)") : null;

    function gapPx() {
      var g = getComputedStyle(list).columnGap || getComputedStyle(list).gap || "0";
      var n = parseFloat(g, 10);
      return Number.isFinite(n) ? n : 16;
    }

    function activeSlides() {
      return allSlides.filter(function (s) {
        return getComputedStyle(s).display !== "none";
      });
    }

    function visibleCount() {
      var n = activeSlides().length;
      var vis = wideMq && wideMq.matches ? 3 : 1;
      return Math.min(vis, n);
    }

    function viewportInnerWidthPx() {
      var cs = getComputedStyle(viewport);
      var pl = parseFloat(cs.paddingLeft);
      var pr = parseFloat(cs.paddingRight);
      if (!Number.isFinite(pl)) pl = 0;
      if (!Number.isFinite(pr)) pr = 0;
      var cw = viewport.clientWidth;
      if (Number.isFinite(cw) && cw > 0) return Math.max(0, cw - pl - pr);
      var bl = parseFloat(cs.borderLeftWidth);
      var br = parseFloat(cs.borderRightWidth);
      if (!Number.isFinite(bl)) bl = 0;
      if (!Number.isFinite(br)) br = 0;
      var outer = viewport.getBoundingClientRect().width;
      return Math.max(0, outer - pl - pr - bl - br);
    }

    function slideWidthPx() {
      var inner = viewportInnerWidthPx();
      if (inner <= 0) return 0;
      var vis = visibleCount();
      var g = gapPx();
      var gutters = (vis - 1) * g;
      var share = inner - gutters;
      if (share <= 0) return 0;
      /* Fractional width so vis slides + (vis−1) gaps exactly span the toolbar width. */
      return share / vis;
    }

    function stepPx() {
      var sw = slideWidthPx();
      if (sw <= 0) return gapPx() || 1;
      return sw + gapPx();
    }

    function maxLeftIndex() {
      var n = activeSlides().length;
      var vis = visibleCount();
      return Math.max(0, n - vis);
    }

    /** Largest L <= maxLeftIndex() where the counter shows cardOneBased (same formula as updateCounterOnly). */
    function largestLeftIndexForCounterCard(cardOneBased) {
      var r = realTotal;
      var maxL = maxLeftIndex();
      if (r <= 0 || maxL <= 0) return 0;
      var want = (((cardOneBased - 1) % r) + r) % r;
      var k = Math.floor(maxL / r) * r + want;
      if (k > maxL) k -= r;
      return Math.max(0, k);
    }

    function firstSetWidthPx() {
      var c = list.querySelector(".h-updates-carousel__slide--clone");
      if (!c || getComputedStyle(c).display === "none") return 0;
      return c.offsetLeft;
    }

    function formatPosition(cardOneBased, tot) {
      var zh = document.documentElement.dataset.uiLang === "zh";
      if (zh) return String(cardOneBased) + " / " + String(tot);
      return String(cardOneBased) + " of " + String(tot);
    }

    function setSlideWidths() {
      if (viewportInnerWidthPx() <= 0) return;
      var sw = slideWidthPx();
      viewport.style.setProperty("--updates-slide-basis", (Number.isFinite(sw) ? sw : 0) + "px");
    }

    function nearestLeftIndex() {
      var step = stepPx();
      if (step <= 0) return 0;
      var maxL = maxLeftIndex();
      var raw = Math.round(viewport.scrollLeft / step);
      return Math.max(0, Math.min(maxL, raw));
    }

    function scrollToLeftIndex(L, smooth) {
      var step = stepPx();
      var maxL = maxLeftIndex();
      var clamped = Math.max(0, Math.min(maxL, L));
      var target = clamped * step;
      if (smooth === false) {
        viewport.scrollLeft = target;
      } else {
        viewport.scrollTo({ left: target, behavior: "smooth" });
      }
    }

    function normalizeLoopPosition() {
      var w = firstSetWidthPx();
      if (w <= 0) return;
      while (viewport.scrollLeft >= w - 1) {
        viewport.scrollLeft -= w;
      }
    }

    function updateCounterOnly() {
      var L = nearestLeftIndex();
      var cardNum = (L % realTotal) + 1;
      if (countEl) countEl.textContent = formatPosition(cardNum, realTotal);
    }

    function sync() {
      setSlideWidths();
      updateCounterOnly();
      prev.disabled = false;
      next.disabled = false;
    }

    function applyNavScroll(targetL) {
      scrollToLeftIndex(targetL, false);
      normalizeLoopPosition();
      updateCounterOnly();
    }

    var scrollIdleTimer;
    function onScrollIdle() {
      normalizeLoopPosition();
      updateCounterOnly();
    }

    prev.addEventListener("click", function () {
      var maxL = maxLeftIndex();
      if (maxL <= 0) return;
      var L = nearestLeftIndex();
      var prevL = L <= 0 ? largestLeftIndexForCounterCard(realTotal) : L - 1;
      applyNavScroll(prevL);
    });
    next.addEventListener("click", function () {
      var maxL = maxLeftIndex();
      if (maxL <= 0) return;
      var L = nearestLeftIndex();
      if (L < maxL) {
        applyNavScroll(L + 1);
      } else {
        applyNavScroll(0);
      }
    });
    viewport.addEventListener(
      "wheel",
      function (ev) {
        if (Math.abs(ev.deltaX) <= Math.abs(ev.deltaY)) return;
        ev.preventDefault();
      },
      { passive: false }
    );
    viewport.addEventListener(
      "scroll",
      function () {
        updateCounterOnly();
        clearTimeout(scrollIdleTimer);
        scrollIdleTimer = setTimeout(onScrollIdle, 130);
      },
      { passive: true }
    );
    viewport.addEventListener("scrollend", function () {
      clearTimeout(scrollIdleTimer);
      onScrollIdle();
    });

    function preserveScrollAfterLayout() {
      var maxScroll = Math.max(0, viewport.scrollWidth - viewport.clientWidth);
      var ratio = maxScroll > 0 ? viewport.scrollLeft / maxScroll : 0;
      setSlideWidths();
      requestAnimationFrame(function () {
        var newMax = Math.max(0, viewport.scrollWidth - viewport.clientWidth);
        viewport.scrollTo({ left: newMax * ratio, behavior: "auto" });
        normalizeLoopPosition();
        sync();
      });
    }

    window.addEventListener("resize", preserveScrollAfterLayout);
    if (wideMq && typeof wideMq.addEventListener === "function") {
      wideMq.addEventListener("change", preserveScrollAfterLayout);
    } else if (wideMq && typeof wideMq.addListener === "function") {
      wideMq.addListener(preserveScrollAfterLayout);
    }
    setSlideWidths();
    sync();
  }

  initUpdatesCarousel();
</script>

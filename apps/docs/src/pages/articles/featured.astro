---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import ArticleUpdateArticle from "../../components/article/ArticleUpdateArticle.astro";
import ArticleTeasersViewControls from "../../components/article/ArticleTeasersViewControls.astro";
---

<ArticleLayout
  title="Featured"
  current="featured"
  description="Highlighted release notes and updates from the Prism team."
  pageVariant="teasers"
>
  <header class="page-head">
    <h1 data-i18n="article.nav.featured">Featured</h1>
    <div class="article-teasers-head-row">
      <p class="intro" data-i18n="article.lede">
        Release notes, deep dives, and product updates from the Prism team.
      </p>
      <ArticleTeasersViewControls />
    </div>
  </header>
  <div class="article-posts article-posts--teasers">
    <ArticleUpdateArticle id="update-prism-skill-library" updateN={8} isFirstInPage teaserFromFeatured />
    <ArticleUpdateArticle id="update-home-navigation" updateN={2} teaserFromFeatured />
  </div>
</ArticleLayout>

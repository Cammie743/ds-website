---
import ArticleLayout from "../../../layouts/ArticleLayout.astro";
import ArticleUpdateArticle from "../../../components/article/ArticleUpdateArticle.astro";
import ArticleAnchors from "../../../components/article/ArticleAnchors.astro";
import { uiStrings } from "../../../i18n/ui";
import {
  BLOG_UPDATE_PUBLISHED_YEAR_BY_N,
  BLOG_UPDATE_SLUG_BY_N,
  getArticleUpdatePostPath,
  getArticleUpdateUrlSlug,
  type ArticleUpdateN,
} from "../../../data/articleUpdates";

export function getStaticPaths() {
  return (Object.entries(BLOG_UPDATE_SLUG_BY_N) as [string, string][]).map(([k, id]) => {
    const updateN = Number(k) as ArticleUpdateN;
    const year = BLOG_UPDATE_PUBLISHED_YEAR_BY_N[updateN];
    const slug = getArticleUpdateUrlSlug(updateN);
    return { params: { year, slug }, props: { id, updateN } };
  });
}

const { id, updateN } = Astro.props;
const { year, slug } = Astro.params;

if (year !== BLOG_UPDATE_PUBLISHED_YEAR_BY_N[updateN] || slug !== getArticleUpdateUrlSlug(updateN)) {
  return Astro.redirect(getArticleUpdatePostPath(updateN), 301);
}

function listingTitle(n: ArticleUpdateN): string {
  switch (n) {
    case 1:
      return uiStrings.en["home.updates.1.title"];
    case 2:
      return uiStrings.en["home.updates.2.title"];
    case 3:
      return uiStrings.en["home.updates.3.title"];
    case 4:
      return uiStrings.en["home.updates.4.title"];
    case 5:
      return uiStrings.en["home.updates.5.title"];
    case 6:
      return uiStrings.en["home.updates.6.title"];
    case 7:
      return uiStrings.en["home.updates.7.title"];
    case 8:
      return uiStrings.en["home.updates.8.title"];
    default:
      return uiStrings.en["article.nav.latest"];
  }
}
---

<ArticleLayout
  title={listingTitle(updateN)}
  current="latest"
  description={uiStrings.en["article.lede"]}
  pageVariant="article"
>
  <p class="article-update-back">
    <a class="article-update-back__link" href="/articles/latest">
      <span class="article-update-back__arrow" aria-hidden="true">←</span>
      <span class="article-update-back__label" data-i18n="article.backToUpdates">Back to Latest updates</span>
    </a>
  </p>
  <ArticleUpdateArticle id={id} updateN={updateN} mode="full" isFirstInPage />
  <ArticleAnchors slot="anchors" id={id} updateN={updateN} />
</ArticleLayout>

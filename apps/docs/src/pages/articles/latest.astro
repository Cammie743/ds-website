---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import ArticleUpdateArticle from "../../components/article/ArticleUpdateArticle.astro";
import ArticleTeasersViewControls from "../../components/article/ArticleTeasersViewControls.astro";
---

<ArticleLayout
  title="Latest updates"
  current="latest"
  description="Recent release notes and product updates from the Prism team."
  pageVariant="teasers"
>
  <header class="page-head">
    <h1 data-i18n="article.nav.latest">Latest updates</h1>
    <div class="article-teasers-head-row">
      <p class="intro" data-i18n="article.lede">
        Release notes, deep dives, and product updates from the Prism team.
      </p>
      <ArticleTeasersViewControls />
    </div>
  </header>
  <div class="article-posts article-posts--teasers">
    <ArticleUpdateArticle id="update-april-2026" updateN={1} isFirstInPage />
    <ArticleUpdateArticle id="update-theme-previews" updateN={3} />
    <ArticleUpdateArticle id="update-foundations-ia" updateN={4} />
    <ArticleUpdateArticle id="update-search-docs" updateN={5} />
    <ArticleUpdateArticle id="update-usage-metrics" updateN={6} />
    <ArticleUpdateArticle id="update-a11y-checklist" updateN={7} />
  </div>
</ArticleLayout>

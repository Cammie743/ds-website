---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import ArticleUpdateArticle from "../../components/article/ArticleUpdateArticle.astro";
import ArticleTeasersViewControls from "../../components/article/ArticleTeasersViewControls.astro";
---

<ArticleLayout title="2025" current="y2025" description="Articles from 2025 by the Prism team." pageVariant="teasers">
  <header class="page-head">
    <h1 data-i18n="article.nav.y2025">2025</h1>
    <div class="article-teasers-head-row">
      <p class="intro" data-i18n="article.lede">
        Release notes, deep dives, and product updates from the Prism team.
      </p>
      <ArticleTeasersViewControls />
    </div>
  </header>
  <div class="article-posts article-posts--teasers">
    <ArticleUpdateArticle id="update-usage-metrics" updateN={6} isFirstInPage />
    <ArticleUpdateArticle id="update-a11y-checklist" updateN={7} />
  </div>
</ArticleLayout>

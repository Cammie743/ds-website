---
import DocH2WithAnchor from "../DocH2WithAnchor.astro";
import { getBlogUpdatePostPath, type BlogUpdateN } from "../../data/blogUpdates";

interface Props {
  id: string;
  updateN: BlogUpdateN;
  isFirstInPage?: boolean;
  /** Listing: home-level teaser + link. Detail: full post body + byline. */
  mode?: "teaser" | "full";
  /** Teaser `href` includes `?from=featured` so the article page shows “Back to Featured”. */
  teaserFromFeatured?: boolean;
}

const { id, updateN, isFirstInPage = false, mode = "teaser", teaserFromFeatured = false } = Astro.props;
/** `Object.entries` and some callers may pass string indices; normalize for strict `===` checks. */
const n = (typeof updateN === "number" ? updateN : Number(updateN)) as BlogUpdateN;

/** Newer post (reverse-chronological “up” the feed). Post 8 is newest; post 1 follows. */
const prevNav: { n: BlogUpdateN } | null =
  n === 8 ? null : n === 1 ? { n: 8 } : { n: (n - 1) as BlogUpdateN };
/** Older post (“down” the feed). */
const nextNav: { n: BlogUpdateN } | null =
  n === 8 ? { n: 1 } : n < 7 ? { n: (n + 1) as BlogUpdateN } : null;

const datetimeByN: Record<BlogUpdateN, string> = {
  1: "2026-04-17",
  2: "2026-04-01",
  3: "2026-03-01",
  4: "2026-02-01",
  5: "2026-01-15",
  6: "2025-12-08",
  7: "2025-11-20",
  8: "2026-04-20",
};

const headingId = `${id}-heading`;
const postHref = getBlogUpdatePostPath(n);
const teaserHref = teaserFromFeatured ? `${postHref}?from=featured` : postHref;

const authorAvatarSrc: Record<BlogUpdateN, string> = {
  1: "/images/prism-library/avatars/april-2026-update.png",
  2: "/images/prism-library/avatars/rowan-vega.png",
  3: "/images/prism-library/avatars/kenji-park.png",
  4: "/images/prism-library/avatars/ellis-mercer.png",
  5: "/images/prism-library/avatars/calvin-rhodes.png",
  6: "/images/prism-library/avatars/amari-okoro.png",
  7: "/images/prism-library/avatars/sofia-delgado.png",
  8: "/images/prism-library/avatars/april-2026-update.png",
};

const author8JeffSrc = "/images/prism-library/avatars/jeff-low.png";
const author8LizSrc = "/images/prism-library/avatars/liz-chang.png";

/** April 2026 hero uses the shared gradient image under `article-1/` in article views; home carousel uses the same asset. */
const updateHeroImageSrc =
  n === 1
    ? "/images/articles/article-1/article-1-hero.jpg"
    : n === 8
      ? "/images/articles/article-8/article-8-prism-skill-library-hero.png"
      : `/images/articles/article-${n}/article-${n}.svg`;
const updateHeroImageAltKey = n === 1 ? "blog.update.1.heroAlt" : (`home.updates.${n}.alt` as string);
const updateHeroImageWidth = n === 1 || n === 8 ? 1024 : mode === "teaser" ? 780 : 640;
const updateHeroImageHeight = n === 1 ? 601 : n === 8 ? 492 : mode === "teaser" ? 440 : 360;
---

{
  mode === "teaser" ? (
    <article id={id} class:list={["blog-article", "blog-article--teaser", { "blog-article--first": isFirstInPage }]}>
      <a class="blog-article__teaser" href={teaserHref} aria-labelledby={headingId}>
        <div class="blog-article__teaser-text">
          <p class="blog-article__meta">
            <time datetime={datetimeByN[n]} data-i18n={`home.updates.${n}.date`}>
              Date
            </time>
          </p>
          <h2
            id={headingId}
            class="blog-article__title doc-h2-anchor-heading"
            data-i18n={`home.updates.${n}.title`}
            data-stagger-title-underline
          >
            {n === 1 ? "April release: Figma library updates for v2.5" : n === 8 ? "Prism Library Skill for product teams" : "Title"}
          </h2>
          <p class="blog-article__excerpt">
            <span class="blog-article__excerpt-text" data-i18n={`home.updates.${n}.body`}>
              Summary
            </span>
          </p>
          <div class:list={["blog-article__author", { "blog-article__author--multi": n === 8 }]}>
            {
              n === 8 ? (
                <div class="blog-article__author-avatars">
                  <img
                    class="blog-article__author-avatar"
                    src={author8JeffSrc}
                    width="64"
                    height="64"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.8.author1AvatarAlt"
                  />
                  <img
                    class="blog-article__author-avatar"
                    src={author8LizSrc}
                    width="64"
                    height="64"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="home.updates.8.author2AvatarAlt"
                  />
                </div>
              ) : (
                <img
                  class="blog-article__author-avatar"
                  src={authorAvatarSrc[n]}
                  width="64"
                  height="64"
                  loading="lazy"
                  decoding="async"
                  alt=""
                  data-i18n-alt={`home.updates.${n}.authorAvatarAlt`}
                />
              )
            }
            <span class="blog-article__author-name" data-i18n={`home.updates.${n}.authorName`}>
              Author
            </span>
          </div>
        </div>
        <figure class="blog-article__figure">
          <img
            class="blog-article__img"
            src={updateHeroImageSrc}
            width={updateHeroImageWidth}
            height={updateHeroImageHeight}
            loading="lazy"
            decoding="async"
            alt=""
            data-i18n-alt={updateHeroImageAltKey}
          />
        </figure>
      </a>
    </article>
  ) : (
    <article id={id} class:list={["blog-article", "blog-article--full", { "blog-article--first": isFirstInPage }]}>
      <header class="blog-article__head">
        <p class="blog-article__meta">
          <time datetime={datetimeByN[n]} data-i18n={`home.updates.${n}.date`}>
            Date
          </time>
        </p>
        <h1 id={headingId} class="blog-article__title" data-i18n={`home.updates.${n}.title`}>
          {n === 1 ? "April release: Figma library updates for v2.5" : n === 8 ? "Prism Library Skill for product teams" : "Title"}
        </h1>
        <div class:list={["blog-article__head-author", { "blog-article__head-author--multi": n === 8 }]}>
          {
            n === 8 ? (
              <div class="blog-article__head-author-avatars">
                <img
                  class="blog-article__head-author-avatar"
                  src={author8JeffSrc}
                  width="48"
                  height="48"
                  loading="lazy"
                  decoding="async"
                  alt=""
                  data-i18n-alt="home.updates.8.author1AvatarAlt"
                />
                <img
                  class="blog-article__head-author-avatar"
                  src={author8LizSrc}
                  width="48"
                  height="48"
                  loading="lazy"
                  decoding="async"
                  alt=""
                  data-i18n-alt="home.updates.8.author2AvatarAlt"
                />
              </div>
            ) : (
              <img
                class="blog-article__head-author-avatar"
                src={authorAvatarSrc[n]}
                width="48"
                height="48"
                loading="lazy"
                decoding="async"
                alt=""
                data-i18n-alt={`home.updates.${n}.authorAvatarAlt`}
              />
            )
          }
          <span class="blog-article__head-author-name" data-i18n={`home.updates.${n}.authorName`}>
            Author
          </span>
        </div>
      </header>
      <figure class="blog-article__figure">
        <img
          class="blog-article__img"
          src={updateHeroImageSrc}
          width={updateHeroImageWidth}
          height={updateHeroImageHeight}
          loading="lazy"
          decoding="async"
          alt=""
          data-i18n-alt={updateHeroImageAltKey}
        />
      </figure>
      <div class="blog-article__body">
        {n === 1 ? (
          <div class="blog-article__sections">
            <DocH2WithAnchor
              id={`${id}-section-components`}
              class="doc-tabs__h2 blog-article__section-title"
              rowClass="doc-h2-anchor-row--tabs"
              data-i18n="blog.update.1.section.components"
            >
              Component updates
            </DocH2WithAnchor>
            <p class="blog-article__section-intro" data-i18n="blog.update.1.p.comp.intro">
              The following components have been updated in this month's weekly releases.
            </p>
            <div class="blog-article__subsection">
              <h4 id={`${id}-sub-comp-button`} class="blog-article__subsection-title" data-i18n="blog.update.1.sub.comp.button">
                Secondary basic button
              </h4>
              <p data-i18n="blog.update.1.p.comp.button">
                We kept the current Secondary Default button light blue and introduced a new Secondary Neutral option as a half step down. This update gives teams a secondary button that better matches other grey secondary buttons when that is the better fit for the layout, while still preserving the blue Secondary Default button as a stronger alternative to the primary button.
              </p>
              <figure class="blog-article__inline-figure">
                <img
                  class="blog-article__img"
                  src="/images/articles/article-1/article-1-comp-button.png"
                  width="1024"
                  height="400"
                  loading="lazy"
                  decoding="async"
                  alt=""
                  data-i18n-alt="blog.update.1.comp.imgAlt.button"
                />
                <figcaption class="blog-article__inline-caption">
                  <span class="blog-article__inline-caption__badge">
                    <span class="blog-article__inline-caption__badge-num">1</span>
                  </span>
                  <span class="blog-article__inline-caption__text" data-i18n="blog.update.1.comp.caption.button">
                    Secondary basic button - Neutral sentiment
                  </span>
                </figcaption>
              </figure>
            </div>
            <div class="blog-article__subsection">
              <h4 id={`${id}-sub-comp-media-player`} class="blog-article__subsection-title" data-i18n="blog.update.1.sub.comp.mediaPlayer">
                Media player
              </h4>
              <p data-i18n="blog.update.1.p.comp.mediaPlayer">
                Media player has been updated to improve visibility across light and dark media backgrounds. Disabled states could previously become hard to see on lighter content, so the control bar now uses a stronger transparent dark background with 8px blur, and disabled buttons use a more visible transparent fill treatment.
              </p>
              <figure class="blog-article__inline-figure blog-article__inline-figure--media-player">
                <img
                  class="blog-article__img"
                  src="/images/articles/article-1/article-1-comp-media-player.jpg"
                  width="1024"
                  height="720"
                  loading="lazy"
                  decoding="async"
                  alt=""
                  data-i18n-alt="blog.update.1.comp.imgAlt.mediaPlayer"
                />
                <figcaption class="blog-article__inline-caption">
                  <span class="blog-article__inline-caption__text" data-i18n="blog.update.1.comp.caption.mediaPlayer">
                    Updated the media player control bar to improve disabled state visibility and overall legibility across different media backgrounds.
                  </span>
                </figcaption>
              </figure>
            </div>
            <div class="blog-article__subsection">
              <h4 id={`${id}-sub-comp-pagination`} class="blog-article__subsection-title" data-i18n="blog.update.1.sub.comp.pagination">
                Pagination
              </h4>
              <p data-i18n="blog.update.1.p.comp.pagination">
                Improved pagination by fixing layout shifts from dynamic slots. Added an additional slot and locked the total slot count, keeping chevrons in a fixed position and reducing accidentally clicking the last page.
              </p>
              <figure class="blog-article__inline-figure" data-blog-pagination-demo>
                <div class="blog-article__inline-video-frame">
                  <div class="blog-article__inline-video-stack">
                    <video
                      id={`${id}-pagination-video`}
                      class="blog-article__inline-video"
                      autoplay
                      muted
                      loop
                      playsinline
                      preload="auto"
                      tabindex="0"
                      aria-label="Screen recording: Vue pagination moving between pages with the dot track."
                      data-i18n-aria="blog.update.1.comp.paginationVideoAria"
                    >
                      <source src="/images/articles/article-1/article-1-comp-pagination-demo.mp4" type="video/mp4" />
                    </video>
                  </div>
                  <div class="blog-article__inline-video-overlay-actions">
                    <button
                      type="button"
                      class="blog-article__inline-video-toggle icon-btn"
                      data-blog-pagination-demo-toggle
                      aria-controls={`${id}-pagination-video`}
                      aria-pressed="true"
                      aria-label="Play or pause the pagination demo video"
                      data-i18n-aria="blog.update.1.comp.paginationVideoToggleAria"
                    >
                      <svg
                        class="icon blog-article__inline-video-icon blog-article__inline-video-icon--pause"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M6 5h4v14H6V5zm8 0h4v14h-4V5z"></path>
                      </svg>
                      <svg
                        class="icon blog-article__inline-video-icon blog-article__inline-video-icon--play"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                        hidden
                      >
                        <path d="M8 5v14l11-7L8 5z"></path>
                      </svg>
                    </button>
                  </div>
                </div>
              </figure>
            </div>
            <DocH2WithAnchor
              id={`${id}-section-icons`}
              class="doc-tabs__h2 blog-article__section-title"
              rowClass="doc-h2-anchor-row--tabs"
              data-i18n="blog.update.1.section.icons"
            >
              Icon updates
            </DocH2WithAnchor>
            <div class="blog-article__subsection">
              <h4 id={`${id}-sub-icons-office`} class="blog-article__subsection-title" data-i18n="blog.update.1.sub.icons.office">
                Office icons
              </h4>
              <p data-i18n="blog.update.1.p.icons.office">
                We introduced a new set of icons for the new Zoom AI products and more.
              </p>
              <figure class="blog-article__inline-figure">
                <img
                  class="blog-article__img"
                  src="/images/articles/article-1/article-1-office-icons.png"
                  width="1024"
                  height="400"
                  loading="lazy"
                  decoding="async"
                  alt=""
                  data-i18n-alt="blog.update.1.icons.office.imgAlt"
                />
                <figcaption class="blog-article__inline-caption blog-article__inline-caption--stack">
                  <div class="blog-article__inline-caption-row">
                    <span class="blog-article__inline-caption__badge" aria-hidden="true">
                      <span class="blog-article__inline-caption__badge-num">1</span>
                    </span>
                    <span class="blog-article__inline-caption__text" data-i18n="blog.update.1.icons.office.caption.1">
                      Classic doc
                    </span>
                  </div>
                  <div class="blog-article__inline-caption-row">
                    <span class="blog-article__inline-caption__badge" aria-hidden="true">
                      <span class="blog-article__inline-caption__badge-num">2</span>
                    </span>
                    <span class="blog-article__inline-caption__text" data-i18n="blog.update.1.icons.office.caption.2">
                      AI docs
                    </span>
                  </div>
                  <div class="blog-article__inline-caption-row">
                    <span class="blog-article__inline-caption__badge" aria-hidden="true">
                      <span class="blog-article__inline-caption__badge-num">3</span>
                    </span>
                    <span class="blog-article__inline-caption__text" data-i18n="blog.update.1.icons.office.caption.3">
                      AI slides
                    </span>
                  </div>
                  <div class="blog-article__inline-caption-row">
                    <span class="blog-article__inline-caption__badge" aria-hidden="true">
                      <span class="blog-article__inline-caption__badge-num">4</span>
                    </span>
                    <span class="blog-article__inline-caption__text" data-i18n="blog.update.1.icons.office.caption.4">
                      AI sheets
                    </span>
                  </div>
                  <div class="blog-article__inline-caption-row">
                    <span class="blog-article__inline-caption__badge" aria-hidden="true">
                      <span class="blog-article__inline-caption__badge-num">5</span>
                    </span>
                    <span class="blog-article__inline-caption__text" data-i18n="blog.update.1.icons.office.caption.5">
                      AI data tables
                    </span>
                  </div>
                </figcaption>
              </figure>
            </div>
            <div class="blog-article__subsection">
              <h4 id={`${id}-sub-icons-deprecated`} class="blog-article__subsection-title" data-i18n="blog.update.1.sub.icons.deprecated">
                Deprecated icons
              </h4>
              <p class="blog-article__affected-icons-label" data-i18n="blog.update.1.p.icons.deprecated.intro">
                The following icons have been deprecated and replaced:
              </p>
              <ul class="blog-article__affected-icons-list">
                <li data-i18n="blog.update.1.icons.deprecated.paper">Paper → Classic doc</li>
                <li data-i18n="blog.update.1.icons.deprecated.docs">Docs → AI docs</li>
                <li data-i18n="blog.update.1.icons.deprecated.present">Present → AI slides</li>
                <li data-i18n="blog.update.1.icons.deprecated.sheet">Sheet → AI sheets</li>
              </ul>
            </div>
            <div class="blog-article__subsection">
              <h4 id={`${id}-sub-icons-file-types-updated`} class="blog-article__subsection-title" data-i18n="blog.update.1.sub.icons.fileTypesUpdated">
                Updated file type icons
              </h4>
              <p data-i18n="blog.update.1.p.icons.fileTypesUpdated">
                We refreshed the file type icons for XLS, PPT, and DOC.
              </p>
              <figure class="blog-article__inline-figure">
                <img
                  class="blog-article__img"
                  src="/images/articles/article-1/article-1-file-type-icons-xls-ppt-doc.png"
                  width="1024"
                  height="400"
                  loading="lazy"
                  decoding="async"
                  alt=""
                  data-i18n-alt="blog.update.1.icons.fileTypesUpdated.imgAlt"
                />
              </figure>
            </div>
            <DocH2WithAnchor
              id={`${id}-section-tokens`}
              class="doc-tabs__h2 blog-article__section-title"
              rowClass="doc-h2-anchor-row--tabs"
              data-i18n="blog.update.1.section.tokens"
            >
              Color updates
            </DocH2WithAnchor>
            <div class="blog-article__subsection">
              <h4
                id={`${id}-sub-tokens-spreadsheet`}
                class="blog-article__subsection-title"
                data-i18n="blog.update.1.sub.tokens.spreadsheet"
              >
                Spreadsheet file type
              </h4>
              <p class="blog-article__token-lede">
                <span data-i18n="blog.update.1.p.tokens.lead">We updated the </span>
                <code class="blog-article__token-path">component/icon/fileType/spreadsheet</code>
                <span data-i18n="blog.update.1.p.tokens.tail"> token to a brighter green.</span>
              </p>
              <div
                class="blog-article__compare-row"
                role="group"
                data-i18n-aria="blog.update.1.tokens.compareAria"
                aria-label="Original and updated library token tile"
              >
                <figure class="blog-article__inline-figure blog-article__compare-cell">
                  <img
                    class="blog-article__img"
                    src="/images/articles/article-1/article-1-token-original.png"
                    width="616"
                    height="340"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="blog.update.1.tokens.imgAlt.original"
                  />
                  <figcaption class="blog-article__inline-caption">
                    <span class="blog-article__inline-caption__text" data-i18n="blog.update.1.tokens.caption.original">
                      Original
                    </span>
                  </figcaption>
                </figure>
                <figure class="blog-article__inline-figure blog-article__compare-cell">
                  <img
                    class="blog-article__img"
                    src="/images/articles/article-1/article-1-token-updated.png"
                    width="616"
                    height="340"
                    loading="lazy"
                    decoding="async"
                    alt=""
                    data-i18n-alt="blog.update.1.tokens.imgAlt.updated"
                  />
                  <figcaption class="blog-article__inline-caption">
                    <span class="blog-article__inline-caption__text" data-i18n="blog.update.1.tokens.caption.updated">
                      Updated
                    </span>
                  </figcaption>
                </figure>
              </div>
              <p class="blog-article__affected-icons-label" data-i18n="blog.update.1.tokens.affectedIconsLabel">
                These icons use the new updated color:
              </p>
              <ul class="blog-article__affected-icons-list">
                <li data-i18n="blog.update.1.tokens.affectedIcons.xls">XLS</li>
                <li data-i18n="blog.update.1.tokens.affectedIcons.spreadsheet">Spreadsheet</li>
                <li data-i18n="blog.update.1.tokens.affectedIcons.aiSheets">AI sheets</li>
                <li data-i18n="blog.update.1.tokens.affectedIcons.aiDataTables">AI data tables</li>
              </ul>
            </div>
            <div class="blog-article__subsection">
              <h4
                id={`${id}-sub-tokens-new-file-types`}
                class="blog-article__subsection-title"
                data-i18n="blog.update.1.sub.tokens.newFileTypes"
              >
                New file types
              </h4>
              <div
                class="blog-article__compare-row"
                role="group"
                data-i18n-aria="blog.update.1.tokens.newFileTypesCompareAria"
                aria-label="New docs and slides library file-type tiles"
              >
                <div class="blog-article__compare-cell">
                  <figure class="blog-article__inline-figure">
                    <img
                      class="blog-article__img"
                      src="/images/articles/article-1/article-1-token-file-type-docs.png"
                      width="616"
                      height="340"
                      loading="lazy"
                      decoding="async"
                      alt=""
                      data-i18n-alt="blog.update.1.tokens.imgAlt.docs"
                    />
                    <figcaption class="blog-article__inline-caption blog-article__inline-caption--token-new">
                      <span data-i18n="blog.update.1.tokens.newFile.captionLead">New token:</span>
                      <code class="blog-article__token-path">component/icon/fileType/docs</code>
                    </figcaption>
                  </figure>
                  <p class="blog-article__affected-icons-label" data-i18n="blog.update.1.tokens.newFile.affectedIconsColon">
                    Affected icons:
                  </p>
                  <ul class="blog-article__affected-icons-list">
                    <li data-i18n="blog.update.1.tokens.newFile.docsAffected.classicDoc">Classic doc</li>
                    <li data-i18n="blog.update.1.tokens.newFile.docsAffected.doc">Doc</li>
                  </ul>
                </div>
                <div class="blog-article__compare-cell">
                  <figure class="blog-article__inline-figure">
                    <img
                      class="blog-article__img"
                      src="/images/articles/article-1/article-1-token-file-type-slides.png"
                      width="616"
                      height="340"
                      loading="lazy"
                      decoding="async"
                      alt=""
                      data-i18n-alt="blog.update.1.tokens.imgAlt.slides"
                    />
                    <figcaption class="blog-article__inline-caption blog-article__inline-caption--token-new">
                      <span data-i18n="blog.update.1.tokens.newFile.captionLead">New token:</span>
                      <code class="blog-article__token-path">component/icon/fileType/slides</code>
                    </figcaption>
                  </figure>
                  <p class="blog-article__affected-icons-label" data-i18n="blog.update.1.tokens.newFile.affectedIconsColon">
                    Affected icons:
                  </p>
                  <ul class="blog-article__affected-icons-list">
                    <li data-i18n="blog.update.1.tokens.newFile.slidesAffected.aiSlides">AI Slides</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        ) : n === 8 ? (
          <div class="blog-article__sections">
            <DocH2WithAnchor
              id={`${id}-intro-subtitle`}
              class="doc-tabs__h2 blog-article__section-title"
              rowClass="doc-h2-anchor-row--tabs"
              data-i18n="blog.update.8.intro.eyebrow"
            >
              Introducing the first Prism skill
            </DocH2WithAnchor>
            <p data-i18n="blog.update.8.intro.p1">
              We’re excited to share the first Prism skill for product teams. This is a new way to help teams move faster with Prism by giving them guided support right when you need it.
            </p>
            <section class="blog-article__section" aria-labelledby={`${id}-section-what`}>
              <DocH2WithAnchor
                id={`${id}-section-what`}
                class="doc-tabs__h2 blog-article__section-title"
                rowClass="doc-h2-anchor-row--tabs"

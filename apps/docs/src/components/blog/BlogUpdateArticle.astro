            document.querySelectorAll("[data-blog-pagination-demo]").forEach(function (root) {
              var video = root.querySelector("video");
              var btn = root.querySelector("[data-blog-pagination-demo-toggle]");
              if (!video || !btn) return;
              var pauseIcon = btn.querySelector(".blog-article__inline-video-icon--pause");
              var playIcon = btn.querySelector(".blog-article__inline-video-icon--play");
              var motionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
              function syncUi() {
                var paused = video.paused;
                btn.setAttribute("aria-pressed", paused ? "false" : "true");
                if (pauseIcon) {
                  if (paused) pauseIcon.setAttribute("hidden", "");
                  else pauseIcon.removeAttribute("hidden");
                }
                if (playIcon) {
                  if (paused) playIcon.removeAttribute("hidden");
                  else playIcon.setAttribute("hidden", "");
                }
              }
              if (motionQuery.matches) {
                video.removeAttribute("autoplay");
                video.pause();
                video.controls = true;
                btn.setAttribute("hidden", "");
                btn.setAttribute("aria-hidden", "true");
                return;
              }
              btn.addEventListener("click", function () {
                if (video.paused) {
                  void video.play();
                } else {
                  video.pause();
                }
                syncUi();
              });
              video.addEventListener("play", syncUi);
              video.addEventListener("pause", syncUi);
              syncUi();
            });
          })();
        </script>
